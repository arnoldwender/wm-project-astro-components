---
/**
 * AccessibleAlert Component - WenderMedia Astro Components
 *
 * A11y-first static alert/notification banner with full WAI-ARIA live-region
 * contract. Renders a visible, fully accessible alert for info, success,
 * warning, or error states. Screen readers announce the alert content
 * immediately on mount: `role="alert"` (assertive) for errors, `role="status"`
 * (polite) for all other types.
 *
 * Relationship to library siblings:
 * - Complements `accessibility/LiveRegion` (dynamic, JS-injected announcements)
 *   by providing a static, SSR-rendered alert with visible UI.
 * - Unlike `ui/Alert` (if present), this component prioritises the WAI-ARIA
 *   live-region contract and design-token compliance over Tailwind utility classes.
 *
 * WAI-ARIA contract (WCAG 2.2 / APG):
 * - `role="alert"` + `aria-live="assertive"` + `aria-atomic="true"` for errors
 * - `role="status"` + `aria-live="polite"` + `aria-atomic="true"` for info/success/warning
 * - Icon SVGs carry `aria-hidden="true"`; type label exposed to AT via
 *   visually-hidden `<span class="sr-only">` prefix inside the title
 * - Dismissible variant sets `aria-label` on the close button for AT
 * - Focus moves to the alert wrapper on mount when `autofocus` is true
 *
 * @example
 * <!-- Simple info alert -->
 * <AccessibleAlert type="info" message="Your profile has been updated." />
 *
 * @example
 * <!-- Error alert with title and dismiss button -->
 * <AccessibleAlert
 *   type="error"
 *   title="Submission failed"
 *   message="Please fill in all required fields."
 *   dismissible
 * />
 *
 * @example
 * <!-- Success with autofocus (e.g. after form submit) -->
 * <AccessibleAlert
 *   type="success"
 *   message="Your order has been placed."
 *   autofocus
 * />
 *
 * @copyright 2007-2026 Arnold Wender · Wender Media. All Rights Reserved. License: LicenseRef-Wender-Media-Source-1.0
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  /** Visual and semantic alert type. Drives role, aria-live, colours and icon. */
  type?: 'info' | 'success' | 'warning' | 'error';
  /** Optional bold title line rendered above the message. */
  title?: string;
  /** The main alert message text. Required. */
  message: string;
  /** When true, renders a close (×) button. The alert is removed from the DOM on click. */
  dismissible?: boolean;
  /**
   * When true, the alert wrapper receives `tabindex="-1"` and JS moves focus
   * to it on mount (useful after async operations like form submissions).
   */
  autofocus?: boolean;
  /** Additional CSS classes forwarded to the root element. */
  class?: string;
  /** Unique id applied to the root element (useful for aria-describedby references). */
  id?: string;
}

const {
  type = 'info',
  title,
  message,
  dismissible = false,
  autofocus = false,
  class: className = '',
  id,
} = Astro.props;

// WAI-ARIA: errors are assertive (interrupts); everything else is polite.
const role = type === 'error' ? 'alert' : 'status';
const ariaLive = type === 'error' ? 'assertive' : 'polite';

// Human-readable type label for screen readers (prepended sr-only to title).
const typeLabels: Record<NonNullable<Props['type']>, string> = {
  info: 'Information',
  success: 'Success',
  warning: 'Warning',
  error: 'Error',
};
const typeLabel = typeLabels[type];

// Icon paths — purely decorative (aria-hidden), one per type.
const icons: Record<NonNullable<Props['type']>, string> = {
  info: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  success: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  warning: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  error: 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z',
};
const iconPath = icons[type];
---

<div
  {id}
  role={role}
  aria-live={ariaLive}
  aria-atomic="true"
  tabindex={autofocus ? -1 : undefined}
  class:list={['accessible-alert', `accessible-alert--${type}`, { 'accessible-alert--dismissible': dismissible }, className]}
  data-accessible-alert
  data-autofocus={autofocus ? '' : undefined}
>
  <!-- Icon (decorative, aria-hidden) -->
  <svg
    class="accessible-alert__icon"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
    focusable="false"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
  </svg>

  <!-- Content -->
  <div class="accessible-alert__body">
    {title && (
      <p class="accessible-alert__title">
        {/* Screen-reader-only type prefix keeps the title self-explanatory out of context */}
        <span class="sr-only">{typeLabel}: </span>
        {title}
      </p>
    )}
    <p class="accessible-alert__message">
      {/* When there is no title, expose type label only to AT */}
      {!title && <span class="sr-only">{typeLabel}: </span>}
      {message}
    </p>
  </div>

  {dismissible && (
    <button
      type="button"
      class="accessible-alert__dismiss"
      aria-label="Dismiss alert"
      data-dismiss-alert
    >
      {/* × glyph via SVG keeps it sharp at all sizes */}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
        focusable="false"
        class="accessible-alert__dismiss-icon"
      >
        <path
          fill-rule="evenodd"
          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
          clip-rule="evenodd"
        />
      </svg>
    </button>
  )}
</div>

<script>
  function initAccessibleAlerts(): void {
    // --- Autofocus: move focus to the alert on mount ---
    document.querySelectorAll<HTMLElement>('[data-accessible-alert][data-autofocus]').forEach((el) => {
      // Defer so the layout has settled; respects prefers-reduced-motion (focus itself is instant)
      requestAnimationFrame(() => {
        el.focus({ preventScroll: false });
      });
    });

    // --- Dismiss button: remove alert from DOM, return focus to a sensible target ---
    document.querySelectorAll<HTMLButtonElement>('[data-dismiss-alert]').forEach((btn) => {
      if (btn.dataset.alertInitialised) return;
      btn.dataset.alertInitialised = '1';

      btn.addEventListener('click', () => {
        const alert = btn.closest<HTMLElement>('[data-accessible-alert]');
        if (!alert) return;

        // Attempt to return focus to the element that existed before the alert
        // (heuristic: previous focusable sibling or the <body>).
        const focusTarget =
          (alert.previousElementSibling as HTMLElement | null) ??
          (document.querySelector<HTMLElement>('main h1, main, body') as HTMLElement);

        alert.remove();

        if (focusTarget && typeof focusTarget.focus === 'function') {
          focusTarget.focus({ preventScroll: true });
        }
      });
    });
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccessibleAlerts);
  } else {
    initAccessibleAlerts();
  }

  // Re-run on Astro View Transitions
  document.addEventListener('astro:page-load', initAccessibleAlerts);
</script>

<style>
  /* ------------------------------------------------------------------ */
  /* sr-only — standard 1-pixel clip pattern (WCAG technique)            */
  /* ------------------------------------------------------------------ */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ------------------------------------------------------------------ */
  /* Base alert shell                                                     */
  /* ------------------------------------------------------------------ */
  .accessible-alert {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-3);
    padding: var(--spacing-4);
    border-width: 1px;
    border-style: solid;
    border-radius: var(--border-radius-lg);
    font-size: var(--font-size-sm);
    line-height: var(--font-line-height-relaxed);
    /* Subtle entrance — respects prefers-reduced-motion below */
    animation: alert-in var(--transition-duration-slow) var(--transition-timing-ease-out) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .accessible-alert {
      animation: none;
    }
  }

  @keyframes alert-in {
    from {
      opacity: 0;
      transform: translateY(-var(--spacing-1));
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ------------------------------------------------------------------ */
  /* Focus ring — :focus-visible only (keyboard users)                   */
  /* ------------------------------------------------------------------ */
  .accessible-alert:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  /* ------------------------------------------------------------------ */
  /* Icon                                                                 */
  /* ------------------------------------------------------------------ */
  .accessible-alert__icon {
    /* Fixed 20×20 — keeps layout stable regardless of content length    */
    width: var(--spacing-5);
    height: var(--spacing-5);
    flex-shrink: 0;
    /* Vertical alignment: nudge down slightly so icon aligns with text cap */
    margin-top: 0.125rem;
  }

  /* ------------------------------------------------------------------ */
  /* Body                                                                 */
  /* ------------------------------------------------------------------ */
  .accessible-alert__body {
    flex: 1;
    min-width: 0; /* Prevents overflow in flex containers */
  }

  .accessible-alert__title {
    font-weight: var(--font-weight-semibold);
    margin: 0 0 var(--spacing-1) 0;
  }

  .accessible-alert__message {
    margin: 0;
  }

  /* ------------------------------------------------------------------ */
  /* Dismiss button — 44×44 touch target (WCAG 2.5.5)                   */
  /* ------------------------------------------------------------------ */
  .accessible-alert__dismiss {
    display: flex;
    align-items: center;
    justify-content: center;
    /* Minimum 44×44 touch target */
    min-width: 2.75rem;
    min-height: 2.75rem;
    flex-shrink: 0;
    margin: calc(var(--spacing-2) * -1) calc(var(--spacing-2) * -1) auto auto;
    padding: var(--spacing-2);
    background: transparent;
    border: none;
    border-radius: var(--border-radius-md);
    cursor: pointer;
    transition:
      background-color var(--transition-duration-fast) var(--transition-timing-ease),
      opacity var(--transition-duration-fast) var(--transition-timing-ease);
    opacity: var(--opacity-70);
  }

  .accessible-alert__dismiss:hover {
    opacity: 1;
  }

  .accessible-alert__dismiss:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
    opacity: 1;
  }

  .accessible-alert__dismiss-icon {
    width: var(--spacing-4);
    height: var(--spacing-4);
  }

  /* ------------------------------------------------------------------ */
  /* Type variants — all values are token-resolved                        */
  /* ------------------------------------------------------------------ */

  /* info */
  .accessible-alert--info {
    background-color: var(--color-semantic-info-light);
    border-color: var(--color-sky-200);
    color: var(--color-sky-900);
  }
  .accessible-alert--info .accessible-alert__icon {
    color: var(--color-sky-600);
  }
  .accessible-alert--info .accessible-alert__dismiss:hover {
    background-color: var(--color-sky-100);
  }

  /* success */
  .accessible-alert--success {
    background-color: var(--color-semantic-success-light);
    border-color: var(--color-green-200);
    color: var(--color-green-900);
  }
  .accessible-alert--success .accessible-alert__icon {
    color: var(--color-green-600);
  }
  .accessible-alert--success .accessible-alert__dismiss:hover {
    background-color: var(--color-green-100);
  }

  /* warning */
  .accessible-alert--warning {
    background-color: var(--color-semantic-warning-light);
    border-color: var(--color-amber-200);
    color: var(--color-amber-900);
  }
  .accessible-alert--warning .accessible-alert__icon {
    color: var(--color-amber-600);
  }
  .accessible-alert--warning .accessible-alert__dismiss:hover {
    background-color: var(--color-amber-100);
  }

  /* error */
  .accessible-alert--error {
    background-color: var(--color-semantic-error-light);
    border-color: var(--color-red-200);
    color: var(--color-red-900);
  }
  .accessible-alert--error .accessible-alert__icon {
    color: var(--color-red-600);
  }
  .accessible-alert--error .accessible-alert__dismiss:hover {
    background-color: var(--color-red-100);
  }

  /* ------------------------------------------------------------------ */
  /* Forced colors (Windows High Contrast)                               */
  /* ------------------------------------------------------------------ */
  @media (forced-colors: active) {
    .accessible-alert {
      forced-color-adjust: none;
      background: ButtonFace;
      border-color: ButtonText;
      color: ButtonText;
    }

    .accessible-alert__icon,
    .accessible-alert__dismiss {
      color: ButtonText;
    }

    .accessible-alert__dismiss:focus-visible {
      outline: 2px solid ButtonText;
    }
  }
</style>
