---
/**
 * Premium Text-to-Speech Component - WenderMedia Astro Components
 *
 * Web Speech API powered TTS controls for page content.
 *
 * Features:
 * - Play/Pause/Stop controls
 * - Speed and pitch adjustment
 * - Voice selection
 * - Read selected text or full page
 * - Highlight current sentence
 * - Language auto-detection
 * - Keyboard shortcuts
 *
 * Accessibility:
 * - Helps users with dyslexia, low vision
 * - Supports multiple languages
 * - Works with screen readers
 *
 * @example
 * <!-- Full TTS toolbar targeting the main content -->
 * <TextToSpeech targetSelector="main" variant="full" />
 *
 * @example
 * <!-- Compact floating button for article reading -->
 * <TextToSpeech
 *   targetSelector="#article-body"
 *   variant="floating"
 *   defaultRate={1.2}
 *   showVoiceSelect={false}
 * />
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  targetSelector?: string;
  autoHighlight?: boolean;
  defaultRate?: number;
  defaultPitch?: number;
  showVoiceSelect?: boolean;
  showRateControl?: boolean;
  showPitchControl?: boolean;
  variant?: 'full' | 'compact' | 'floating';
  position?: 'top' | 'bottom';
  labels?: {
    play?: string;
    pause?: string;
    stop?: string;
    rate?: string;
    pitch?: string;
    voice?: string;
    readSelection?: string;
    readPage?: string;
  };
  class?: string;
}

const defaultLabels = {
  play: 'Play',
  pause: 'Pause',
  stop: 'Stop',
  rate: 'Speed',
  pitch: 'Pitch',
  voice: 'Voice',
  readSelection: 'Read Selection',
  readPage: 'Read Page',
};

const {
  targetSelector = 'main, article, .content',
  autoHighlight = true,
  defaultRate = 1,
  defaultPitch = 1,
  showVoiceSelect = true,
  showRateControl = true,
  showPitchControl = false,
  variant = 'full',
  position = 'bottom',
  labels = defaultLabels,
  class: className = '',
} = Astro.props;

const mergedLabels = { ...defaultLabels, ...labels };
---

<div
  class:list={[
    'tts-controls',
    `variant-${variant}`,
    `position-${position}`,
    className
  ]}
  data-tts-controls
  data-target={targetSelector}
  data-highlight={autoHighlight}
  data-rate={defaultRate}
  data-pitch={defaultPitch}
>
  {/* Full Variant */}
  {variant === 'full' && (
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-lg">
      <div class="flex flex-wrap items-center gap-4">
        {/* Playback Controls */}
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="p-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
            aria-label={mergedLabels.play}
            data-tts-play
          >
            <svg class="w-5 h-5" data-icon-play fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
            <svg class="w-5 h-5 hidden" data-icon-pause fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
            </svg>
          </button>

          <button
            type="button"
            class="p-2 rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-gray-500 transition-colors"
            aria-label={mergedLabels.stop}
            data-tts-stop
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 6h12v12H6z" />
            </svg>
          </button>
        </div>

        {/* Voice Select */}
        {showVoiceSelect && (
          <div class="flex items-center gap-2">
            <label for="tts-voice" class="text-sm font-medium text-gray-700 dark:text-gray-300">
              {mergedLabels.voice}
            </label>
            <select
              id="tts-voice"
              class="px-3 py-1.5 text-sm border border-gray-200 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
              data-tts-voice
            >
              <option value="">Loading...</option>
            </select>
          </div>
        )}

        {/* Rate Control */}
        {showRateControl && (
          <div class="flex items-center gap-2">
            <label for="tts-rate" class="text-sm font-medium text-gray-700 dark:text-gray-300">
              {mergedLabels.rate}
            </label>
            <input
              type="range"
              id="tts-rate"
              min="0.5"
              max="2"
              step="0.1"
              value={defaultRate}
              class="w-20 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700"
              data-tts-rate
            />
            <span class="text-xs text-gray-500 w-8" data-tts-rate-value>{defaultRate}x</span>
          </div>
        )}

        {/* Pitch Control */}
        {showPitchControl && (
          <div class="flex items-center gap-2">
            <label for="tts-pitch" class="text-sm font-medium text-gray-700 dark:text-gray-300">
              {mergedLabels.pitch}
            </label>
            <input
              type="range"
              id="tts-pitch"
              min="0.5"
              max="2"
              step="0.1"
              value={defaultPitch}
              class="w-20 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700"
              data-tts-pitch
            />
            <span class="text-xs text-gray-500 w-8" data-tts-pitch-value>{defaultPitch}</span>
          </div>
        )}

        {/* Read Selection/Page Buttons */}
        <div class="flex items-center gap-2 ml-auto">
          <button
            type="button"
            class="px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
            data-tts-read-selection
          >
            {mergedLabels.readSelection}
          </button>
          <button
            type="button"
            class="px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors"
            data-tts-read-page
          >
            {mergedLabels.readPage}
          </button>
        </div>
      </div>
    </div>
  )}

  {/* Compact Variant */}
  {variant === 'compact' && (
    <div class="inline-flex items-center gap-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full px-4 py-2 shadow-md">
      <button
        type="button"
        class="p-1.5 rounded-full bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
        aria-label={mergedLabels.play}
        data-tts-play
      >
        <svg class="w-4 h-4" data-icon-play fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z" />
        </svg>
        <svg class="w-4 h-4 hidden" data-icon-pause fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
        </svg>
      </button>

      <button
        type="button"
        class="p-1.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
        aria-label={mergedLabels.stop}
        data-tts-stop
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 6h12v12H6z" />
        </svg>
      </button>

      {showRateControl && (
        <div class="flex items-center gap-1 border-l border-gray-200 dark:border-gray-700 pl-2 ml-1">
          <button
            type="button"
            class="p-1 text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300"
            data-tts-rate-decrease
          >
            −
          </button>
          <span class="text-xs text-gray-600 dark:text-gray-400 w-8 text-center" data-tts-rate-value>{defaultRate}x</span>
          <button
            type="button"
            class="p-1 text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300"
            data-tts-rate-increase
          >
            +
          </button>
        </div>
      )}
    </div>
  )}

  {/* Floating Variant */}
  {variant === 'floating' && (
    <div class:list={[
      'fixed z-50 right-6',
      position === 'top' ? 'top-6' : 'bottom-6'
    ]}>
      <div class="flex flex-col items-end gap-2">
        <button
          type="button"
          class="w-14 h-14 rounded-full bg-blue-600 text-white shadow-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all flex items-center justify-center"
          aria-label={mergedLabels.play}
          data-tts-play
        >
          <svg class="w-6 h-6" data-icon-play fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z" />
          </svg>
          <svg class="w-6 h-6 hidden" data-icon-pause fill="currentColor" viewBox="0 0 24 24">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
          </svg>
        </button>

        <button
          type="button"
          class="w-10 h-10 rounded-full bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 shadow-lg hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 transition-all flex items-center justify-center"
          aria-label={mergedLabels.stop}
          data-tts-stop
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6 6h12v12H6z" />
          </svg>
        </button>
      </div>
    </div>
  )}
</div>

<style is:global>
  /* Highlight currently spoken text */
  .tts-highlight {
    background: #ffeb3b !important;
    color: #000 !important;
    padding: 2px 4px;
    border-radius: 2px;
  }

  /* Reduced motion - disable highlight animation */
  @media (prefers-reduced-motion: reduce) {
    .tts-highlight {
      transition: none;
    }
  }
</style>

<script>
function initTextToSpeech() {
  if (!('speechSynthesis' in window)) {
    console.warn('Text-to-Speech is not supported in this browser');
    return;
  }

  const controls = document.querySelectorAll('[data-tts-controls]');

  controls.forEach(control => {
    const targetSelector = control.getAttribute('data-target') || 'main';
    const autoHighlight = control.getAttribute('data-highlight') === 'true';
    let rate = parseFloat(control.getAttribute('data-rate') || '1');
    let pitch = parseFloat(control.getAttribute('data-pitch') || '1');

    const playBtn = control.querySelector('[data-tts-play]');
    const stopBtn = control.querySelector('[data-tts-stop]');
    const voiceSelect = control.querySelector('[data-tts-voice]') as HTMLSelectElement;
    const rateInput = control.querySelector('[data-tts-rate]') as HTMLInputElement;
    const pitchInput = control.querySelector('[data-tts-pitch]') as HTMLInputElement;
    const rateValue = control.querySelector('[data-tts-rate-value]');
    const pitchValue = control.querySelector('[data-tts-pitch-value]');
    const readSelectionBtn = control.querySelector('[data-tts-read-selection]');
    const readPageBtn = control.querySelector('[data-tts-read-page]');
    const rateDecreaseBtn = control.querySelector('[data-tts-rate-decrease]');
    const rateIncreaseBtn = control.querySelector('[data-tts-rate-increase]');

    const playIcon = control.querySelector('[data-icon-play]');
    const pauseIcon = control.querySelector('[data-icon-pause]');

    let currentUtterance: SpeechSynthesisUtterance | null = null;
    let isPaused = false;
    let voices: SpeechSynthesisVoice[] = [];

    // Load voices
    function loadVoices() {
      voices = speechSynthesis.getVoices();

      if (voiceSelect && voices.length > 0) {
        voiceSelect.innerHTML = '';

        // Group by language
        const grouped: Record<string, SpeechSynthesisVoice[]> = {};
        voices.forEach(voice => {
          const lang = voice.lang.split('-')[0];
          if (!grouped[lang]) grouped[lang] = [];
          grouped[lang].push(voice);
        });

        // Current page language first
        const pageLang = document.documentElement.lang || 'en';

        Object.entries(grouped)
          .sort(([a], [b]) => {
            if (a === pageLang) return -1;
            if (b === pageLang) return 1;
            return a.localeCompare(b);
          })
          .forEach(([lang, langVoices]) => {
            const optgroup = document.createElement('optgroup');
            optgroup.label = new Intl.DisplayNames([pageLang], { type: 'language' }).of(lang) || lang;

            langVoices.forEach(voice => {
              const option = document.createElement('option');
              option.value = voice.name;
              option.textContent = `${voice.name}${voice.localService ? '' : ' (Online)'}`;
              if (voice.lang.startsWith(pageLang) && voice.default) {
                option.selected = true;
              }
              optgroup.appendChild(option);
            });

            voiceSelect.appendChild(optgroup);
          });
      }
    }

    // Load voices (async in some browsers)
    loadVoices();
    speechSynthesis.onvoiceschanged = loadVoices;

    function updateIcons(playing: boolean) {
      if (playIcon && pauseIcon) {
        playIcon.classList.toggle('hidden', playing);
        pauseIcon.classList.toggle('hidden', !playing);
      }
    }

    function speak(text: string) {
      // Cancel any existing speech
      speechSynthesis.cancel();

      currentUtterance = new SpeechSynthesisUtterance(text);
      currentUtterance.rate = rate;
      currentUtterance.pitch = pitch;
      currentUtterance.lang = document.documentElement.lang || 'en';

      // Set voice
      if (voiceSelect && voiceSelect.value) {
        const selectedVoice = voices.find(v => v.name === voiceSelect.value);
        if (selectedVoice) {
          currentUtterance.voice = selectedVoice;
        }
      }

      currentUtterance.onstart = () => {
        updateIcons(true);
        isPaused = false;
      };

      currentUtterance.onend = () => {
        updateIcons(false);
        removeHighlights();
      };

      currentUtterance.onerror = () => {
        updateIcons(false);
        removeHighlights();
      };

      // Highlight support (basic - highlights whole text)
      if (autoHighlight) {
        currentUtterance.onboundary = (event) => {
          // Browser support for word boundaries varies
          if (event.name === 'word') {
            // Could implement word-level highlighting here
          }
        };
      }

      speechSynthesis.speak(currentUtterance);
    }

    function removeHighlights() {
      document.querySelectorAll('.tts-highlight').forEach(el => {
        el.classList.remove('tts-highlight');
      });
    }

    function getSelectedText(): string {
      const selection = window.getSelection();
      return selection?.toString().trim() || '';
    }

    function getPageText(): string {
      const target = document.querySelector(targetSelector);
      if (!target) return '';

      // Clone to avoid modifying the DOM
      const clone = target.cloneNode(true) as HTMLElement;

      // Remove scripts, styles, hidden elements
      clone.querySelectorAll('script, style, [aria-hidden="true"], .sr-only').forEach(el => el.remove());

      return clone.textContent?.trim() || '';
    }

    // Event handlers
    playBtn?.addEventListener('click', () => {
      if (speechSynthesis.speaking && !isPaused) {
        speechSynthesis.pause();
        isPaused = true;
        updateIcons(false);
      } else if (isPaused) {
        speechSynthesis.resume();
        isPaused = false;
        updateIcons(true);
      } else {
        const text = getSelectedText() || getPageText();
        if (text) speak(text);
      }
    });

    stopBtn?.addEventListener('click', () => {
      speechSynthesis.cancel();
      updateIcons(false);
      removeHighlights();
    });

    readSelectionBtn?.addEventListener('click', () => {
      const text = getSelectedText();
      if (text) speak(text);
    });

    readPageBtn?.addEventListener('click', () => {
      const text = getPageText();
      if (text) speak(text);
    });

    // Rate controls
    rateInput?.addEventListener('input', () => {
      rate = parseFloat(rateInput.value);
      if (rateValue) rateValue.textContent = `${rate}x`;
      if (currentUtterance) currentUtterance.rate = rate;
    });

    rateDecreaseBtn?.addEventListener('click', () => {
      rate = Math.max(0.5, rate - 0.1);
      if (rateValue) rateValue.textContent = `${rate.toFixed(1)}x`;
    });

    rateIncreaseBtn?.addEventListener('click', () => {
      rate = Math.min(2, rate + 0.1);
      if (rateValue) rateValue.textContent = `${rate.toFixed(1)}x`;
    });

    // Pitch control
    pitchInput?.addEventListener('input', () => {
      pitch = parseFloat(pitchInput.value);
      if (pitchValue) pitchValue.textContent = pitch.toString();
      if (currentUtterance) currentUtterance.pitch = pitch;
    });

    // Keyboard shortcut (Alt + S to toggle)
    document.addEventListener('keydown', (e) => {
      if (e.altKey && e.key.toLowerCase() === 's') {
        e.preventDefault();
        playBtn?.dispatchEvent(new Event('click'));
      }
    });
  });
}

// Initialize
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initTextToSpeech);
} else {
  initTextToSpeech();
}

// View Transitions support
document.addEventListener('astro:page-load', initTextToSpeech);
</script>
