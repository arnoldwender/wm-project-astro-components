---
/**
 * Screen Reader Only Component - WenderMedia Astro Components
 *
 * Visually hides content while keeping it accessible to screen readers.
 * Essential for providing additional context to assistive technology users.
 *
 * Features:
 * - Visually hidden content accessible to screen readers
 * - Configurable HTML element tag (span, div, p, h1-h6, label)
 * - Optional focusable mode for skip links that appear on focus
 * - Zero visual footprint using clip-path technique
 * - Slot-based content composition
 *
 * Use cases:
 * - Icon button labels
 * - Form field instructions
 * - Skip link targets
 * - Table captions
 * - Live region announcements
 *
 * @example
 * <!-- Hidden label for an icon-only button -->
 * <button>
 *   <svg aria-hidden="true">...</svg>
 *   <ScreenReaderOnly>Close menu</ScreenReaderOnly>
 * </button>
 *
 * @example
 * <!-- Focusable skip link that becomes visible on focus -->
 * <ScreenReaderOnly as="a" focusable id="skip-nav">
 *   Skip to main content
 * </ScreenReaderOnly>
 *
 * @example
 * <!-- Hidden heading for a landmark region -->
 * <ScreenReaderOnly as="h2">Navigation</ScreenReaderOnly>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  as?: 'span' | 'div' | 'p' | 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'label';
  id?: string;
  focusable?: boolean;
  class?: string;
}

const {
  as: Tag = 'span',
  id,
  focusable = false,
  class: className = '',
} = Astro.props;
---

<Tag
  id={id}
  class:list={[
    'sr-only',
    focusable && 'sr-only-focusable',
    className
  ]}
>
  <slot />
</Tag>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sr-only-focusable:focus,
  .sr-only-focusable:active {
    position: static;
    width: auto;
    height: auto;
    padding: inherit;
    margin: inherit;
    overflow: visible;
    clip: auto;
    white-space: normal;
  }
</style>
