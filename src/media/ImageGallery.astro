---
/**
 * ImageGallery Component - WenderMedia Astro Components
 *
 * Responsive image gallery with lightbox support.
 * SEO-optimized with proper lazy loading and structured data.
 *
 * @example
 * <ImageGallery
 *   images={[
 *     { src: '/images/1.jpg', alt: 'Image 1', caption: 'Caption' },
 *     { src: '/images/2.jpg', alt: 'Image 2' },
 *   ]}
 *   columns={3}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  thumbnail?: string;
}

export interface Props {
  images: GalleryImage[];
  columns?: 2 | 3 | 4 | 5 | 6;
  gap?: 'sm' | 'md' | 'lg';
  layout?: 'grid' | 'masonry';
  lightbox?: boolean;
  showCaptions?: boolean;
  aspectRatio?: string;
  rounded?: boolean;
  class?: string;
}

const {
  images,
  columns = 3,
  gap = 'md',
  layout = 'grid',
  lightbox = true,
  showCaptions = false,
  aspectRatio = '1/1',
  rounded = true,
  class: className = '',
} = Astro.props;

const gapClasses = {
  sm: 'gallery--gap-sm',
  md: 'gallery--gap-md',
  lg: 'gallery--gap-lg',
};

// Schema.org ImageGallery structured data
const gallerySchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  image: images.map((img) => ({
    '@type': 'ImageObject',
    contentUrl: img.src,
    description: img.alt,
    caption: img.caption,
  })),
};
---

<div
  class:list={[
    'gallery',
    `gallery--${layout}`,
    `gallery--cols-${columns}`,
    gapClasses[gap],
    rounded && 'gallery--rounded',
    className,
  ]}
  data-gallery
  data-lightbox={lightbox}
  style={layout === 'grid' ? `--aspect-ratio: ${aspectRatio}` : undefined}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(gallerySchema)} />

  {images.map((image, index) => (
    <figure class="gallery__item" data-gallery-item={index}>
      <button
        type="button"
        class="gallery__trigger"
        aria-label={`${image.alt} vergrößern`}
        data-image-index={index}
        disabled={!lightbox}
      >
        <img
          src={image.thumbnail || image.src}
          alt={image.alt}
          width={image.width}
          height={image.height}
          loading="lazy"
          decoding="async"
          class="gallery__image"
        />
        {lightbox && (
          <div class="gallery__overlay">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              <line x1="11" y1="8" x2="11" y2="14"/>
              <line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
        )}
      </button>
      {showCaptions && image.caption && (
        <figcaption class="gallery__caption">{image.caption}</figcaption>
      )}
    </figure>
  ))}
</div>

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
{/* Lightbox Modal */}
{lightbox && (
  <div
    class="lightbox"
    data-lightbox-modal
    role="dialog"
    aria-modal="true"
    aria-label="Bildergalerie"
    hidden
  >
    <div class="lightbox__backdrop" data-lightbox-close></div>

    <div class="lightbox__content">
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
      {/* Close Button */}
      <button
        type="button"
        class="lightbox__close"
        data-lightbox-close
        aria-label="Schließen"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
      {/* Navigation */}
      <button
        type="button"
        class="lightbox__nav lightbox__nav--prev"
        data-lightbox-prev
        aria-label="Vorheriges Bild"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <button
        type="button"
        class="lightbox__nav lightbox__nav--next"
        data-lightbox-next
        aria-label="Nächstes Bild"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
      {/* Image Container */}
      <div class="lightbox__image-container">
        <img
          class="lightbox__image"
          data-lightbox-image
          src=""
          alt=""
        />
        <div class="lightbox__loader" data-lightbox-loader>
          <div class="lightbox__spinner"></div>
        </div>
      </div>

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
      {/* Caption & Counter */}
      <div class="lightbox__footer">
        <p class="lightbox__caption" data-lightbox-caption></p>
        <span class="lightbox__counter" data-lightbox-counter></span>
      </div>
    </div>

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
    {/* Images Data */}
    <script type="application/json" data-images>
      {JSON.stringify(images)}
    </script>
  </div>
)}

<style>
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Gallery Grid */
  .gallery {
    display: grid;
    width: 100%;
  }

  .gallery--grid {
    grid-template-columns: repeat(var(--columns, 3), 1fr);
  }

  .gallery--masonry {
    grid-template-columns: repeat(var(--columns, 3), 1fr);
    grid-auto-rows: 10px;
  }

  .gallery--cols-2 { --columns: 2; }
  .gallery--cols-3 { --columns: 3; }
  .gallery--cols-4 { --columns: 4; }
  .gallery--cols-5 { --columns: 5; }
  .gallery--cols-6 { --columns: 6; }

  .gallery--gap-sm { gap: 0.5rem; }
  .gallery--gap-md { gap: 1rem; }
  .gallery--gap-lg { gap: 1.5rem; }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Responsive columns */
  @media (max-width: 1024px) {
    .gallery--cols-5,
    .gallery--cols-6 { --columns: 4; }
  }

  @media (max-width: 768px) {
    .gallery--cols-4,
    .gallery--cols-5,
    .gallery--cols-6 { --columns: 3; }
  }

  @media (max-width: 480px) {
    .gallery--cols-3,
    .gallery--cols-4,
    .gallery--cols-5,
    .gallery--cols-6 { --columns: 2; }
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Gallery Item */
  .gallery__item {
    margin: 0;
    overflow: hidden;
  }

  .gallery--rounded .gallery__item {
    border-radius: 0.5rem;
  }

  .gallery--grid .gallery__item {
    aspect-ratio: var(--aspect-ratio, 1/1);
  }

  .gallery__trigger {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    overflow: hidden;
  }

  .gallery__trigger:disabled {
    cursor: default;
  }

  .gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery__trigger:not(:disabled):hover .gallery__image {
    transform: scale(1.05);
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gallery__trigger:not(:disabled):hover .gallery__overlay,
  .gallery__trigger:not(:disabled):focus .gallery__overlay {
    opacity: 1;
  }

  .gallery__overlay svg {
    width: 2.5rem;
    height: 2.5rem;
    color: #fff;
  }

  .gallery__caption {
    padding: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
    text-align: center;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    animation: fadeIn 0.2s ease;
  }

  .lightbox__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 4rem 1rem 3rem;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Close Button */
  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s;
    z-index: 10;
  }

  .lightbox__close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox__close svg {
    width: 1.5rem;
    height: 1.5rem;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Navigation */
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s;
    z-index: 10;
  }

  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox__nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .lightbox__nav--prev {
    left: 1rem;
  }

  .lightbox__nav--next {
    right: 1rem;
  }

  .lightbox__nav svg {
    width: 1.5rem;
    height: 1.5rem;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Image Container */
  .lightbox__image-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 90vw;
    max-height: 80vh;
  }

  .lightbox__image {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    animation: zoomIn 0.3s ease;
  }

  .lightbox__loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox__loader[hidden] {
    display: none;
  }

  .lightbox__spinner {
    width: 2.5rem;
    height: 2.5rem;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Footer */
  .lightbox__footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
  }

  .lightbox__caption {
    font-size: 0.9375rem;
    margin: 0;
    opacity: 0.9;
  }

  .lightbox__counter {
    font-size: 0.875rem;
    opacity: 0.7;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes zoomIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Touch devices */
  @media (hover: none) {
    .lightbox__nav {
      width: 2.5rem;
      height: 2.5rem;
    }

    .lightbox__nav svg {
      width: 1.25rem;
      height: 1.25rem;
    }
  }
</style>

<script>
  interface GalleryImage {
    src: string;
    alt: string;
    caption?: string;
    thumbnail?: string;
  }

  function initImageGalleries() {
    document.querySelectorAll('[data-gallery]').forEach((gallery) => {
      const el = gallery as HTMLElement;
      const hasLightbox = el.dataset.lightbox === 'true';

      if (!hasLightbox) return;

      const modal = document.querySelector('[data-lightbox-modal]') as HTMLElement;
      if (!modal) return;

      const imagesJson = modal.querySelector('[data-images]')?.textContent;
      const images: GalleryImage[] = imagesJson ? JSON.parse(imagesJson) : [];

      const imageEl = modal.querySelector('[data-lightbox-image]') as HTMLImageElement;
      const captionEl = modal.querySelector('[data-lightbox-caption]') as HTMLElement;
      const counterEl = modal.querySelector('[data-lightbox-counter]') as HTMLElement;
      const loaderEl = modal.querySelector('[data-lightbox-loader]') as HTMLElement;
      const prevBtn = modal.querySelector('[data-lightbox-prev]') as HTMLButtonElement;
      const nextBtn = modal.querySelector('[data-lightbox-next]') as HTMLButtonElement;
      const closeButtons = modal.querySelectorAll('[data-lightbox-close]');

      let currentIndex = 0;

      function showImage(index: number) {
        if (index < 0 || index >= images.length) return;

        currentIndex = index;
        const image = images[index];

        // Show loader
        loaderEl.hidden = false;
        imageEl.style.opacity = '0';

        // Load image
        const img = new Image();
        img.onload = () => {
          imageEl.src = image.src;
          imageEl.alt = image.alt;
          imageEl.style.opacity = '1';
          loaderEl.hidden = true;
        };
        img.onerror = () => {
          loaderEl.hidden = true;
        };
        img.src = image.src;

        // Update caption and counter
        captionEl.textContent = image.caption || '';
        counterEl.textContent = `${index + 1} / ${images.length}`;

        // Update navigation
        prevBtn.disabled = index === 0;
        nextBtn.disabled = index === images.length - 1;
      }

      function openLightbox(index: number) {
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
        showImage(index);

        // Focus trap
        modal.focus();
      }

      function closeLightbox() {
        modal.hidden = true;
        document.body.style.overflow = '';
      }

      // Click handlers
      el.querySelectorAll('[data-image-index]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const index = parseInt((btn as HTMLElement).dataset.imageIndex || '0', 10);
          openLightbox(index);
        });
      });

      // Navigation
      prevBtn?.addEventListener('click', () => {
        if (currentIndex > 0) showImage(currentIndex - 1);
      });

      nextBtn?.addEventListener('click', () => {
        if (currentIndex < images.length - 1) showImage(currentIndex + 1);
      });

      // Close handlers
      closeButtons.forEach((btn) => {
        btn.addEventListener('click', closeLightbox);
      });

      // Keyboard navigation
      modal.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        switch (key) {
          case 'Escape':
            closeLightbox();
            break;
          case 'ArrowLeft':
            if (currentIndex > 0) showImage(currentIndex - 1);
            break;
          case 'ArrowRight':
            if (currentIndex < images.length - 1) showImage(currentIndex + 1);
            break;
        }
      });

      // Touch swipe
      let touchStartX = 0;
      let touchEndX = 0;

      modal.addEventListener('touchstart', (e) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      }, { passive: true });

      modal.addEventListener('touchend', (e) => {
        touchEndX = (e as TouchEvent).changedTouches[0].screenX;
        handleSwipe();
      }, { passive: true });

      function handleSwipe() {
        const diff = touchStartX - touchEndX;
        const threshold = 50;

        if (Math.abs(diff) < threshold) return;

        if (diff > 0 && currentIndex < images.length - 1) {
          // Swipe left - next
          showImage(currentIndex + 1);
        } else if (diff < 0 && currentIndex > 0) {
          // Swipe right - prev
          showImage(currentIndex - 1);
        }
      }
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initImageGalleries);
  } else {
    initImageGalleries();
  }

  document.addEventListener('astro:page-load', initImageGalleries);
</script>
