---
/**
 * Sidebar Component - WenderMedia Astro Components
 *
 * Collapsible sidebar navigation with nested items support.
 * Perfect for dashboards, admin panels, and documentation sites.
 *
 * @example
 * <Sidebar
 *   items={[
 *     { label: 'Dashboard', href: '/', icon: 'home' },
 *     { label: 'Products', href: '/products', icon: 'box', badge: '12' },
 *     { label: 'Settings', icon: 'cog', children: [...] },
 *   ]}
 *   collapsed={false}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface SidebarItem {
  label: string;
  href?: string;
  icon?: string;
  badge?: string;
  badgeColor?: 'default' | 'primary' | 'success' | 'warning' | 'error';
  children?: SidebarItem[];
  external?: boolean;
  disabled?: boolean;
}

export interface Props {
  items: SidebarItem[];
  collapsed?: boolean;
  collapsible?: boolean;
  logo?: { src: string; alt: string; href?: string };
  footer?: boolean;
  class?: string;
}

const {
  items,
  collapsed = false,
  collapsible = true,
  logo,
  footer = true,
  class: className = '',
} = Astro.props;

const currentPath = Astro.url.pathname;

function isActive(item: SidebarItem): boolean {
  if (item.href === currentPath) return true;
  if (item.href && item.href !== '/' && currentPath.startsWith(item.href)) return true;
  if (item.children) return item.children.some(isActive);
  return false;
}

const icons: Record<string, string> = {
  home: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>',
  box: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>',
  cog: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/>',
  users: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>',
  chart: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>',
  document: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>',
  folder: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>',
  mail: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>',
  calendar: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>',
  chevron: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>',
};
---

<aside
  id="sidebar"
  class:list={[
    'sidebar',
    collapsed && 'sidebar--collapsed',
    className
  ]}
  data-collapsed={collapsed}
>
  <!-- Logo -->
  {logo && (
    <div class="sidebar__logo">
      {logo.href ? (
        <a href={logo.href}>
          <img src={logo.src} alt={logo.alt} />
        </a>
      ) : (
        <img src={logo.src} alt={logo.alt} />
      )}
    </div>
  )}

  <!-- Toggle Button -->
  {collapsible && (
    <button
      id="sidebar-toggle"
      class="sidebar__toggle"
      aria-label="Toggle sidebar"
      aria-expanded={!collapsed}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <Fragment set:html={icons.chevron} />
      </svg>
    </button>
  )}

  <!-- Navigation -->
  <nav class="sidebar__nav">
    <ul class="sidebar__list">
      {items.map((item) => (
        <li class:list={['sidebar__item', isActive(item) && 'sidebar__item--active']}>
          {item.href && !item.children ? (
            <a
              href={item.href}
              class:list={[
                'sidebar__link',
                item.disabled && 'sidebar__link--disabled'
              ]}
              {...(item.external && { target: '_blank', rel: 'noopener noreferrer' })}
              {...(item.disabled && { 'aria-disabled': 'true', tabindex: '-1' })}
            >
              {item.icon && (
                <svg class="sidebar__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={icons[item.icon] || ''} />
                </svg>
              )}
              <span class="sidebar__label">{item.label}</span>
              {item.badge && (
                <span class:list={['sidebar__badge', `sidebar__badge--${item.badgeColor || 'default'}`]}>
                  {item.badge}
                </span>
              )}
            </a>
          ) : (
            <div class="sidebar__group" data-group>
              <button
                class="sidebar__link sidebar__link--expandable"
                aria-expanded={isActive(item)}
                data-group-toggle
              >
                {item.icon && (
                  <svg class="sidebar__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={icons[item.icon] || ''} />
                  </svg>
                )}
                <span class="sidebar__label">{item.label}</span>
                <svg class="sidebar__chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={icons.chevron} />
                </svg>
              </button>
              {item.children && (
                <ul class="sidebar__sublist" data-group-content>
                  {item.children.map((child) => (
                    <li class:list={['sidebar__subitem', currentPath === child.href && 'sidebar__subitem--active']}>
                      <a href={child.href} class="sidebar__sublink">
                        {child.label}
                        {child.badge && (
                          <span class:list={['sidebar__badge', `sidebar__badge--${child.badgeColor || 'default'}`]}>
                            {child.badge}
                          </span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <!-- Footer Slot -->
  {footer && (
    <div class="sidebar__footer">
      <slot name="footer" />
    </div>
  )}
</aside>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 260px;
    background: var(--color-bg-secondary, #f9fafb);
    border-right: 1px solid var(--color-border, #e5e7eb);
    display: flex;
    flex-direction: column;
    transition: width 0.2s ease;
    z-index: 40;
    overflow: hidden;
  }

  .sidebar--collapsed {
    width: 72px;
  }

  .sidebar__logo {
    padding: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .sidebar__logo img {
    height: 2rem;
    width: auto;
    transition: opacity 0.2s;
  }

  .sidebar--collapsed .sidebar__logo img {
    max-width: 2rem;
    object-fit: contain;
  }

  .sidebar__toggle {
    position: absolute;
    top: 1.25rem;
    right: -12px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s;
    z-index: 50;
  }

  .sidebar__toggle svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s;
  }

  .sidebar--collapsed .sidebar__toggle svg {
    transform: rotate(180deg);
  }

  .sidebar__nav {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 0.75rem;
  }

  .sidebar__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar__item {
    margin-bottom: 0.25rem;
  }

  .sidebar__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    color: var(--color-text-muted, #6b7280);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.15s;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
  }

  .sidebar__link:hover {
    background: var(--color-border, #e5e7eb);
    color: var(--color-text, #111);
  }

  .sidebar__item--active > .sidebar__link,
  .sidebar__item--active > .sidebar__group > .sidebar__link {
    background: var(--color-primary, #3b82f6);
    color: var(--color-white, #fff);
  }

  .sidebar__link--disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .sidebar__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .sidebar__label {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar--collapsed .sidebar__label {
    display: none;
  }

  .sidebar__badge {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: var(--color-border, #e5e7eb);
    color: var(--color-text-muted, #6b7280);
  }

  .sidebar__badge--primary { background: var(--color-primary, #3b82f6); color: var(--color-white, #fff); }
  .sidebar__badge--success { background: var(--color-success, #10b981); color: var(--color-white, #fff); }
  .sidebar__badge--warning { background: var(--color-warning, #f59e0b); color: var(--color-white, #fff); }
  .sidebar__badge--error { background: var(--color-error, #ef4444); color: var(--color-white, #fff); }

  .sidebar--collapsed .sidebar__badge {
    display: none;
  }

  .sidebar__chevron {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s;
  }

  .sidebar__link--expandable[aria-expanded="true"] .sidebar__chevron {
    transform: rotate(90deg);
  }

  .sidebar--collapsed .sidebar__chevron {
    display: none;
  }

  .sidebar__sublist {
    list-style: none;
    padding: 0.25rem 0 0.25rem 2.5rem;
    margin: 0;
    display: none;
  }

  .sidebar__link--expandable[aria-expanded="true"] + .sidebar__sublist {
    display: block;
  }

  .sidebar--collapsed .sidebar__sublist {
    display: none;
  }

  .sidebar__subitem {
    margin-bottom: 0.125rem;
  }

  .sidebar__sublink {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    color: var(--color-text-muted, #6b7280);
    text-decoration: none;
    font-size: 0.8125rem;
    transition: all 0.15s;
  }

  .sidebar__sublink:hover {
    color: var(--color-text, #111);
    background: var(--color-border, #e5e7eb);
  }

  .sidebar__subitem--active .sidebar__sublink {
    color: var(--color-primary, #3b82f6);
    font-weight: 500;
  }

  .sidebar__footer {
    padding: 1rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
  }

  .sidebar--collapsed .sidebar__footer {
    padding: 0.75rem;
  }

  @media (prefers-color-scheme: dark) {
    .sidebar {
      --color-bg-secondary: #1a1a1a;
      --color-border: #374151;
      --color-text: #fff;
      --color-text-muted: #9ca3af;
    }
  }

  @media (max-width: 1024px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.sidebar--open {
      transform: translateX(0);
    }
  }
</style>

<script>
  function initSidebar() {
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebar-toggle');
    const groups = document.querySelectorAll('[data-group]');

    if (!sidebar) return;

    // Toggle collapsed state
    toggle?.addEventListener('click', () => {
      const isCollapsed = sidebar.dataset.collapsed === 'true';
      sidebar.dataset.collapsed = String(!isCollapsed);
      sidebar.classList.toggle('sidebar--collapsed');
      toggle.setAttribute('aria-expanded', String(isCollapsed));
      localStorage.setItem('sidebar-collapsed', String(!isCollapsed));
    });

    // Restore collapsed state
    const savedState = localStorage.getItem('sidebar-collapsed');
    if (savedState === 'true') {
      sidebar.dataset.collapsed = 'true';
      sidebar.classList.add('sidebar--collapsed');
      toggle?.setAttribute('aria-expanded', 'false');
    }

    // Group toggles
    groups.forEach((group) => {
      const toggleBtn = group.querySelector('[data-group-toggle]');
      toggleBtn?.addEventListener('click', () => {
        const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
        toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebar);
  } else {
    initSidebar();
  }

  document.addEventListener('astro:page-load', initSidebar);
</script>
