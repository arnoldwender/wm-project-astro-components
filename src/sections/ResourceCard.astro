---
/**
 * ResourceCard Component - WenderMedia Astro Components
 *
 * Individual downloadable resource or document card.
 *
 * @example
 * <ResourceCard
 *   title="Product Brochure"
 *   description="Learn about our products and services"
 *   fileType="pdf"
 *   fileSize="2.4 MB"
 *   href="/downloads/brochure.pdf"
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  title: string;
  description?: string;
  image?: string;
  fileType?: 'pdf' | 'doc' | 'xls' | 'ppt' | 'zip' | 'video' | 'audio' | 'image' | 'other';
  fileSize?: string;
  href: string;
  category?: string;
  downloadCount?: number;
  featured?: boolean;
  variant?: 'default' | 'card' | 'compact' | 'horizontal';
  class?: string;
}

const {
  title,
  description,
  image,
  fileType = 'other',
  fileSize,
  href,
  category,
  downloadCount,
  featured = false,
  variant = 'default',
  class: className = '',
} = Astro.props;

// File type icons and colors
const fileTypeConfig: Record<string, { icon: string; color: string; label: string }> = {
  pdf: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zm-2.5 9.5a.5.5 0 01.5.5v2a.5.5 0 01-.5.5h-1a.5.5 0 01-.5-.5v-2a.5.5 0 01.5-.5h1zm4 0a.5.5 0 01.5.5v2a.5.5 0 01-.5.5h-1a.5.5 0 01-.5-.5v-2a.5.5 0 01.5-.5h1z"/></svg>',
    color: 'bg-red-100 text-red-600',
    label: 'PDF',
  },
  doc: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zm-5 9h8v2H8v-2zm0 4h5v2H8v-2z"/></svg>',
    color: 'bg-blue-100 text-blue-600',
    label: 'DOC',
  },
  xls: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM8 13h2v2H8v-2zm0 4h2v2H8v-2zm4-4h2v2h-2v-2zm0 4h2v2h-2v-2z"/></svg>',
    color: 'bg-green-100 text-green-600',
    label: 'XLS',
  },
  ppt: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zm-3 9a2 2 0 110 4 2 2 0 010-4z"/></svg>',
    color: 'bg-orange-100 text-orange-600',
    label: 'PPT',
  },
  zip: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zm-2 7h2v2h-2v-2zm0 3h2v2h-2v-2zm0 3h2v2h-2v-2z"/></svg>',
    color: 'bg-amber-100 text-amber-600',
    label: 'ZIP',
  },
  video: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 4l2 4h-3l-2-4h-2l2 4h-3l-2-4H8l2 4H7L5 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V4h-4z"/></svg>',
    color: 'bg-purple-100 text-purple-600',
    label: 'Video',
  },
  audio: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>',
    color: 'bg-pink-100 text-pink-600',
    label: 'Audio',
  },
  image: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 19V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>',
    color: 'bg-cyan-100 text-cyan-600',
    label: 'Bild',
  },
  other: {
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4z"/></svg>',
    color: 'bg-gray-100 text-gray-600',
    label: 'Datei',
  },
};

const config = fileTypeConfig[fileType] || fileTypeConfig.other;
---

<a
  href={href}
  download
  class:list={[
    'resource-card group block',
    variant === 'card' && 'bg-surface border border-border-subtle rounded-xl overflow-hidden hover:shadow-lg transition-shadow',
    variant === 'default' && 'flex items-center gap-4 p-4 bg-surface border border-border-subtle rounded-xl hover:border-primary/50 transition-colors',
    variant === 'compact' && 'flex items-center gap-3 p-3 hover:bg-background-subtle rounded-lg transition-colors',
    variant === 'horizontal' && 'flex gap-6 p-6 bg-surface border border-border-subtle rounded-xl hover:shadow-lg transition-shadow',
    featured && 'ring-2 ring-primary/20',
    className,
  ]}
>
  {/* Image for card/horizontal variants */}
  {image && (variant === 'card' || variant === 'horizontal') && (
    <div class:list={[
      'resource-image overflow-hidden',
      variant === 'card' && 'aspect-video',
      variant === 'horizontal' && 'w-48 flex-shrink-0 rounded-lg',
    ]}>
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  )}

  {/* File type icon */}
  {variant !== 'card' && (
    <div class:list={[
      'resource-icon flex-shrink-0 rounded-lg flex items-center justify-center',
      variant === 'compact' ? 'w-10 h-10' : 'w-12 h-12',
      config.color,
    ]}>
      <span class:list={[variant === 'compact' ? 'w-5 h-5' : 'w-6 h-6']} set:html={config.icon} />
    </div>
  )}

  {/* Content */}
  <div class:list={[
    'resource-content flex-1 min-w-0',
    variant === 'card' && 'p-5',
  ]}>
    {/* Category & File type badge */}
    {(category || variant === 'card') && (
      <div class="flex items-center gap-2 mb-1">
        {variant === 'card' && (
          <span class:list={['px-2 py-0.5 text-xs font-medium rounded', config.color]}>
            {config.label}
          </span>
        )}
        {category && (
          <span class="text-xs text-text-tertiary">{category}</span>
        )}
      </div>
    )}

    {/* Title */}
    <h3 class:list={[
      'font-semibold text-text-primary group-hover:text-primary transition-colors truncate',
      variant === 'compact' ? 'text-sm' : 'text-base',
    ]}>
      {title}
    </h3>

    {/* Description */}
    {description && variant !== 'compact' && (
      <p class="text-sm text-text-secondary mt-1 line-clamp-2">{description}</p>
    )}

    {/* Meta info */}
    <div class:list={[
      'flex items-center gap-3 text-xs text-text-tertiary',
      variant === 'compact' ? 'mt-0.5' : 'mt-2',
    ]}>
      {fileSize && (
        <span>{fileSize}</span>
      )}
      {downloadCount !== undefined && (
        <span class="flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {downloadCount.toLocaleString()}
        </span>
      )}
    </div>
  </div>

  {/* Download icon */}
  <div class="resource-action flex-shrink-0">
    <span class:list={[
      'flex items-center justify-center rounded-full bg-background-subtle text-text-tertiary group-hover:bg-primary group-hover:text-white transition-colors',
      variant === 'compact' ? 'w-8 h-8' : 'w-10 h-10',
    ]}>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
      </svg>
    </span>
  </div>
</a>

<style>
  @media (prefers-reduced-motion: reduce) {
    .resource-card {
      transition: none;
    }
  }
</style>
