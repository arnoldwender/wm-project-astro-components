---
/**
 * Premium Testimonials Component - WenderMedia Astro Components
 *
 * High-trust social proof section with:
 * - Carousel/slider with smooth transitions
 * - Video testimonial support
 * - Star ratings display
 * - Company logos and avatars
 * - Schema.org Review markup
 * - Responsive grid and carousel modes
 * - Keyboard accessible navigation
 *
 * Best practices implemented:
 * - Real names, job titles, and photos increase trust
 * - Video testimonials feel more authentic
 * - Third-party badges (G2, Trustpilot) add credibility
 *
 * Features:
 * - Three layout modes (carousel, grid, masonry)
 * - Carousel with autoplay, touch/swipe support, and dot navigation
 * - Trust badge header with platform rating and review count
 * - Schema.org Review structured data for SEO
 * - Keyboard accessible carousel navigation (Arrow keys)
 *
 * @example
 * <Testimonials
 *   title="What our customers say"
 *   layout="carousel"
 *   autoplay
 *   testimonials={[
 *     { id: "1", quote: "Outstanding service and fast delivery.", author: "Jane Doe", role: "CTO", company: "Widget Inc", rating: 5 },
 *     { id: "2", quote: "Transformed our entire workflow in weeks.", author: "John Smith", role: "CEO", company: "Acme Corp", rating: 5 }
 *   ]}
 * />
 *
 * @example
 * <Testimonials
 *   layout="grid"
 *   showRating
 *   testimonials={[
 *     { id: "1", quote: "Reliable and easy to use.", author: "Alice Brown", role: "Designer", company: "Studio One", rating: 4 },
 *     { id: "2", quote: "Great value for money.", author: "Bob Wilson", role: "Manager", company: "DataFlow", rating: 5 },
 *     { id: "3", quote: "Support team is incredibly responsive.", author: "Carol Davis", role: "Lead Dev", company: "TechHub", rating: 5 }
 *   ]}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Testimonial {
  id: string;
  quote: string;
  author: string;
  role: string;
  company: string;
  avatar?: string;
  companyLogo?: string;
  rating?: number;
  videoUrl?: string;
  featured?: boolean;
}

export interface Props {
  title?: string;
  subtitle?: string;
  testimonials: Testimonial[];
  layout?: 'carousel' | 'grid' | 'masonry';
  showRating?: boolean;
  showSchema?: boolean;
  autoplay?: boolean;
  autoplayInterval?: number;
  trustBadge?: {
    platform: string;
    rating: number;
    reviews: number;
    logo: string;
  };
  class?: string;
}

const {
  title = 'What our customers say',
  subtitle = 'Join thousands of satisfied customers who trust us',
  testimonials,
  layout = 'carousel',
  showRating = true,
  showSchema = true,
  autoplay = true,
  autoplayInterval = 5000,
  trustBadge,
  class: className = '',
} = Astro.props;

const averageRating = testimonials.reduce((acc, t) => acc + (t.rating || 5), 0) / testimonials.length;
---

<section
  class:list={['testimonials-section py-16 md:py-24 lg:py-32 bg-gray-50 dark:bg-gray-900', className]}
  data-testimonials-section
  data-layout={layout}
  data-autoplay={autoplay}
  data-interval={autoplayInterval}
>
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      {/* Trust Badge */}
      {trustBadge && (
        <div class="inline-flex items-center gap-3 px-4 py-2 bg-white dark:bg-gray-800 rounded-full shadow-sm mb-6">
          <img src={trustBadge.logo} alt={trustBadge.platform} class="h-6" />
          <div class="flex items-center gap-1">
            {[...Array(5)].map((_, i) => (
              <svg
                class:list={['w-4 h-4', i < Math.floor(trustBadge.rating) ? 'text-yellow-400' : 'text-gray-300']}
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="ml-2 text-sm font-medium">{trustBadge.rating}</span>
          </div>
          <span class="text-sm text-gray-500 dark:text-gray-400">
            {trustBadge.reviews.toLocaleString()} reviews
          </span>
        </div>
      )}

      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">
        {title}
      </h2>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400">
        {subtitle}
      </p>
    </div>

    {/* Carousel Layout */}
    {layout === 'carousel' && (
      <div class="relative max-w-4xl mx-auto" data-carousel>
        {/* Testimonial Cards */}
        <div class="overflow-hidden" data-carousel-viewport>
          <div class="flex transition-transform duration-500 ease-out" data-carousel-track>
            {testimonials.map((testimonial, index) => (
              <article
                class="flex-shrink-0 w-full px-4"
                data-testimonial-slide
                data-index={index}
                aria-hidden={index !== 0}
              >
                <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 md:p-10 shadow-lg">
                  {/* Rating */}
                  {showRating && testimonial.rating && (
                    <div class="flex items-center gap-1 mb-6">
                      {[...Array(5)].map((_, i) => (
                        <svg
                          class:list={['w-5 h-5', i < testimonial.rating! ? 'text-yellow-400' : 'text-gray-300']}
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  )}

                  {/* Quote */}
                  <blockquote class="text-xl md:text-2xl text-gray-800 dark:text-gray-200 leading-relaxed mb-8">
                    <svg class="w-10 h-10 text-gray-200 dark:text-gray-700 mb-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                    </svg>
                    "{testimonial.quote}"
                  </blockquote>

                  {/* Author */}
                  <footer class="flex items-center gap-4">
                    {testimonial.avatar ? (
                      <img
                        src={testimonial.avatar}
                        alt={testimonial.author}
                        class="w-14 h-14 rounded-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-xl font-bold">
                        {testimonial.author.charAt(0)}
                      </div>
                    )}
                    <div class="flex-grow">
                      <cite class="not-italic font-semibold text-gray-900 dark:text-white">
                        {testimonial.author}
                      </cite>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {testimonial.role}, {testimonial.company}
                      </p>
                    </div>
                    {testimonial.companyLogo && (
                      <img
                        src={testimonial.companyLogo}
                        alt={testimonial.company}
                        class="h-8 opacity-60"
                        loading="lazy"
                      />
                    )}
                  </footer>
                </div>
              </article>
            ))}
          </div>
        </div>

        {/* Navigation Arrows */}
        <button
          type="button"
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-12 w-12 h-12 rounded-full bg-white dark:bg-gray-800 shadow-lg flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
          aria-label="Previous testimonial"
          data-carousel-prev
        >
          <svg class="w-6 h-6 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <button
          type="button"
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-12 w-12 h-12 rounded-full bg-white dark:bg-gray-800 shadow-lg flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
          aria-label="Next testimonial"
          data-carousel-next
        >
          <svg class="w-6 h-6 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        {/* Dots */}
        <div class="flex items-center justify-center gap-2 mt-8" role="tablist" aria-label="Testimonial navigation">
          {testimonials.map((_, index) => (
            <button
              type="button"
              role="tab"
              aria-selected={index === 0}
              aria-label={`Go to testimonial ${index + 1}`}
              class:list={[
                'w-3 h-3 rounded-full transition-all focus:outline-none focus:ring-2 focus:ring-blue-500',
                index === 0 ? 'bg-blue-500 w-8' : 'bg-gray-300 dark:bg-gray-600 hover:bg-gray-400'
              ]}
              data-carousel-dot={index}
            />
          ))}
        </div>
      </div>
    )}

    {/* Grid Layout */}
    {layout === 'grid' && (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {testimonials.map((testimonial) => (
          <article class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow">
            {/* Rating */}
            {showRating && testimonial.rating && (
              <div class="flex items-center gap-1 mb-4">
                {[...Array(5)].map((_, i) => (
                  <svg
                    class:list={['w-4 h-4', i < testimonial.rating! ? 'text-yellow-400' : 'text-gray-300']}
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            )}

            {/* Quote */}
            <blockquote class="text-gray-700 dark:text-gray-300 mb-6 line-clamp-4">
              "{testimonial.quote}"
            </blockquote>

            {/* Author */}
            <footer class="flex items-center gap-3">
              {testimonial.avatar ? (
                <img
                  src={testimonial.avatar}
                  alt={testimonial.author}
                  class="w-10 h-10 rounded-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white font-bold">
                  {testimonial.author.charAt(0)}
                </div>
              )}
              <div>
                <cite class="not-italic font-medium text-gray-900 dark:text-white text-sm">
                  {testimonial.author}
                </cite>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  {testimonial.role}
                </p>
              </div>
            </footer>
          </article>
        ))}
      </div>
    )}

    {/* Masonry Layout */}
    {layout === 'masonry' && (
      <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
        {testimonials.map((testimonial) => (
          <article class="break-inside-avoid bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow">
            {/* Rating */}
            {showRating && testimonial.rating && (
              <div class="flex items-center gap-1 mb-4">
                {[...Array(5)].map((_, i) => (
                  <svg
                    class:list={['w-4 h-4', i < testimonial.rating! ? 'text-yellow-400' : 'text-gray-300']}
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            )}

            {/* Quote */}
            <blockquote class="text-gray-700 dark:text-gray-300 mb-6">
              "{testimonial.quote}"
            </blockquote>

            {/* Author */}
            <footer class="flex items-center gap-3">
              {testimonial.avatar ? (
                <img
                  src={testimonial.avatar}
                  alt={testimonial.author}
                  class="w-10 h-10 rounded-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white font-bold">
                  {testimonial.author.charAt(0)}
                </div>
              )}
              <div>
                <cite class="not-italic font-medium text-gray-900 dark:text-white text-sm">
                  {testimonial.author}
                </cite>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  {testimonial.role}, {testimonial.company}
                </p>
              </div>
            </footer>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

{/* Schema.org Review markup */}
{showSchema && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": testimonials.map((t, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Review",
        "reviewRating": {
          "@type": "Rating",
          "ratingValue": t.rating || 5,
          "bestRating": 5
        },
        "author": {
          "@type": "Person",
          "name": t.author,
          "jobTitle": t.role,
          "worksFor": {
            "@type": "Organization",
            "name": t.company
          }
        },
        "reviewBody": t.quote
      }
    }))
  })} />
)}

<script>
function initTestimonials() {
  const section = document.querySelector('[data-testimonials-section]');
  if (!section) return;

  const layout = section.getAttribute('data-layout');
  if (layout !== 'carousel') return;

  const carousel = section.querySelector('[data-carousel]');
  if (!carousel) return;

  const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
  const slides = carousel.querySelectorAll('[data-testimonial-slide]');
  const prevBtn = carousel.querySelector('[data-carousel-prev]');
  const nextBtn = carousel.querySelector('[data-carousel-next]');
  const dots = carousel.querySelectorAll('[data-carousel-dot]');

  const autoplay = section.getAttribute('data-autoplay') === 'true';
  const interval = parseInt(section.getAttribute('data-interval') || '5000');

  let currentIndex = 0;
  let autoplayTimer: ReturnType<typeof setInterval> | null = null;

  function goToSlide(index: number) {
    if (index < 0) index = slides.length - 1;
    if (index >= slides.length) index = 0;

    currentIndex = index;

    if (track) {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
    }

    // Update slides aria-hidden
    slides.forEach((slide, i) => {
      slide.setAttribute('aria-hidden', (i !== currentIndex).toString());
    });

    // Update dots
    dots.forEach((dot, i) => {
      dot.setAttribute('aria-selected', (i === currentIndex).toString());
      dot.classList.toggle('bg-blue-500', i === currentIndex);
      dot.classList.toggle('w-8', i === currentIndex);
      dot.classList.toggle('bg-gray-300', i !== currentIndex);
      dot.classList.toggle('dark:bg-gray-600', i !== currentIndex);
      dot.classList.toggle('w-3', i !== currentIndex);
    });
  }

  function startAutoplay() {
    if (!autoplay) return;
    stopAutoplay();
    autoplayTimer = setInterval(() => {
      goToSlide(currentIndex + 1);
    }, interval);
  }

  function stopAutoplay() {
    if (autoplayTimer) {
      clearInterval(autoplayTimer);
      autoplayTimer = null;
    }
  }

  // Event listeners
  prevBtn?.addEventListener('click', () => {
    stopAutoplay();
    goToSlide(currentIndex - 1);
    startAutoplay();
  });

  nextBtn?.addEventListener('click', () => {
    stopAutoplay();
    goToSlide(currentIndex + 1);
    startAutoplay();
  });

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      stopAutoplay();
      goToSlide(index);
      startAutoplay();
    });
  });

  // Keyboard navigation
  carousel.addEventListener('keydown', (e: Event) => {
    const keyEvent = e as KeyboardEvent;
    if (keyEvent.key === 'ArrowLeft') {
      stopAutoplay();
      goToSlide(currentIndex - 1);
      startAutoplay();
    } else if (keyEvent.key === 'ArrowRight') {
      stopAutoplay();
      goToSlide(currentIndex + 1);
      startAutoplay();
    }
  });

  // Pause autoplay on hover
  carousel.addEventListener('mouseenter', stopAutoplay);
  carousel.addEventListener('mouseleave', startAutoplay);

  // Touch support
  let touchStartX = 0;
  let touchEndX = 0;

  carousel.addEventListener('touchstart', (e: Event) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
  }, { passive: true });

  carousel.addEventListener('touchend', (e: Event) => {
    touchEndX = (e as TouchEvent).changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      stopAutoplay();
      if (diff > 0) {
        goToSlide(currentIndex + 1);
      } else {
        goToSlide(currentIndex - 1);
      }
      startAutoplay();
    }
  }, { passive: true });

  // Initialize
  goToSlide(0);
  startAutoplay();
}

// Initialize
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initTestimonials);
} else {
  initTestimonials();
}

// View Transitions support
document.addEventListener('astro:page-load', initTestimonials);
</script>

<style>
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    [data-carousel-track] {
      transition: none;
    }
  }
</style>
