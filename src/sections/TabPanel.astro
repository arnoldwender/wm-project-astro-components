---
/**
 * TabPanel Component - WenderMedia Astro Components
 *
 * Individual tab panel content wrapper.
 *
 * Features:
 * - Semantic tabpanel role with proper aria-labelledby linking
 * - Controlled visibility via TabsSection parent component
 * - Keyboard focusable with tabindex for accessibility compliance
 * - Accepts any slotted content (text, components, forms, media)
 *
 * @example
 * <TabPanel id="features">
 *   <h3>Platform Features</h3>
 *   <p>Real-time analytics, team collaboration, and automated reports.</p>
 * </TabPanel>
 *
 * @example
 * <TabPanel id="pricing" class="p-8">
 *   <PricingTable tiers={pricingTiers} />
 * </TabPanel>
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  id: string;
  class?: string;
}

const {
  id,
  class: className = '',
} = Astro.props;
---

<div
  id={`panel-${id}`}
  role="tabpanel"
  aria-labelledby={`tab-${id}`}
  data-tab-panel={id}
  class:list={['tab-panel', className]}
  tabindex="0"
>
  <slot />
</div>
