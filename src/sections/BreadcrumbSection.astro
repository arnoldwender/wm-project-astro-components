---
/**
 * BreadcrumbSection Component - WenderMedia Astro Components
 *
 * Navigation breadcrumbs for page hierarchy.
 *
 * Features:
 * - Six separator styles: default chevron, arrows, pills, dots, slash, chevron
 * - Schema.org BreadcrumbList structured data for SEO
 * - Automatic truncation with ellipsis when maxItems is set
 * - Home icon on first item (toggleable)
 * - Responsive font sizing for mobile
 *
 * Variants:
 * - default: Standard breadcrumb with separators
 * - arrows: Arrow-style separators
 * - pills: Pill/badge style items
 * - dots: Dot separators
 * - slash: Slash separators
 * - chevron: Chevron separators
 *
 * @example
 * <BreadcrumbSection
 *   variant="default"
 *   items={[
 *     { label: 'Home', href: '/' },
 *     { label: 'Products', href: '/products' },
 *     { label: 'Acme Widget Pro' }
 *   ]}
 * />
 *
 * @example
 * <BreadcrumbSection
 *   variant="pills"
 *   homeIcon={true}
 *   maxItems={4}
 *   items={[
 *     { label: 'Home', href: '/' },
 *     { label: 'Shop', href: '/shop' },
 *     { label: 'Electronics', href: '/shop/electronics' },
 *     { label: 'Laptops', href: '/shop/electronics/laptops' },
 *     { label: 'Acme Notebook 15' }
 *   ]}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface BreadcrumbItem {
  label: string;
  href?: string;
  icon?: string;
}

export interface Props {
  variant?: 'default' | 'arrows' | 'pills' | 'dots' | 'slash' | 'chevron';
  items: BreadcrumbItem[];
  homeIcon?: boolean;
  showCurrent?: boolean;
  maxItems?: number;
  class?: string;
}

const {
  variant = 'default',
  items,
  homeIcon = true,
  showCurrent = true,
  maxItems = 0,
  class: className = '',
} = Astro.props;

// Handle truncation
let displayItems = [...items];
let truncated = false;

if (maxItems > 0 && items.length > maxItems) {
  const firstItem = items[0];
  const lastItems = items.slice(-maxItems + 1);
  displayItems = [firstItem, { label: '...', href: undefined }, ...lastItems];
  truncated = true;
}

const homeIconSvg = `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`;

const separators = {
  default: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>`,
  arrows: `<svg fill="currentColor" viewBox="0 0 20 20" width="20" height="20"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>`,
  pills: '',
  dots: '•',
  slash: '/',
  chevron: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>`,
};
---

<nav
  class:list={[
    'breadcrumb',
    `breadcrumb--${variant}`,
    className,
  ]}
  aria-label="Breadcrumb"
>
  <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
    {displayItems.map((item, index) => {
      const isLast = index === displayItems.length - 1;
      const isFirst = index === 0;
      const isEllipsis = item.label === '...';

      return (
        <li
          class:list={[
            'breadcrumb-item',
            isLast && 'breadcrumb-item--current',
            isEllipsis && 'breadcrumb-item--ellipsis',
          ]}
          itemprop="itemListElement"
          itemscope
          itemtype="https://schema.org/ListItem"
        >
          {/* Separator */}
          {index > 0 && variant !== 'pills' && (
            <span class="breadcrumb-separator" aria-hidden="true">
              {typeof separators[variant] === 'string' && separators[variant].startsWith('<')
                ? <span set:html={separators[variant]} />
                : separators[variant]
              }
            </span>
          )}

          {/* Item */}
          {isEllipsis ? (
            <span class="breadcrumb-ellipsis">...</span>
          ) : item.href && (!isLast || !showCurrent) ? (
            <a
              href={item.href}
              class="breadcrumb-link"
              itemprop="item"
            >
              {isFirst && homeIcon && !item.icon ? (
                <span class="breadcrumb-icon" set:html={homeIconSvg} />
              ) : item.icon ? (
                <span class="breadcrumb-icon" set:html={item.icon} />
              ) : null}
              <span itemprop="name">{item.label}</span>
            </a>
          ) : (
            <span
              class="breadcrumb-current"
              aria-current={isLast ? 'page' : undefined}
              itemprop="name"
            >
              {item.icon && <span class="breadcrumb-icon" set:html={item.icon} />}
              {item.label}
            </span>
          )}

          <meta itemprop="position" content={String(index + 1)} />
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumb {
    font-size: 0.875rem;
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb-separator {
    color: var(--color-text-tertiary);
    display: flex;
    align-items: center;
  }

  .breadcrumb-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-link:hover {
    color: var(--color-primary);
  }

  .breadcrumb-current {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .breadcrumb-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .breadcrumb-ellipsis {
    color: var(--color-text-tertiary);
    padding: 0 0.25rem;
  }

  /* Arrows variant */
  .breadcrumb--arrows .breadcrumb-list {
    gap: 0;
  }

  .breadcrumb--arrows .breadcrumb-item {
    gap: 0;
  }

  .breadcrumb--arrows .breadcrumb-separator {
    color: var(--color-border-subtle);
  }

  .breadcrumb--arrows .breadcrumb-link,
  .breadcrumb--arrows .breadcrumb-current {
    padding: 0.375rem 0.75rem;
    background: var(--color-background-subtle);
    position: relative;
  }

  .breadcrumb--arrows .breadcrumb-item:first-child .breadcrumb-link,
  .breadcrumb--arrows .breadcrumb-item:first-child .breadcrumb-current {
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    padding-left: 1rem;
  }

  .breadcrumb--arrows .breadcrumb-item:last-child .breadcrumb-link,
  .breadcrumb--arrows .breadcrumb-item:last-child .breadcrumb-current {
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding-right: 1rem;
  }

  .breadcrumb--arrows .breadcrumb-item--current .breadcrumb-current {
    background: var(--color-primary);
    color: white;
  }

  /* Pills variant */
  .breadcrumb--pills .breadcrumb-list {
    gap: 0.5rem;
  }

  .breadcrumb--pills .breadcrumb-link,
  .breadcrumb--pills .breadcrumb-current {
    padding: 0.375rem 0.75rem;
    background: var(--color-background-subtle);
    border-radius: var(--radius-full);
  }

  .breadcrumb--pills .breadcrumb-link:hover {
    background: var(--color-background-muted);
  }

  .breadcrumb--pills .breadcrumb-item--current .breadcrumb-current {
    background: var(--color-primary);
    color: white;
  }

  /* Dots variant */
  .breadcrumb--dots .breadcrumb-separator {
    font-size: 0.75rem;
  }

  /* Slash variant */
  .breadcrumb--slash .breadcrumb-separator {
    font-size: 1rem;
  }

  /* Chevron variant */
  .breadcrumb--chevron .breadcrumb-separator {
    opacity: 0.5;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .breadcrumb {
      font-size: 0.75rem;
    }

    .breadcrumb-list {
      gap: 0.25rem;
    }

    .breadcrumb-item {
      gap: 0.25rem;
    }

    .breadcrumb--pills .breadcrumb-link,
    .breadcrumb--pills .breadcrumb-current {
      padding: 0.25rem 0.5rem;
    }

    .breadcrumb--arrows .breadcrumb-link,
    .breadcrumb--arrows .breadcrumb-current {
      padding: 0.25rem 0.5rem;
    }
  }
</style>
