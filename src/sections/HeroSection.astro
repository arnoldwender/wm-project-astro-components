---
/**
 * HeroSection Component - WenderMedia Astro Components
 *
 * The main above-the-fold section for landing pages, home pages, and key entry points.
 * Supports six layout variants so you can match the visual style to your content: a
 * classic centered headline, a side-by-side split with media, a full background
 * image/video, a decorative gradient, a minimal text-only layout, or a product
 * showcase with a subtle 3D hover effect.
 *
 * Features:
 * - Eight variants: centered, split, background, gradient, minimal, product, feature-grid, split-visual
 * - Four size presets controlling minimum height (sm/md/lg/full-screen)
 * - Background image or video support with configurable dark overlay
 * - Decorative gradient blobs for the "gradient" variant
 * - 3D hover effect on media in the "product" variant (respects prefers-reduced-motion)
 * - "split" variant supports reversed column order via the reverse prop
 * - Fully slot-based content for maximum flexibility
 *
 * Named slots:
 * - "eyebrow"     — Small uppercase label above the title (e.g., "New Release")
 * - "title"       — The main <h1> headline (required for all variants)
 * - "description" — Supporting paragraph below the title
 * - "cta"         — Call-to-action buttons or links
 * - "media"       — Image, video, or illustration (used by centered, split, product, gradient)
 * - "extra"       — Additional content below the CTA (only in the "split" variant)
 * - "features"    — Feature icons/cards grid (used by "feature-grid" variant)
 * - "benefits"    — Benefits list items (used by "split-visual" variant)
 *
 * @example
 * ---
 * import HeroSection from '../sections/HeroSection.astro';
 * import Button from '../atoms/Button.astro';
 * ---
 * <!-- Centered hero (default) -->
 * <HeroSection variant="centered" size="lg">
 *   <Fragment slot="eyebrow">Trusted by 5,000+ Teams</Fragment>
 *   <Fragment slot="title">Build Faster, Ship Sooner</Fragment>
 *   <Fragment slot="description">The modern platform for web development.</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/signup">Get Started Free</Button>
 *     <Button href="/demo" variant="outline">Watch Demo</Button>
 *   </Fragment>
 * </HeroSection>
 *
 * @example
 * <!-- Split hero with image on the right -->
 * <HeroSection variant="split">
 *   <Fragment slot="title">Design Without Limits</Fragment>
 *   <Fragment slot="description">Drag, drop, and publish in minutes.</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/try">Try It Now</Button>
 *   </Fragment>
 *   <Fragment slot="media">
 *     <img src="/images/dashboard.png" alt="Dashboard screenshot" />
 *   </Fragment>
 * </HeroSection>
 *
 * @example
 * <!-- Split hero with reversed columns (media left, text right) -->
 * <HeroSection variant="split" reverse>
 *   <Fragment slot="title">Your Data, Visualized</Fragment>
 *   <Fragment slot="media">
 *     <img src="/images/chart.png" alt="Analytics chart" />
 *   </Fragment>
 * </HeroSection>
 *
 * @example
 * <!-- Full background image with dark overlay -->
 * <HeroSection
 *   variant="background"
 *   backgroundImage="/images/hero-bg.jpg"
 *   overlay={true}
 *   overlayOpacity={60}
 *   size="full"
 * >
 *   <Fragment slot="title">Welcome to Acme Corp</Fragment>
 *   <Fragment slot="description">Innovation that moves you forward.</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/contact">Get in Touch</Button>
 *   </Fragment>
 * </HeroSection>
 *
 * @example
 * <!-- Product showcase with 3D hover effect -->
 * <HeroSection variant="product">
 *   <Fragment slot="eyebrow">Introducing AppKit</Fragment>
 *   <Fragment slot="title">The Toolkit You Deserve</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/download">Download Now</Button>
 *   </Fragment>
 *   <Fragment slot="media">
 *     <img src="/images/product-hero.png" alt="AppKit product screenshot" />
 *   </Fragment>
 * </HeroSection>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

import SectionWrapper from './SectionWrapper.astro';

export interface Props {
  variant?: 'centered' | 'split' | 'background' | 'gradient' | 'minimal' | 'product' | 'feature-grid' | 'split-visual';
  size?: 'sm' | 'md' | 'lg' | 'full';
  backgroundImage?: string;
  backgroundVideo?: string;
  overlay?: boolean;
  overlayOpacity?: number;
  reverse?: boolean;
  class?: string;
}

const {
  variant = 'centered',
  size = 'lg',
  backgroundImage,
  backgroundVideo,
  overlay = true,
  overlayOpacity = 50,
  reverse = false,
  class: className = '',
} = Astro.props;

// Size classes
const sizeClasses = {
  sm: 'min-h-[50vh]',
  md: 'min-h-[70vh]',
  lg: 'min-h-[85vh]',
  full: 'min-h-screen',
};
---

<SectionWrapper
  background={variant === 'gradient' ? 'gradient' : 'transparent'}
  padding="none"
  container="none"
  class={className}
>
  <div
    class:list={[
      'hero-section relative flex items-center',
      sizeClasses[size],
      variant === 'background' && 'bg-cover bg-center bg-no-repeat',
    ]}
    style={backgroundImage && variant === 'background' ? `background-image: url('${backgroundImage}')` : undefined}
  >
    {/* Background Video */}
    {backgroundVideo && variant === 'background' && (
      <video
        class="absolute inset-0 w-full h-full object-cover"
        src={backgroundVideo}
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      />
    )}

    {/* Overlay */}
    {overlay && variant === 'background' && (
      <div
        class="absolute inset-0 bg-black"
        style={`opacity: ${overlayOpacity / 100}`}
        aria-hidden="true"
      />
    )}

    {/* Gradient decorations */}
    {variant === 'gradient' && (
      <>
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-3xl" aria-hidden="true" />
        <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/20 rounded-full blur-3xl" aria-hidden="true" />
      </>
    )}

    {/* Content Container */}
    <div class="relative z-10 w-full px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="max-w-7xl mx-auto">

        {/* Centered Variant */}
        {variant === 'centered' && (
          <div class="text-center max-w-4xl mx-auto">
            {Astro.slots.has('eyebrow') && (
              <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                <slot name="eyebrow" />
              </div>
            )}
            <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-text-primary mb-6 leading-tight">
              <slot name="title" />
            </h1>
            {Astro.slots.has('description') && (
              <p class="hero-description text-lg sm:text-xl lg:text-2xl text-text-secondary mb-8 max-w-2xl mx-auto">
                <slot name="description" />
              </p>
            )}
            {Astro.slots.has('cta') && (
              <div class="hero-cta flex flex-wrap justify-center gap-4">
                <slot name="cta" />
              </div>
            )}
            {Astro.slots.has('media') && (
              <div class="hero-media mt-12 lg:mt-16">
                <slot name="media" />
              </div>
            )}
          </div>
        )}

        {/* Split Variant */}
        {variant === 'split' && (
          <div class:list={[
            'grid lg:grid-cols-2 gap-12 lg:gap-16 items-center',
            reverse && 'lg:[&>*:first-child]:order-2',
          ]}>
            <div class="hero-content">
              {Astro.slots.has('eyebrow') && (
                <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                  <slot name="eyebrow" />
                </div>
              )}
              <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary mb-6 leading-tight">
                <slot name="title" />
              </h1>
              {Astro.slots.has('description') && (
                <p class="hero-description text-lg lg:text-xl text-text-secondary mb-8">
                  <slot name="description" />
                </p>
              )}
              {Astro.slots.has('cta') && (
                <div class="hero-cta flex flex-wrap gap-4">
                  <slot name="cta" />
                </div>
              )}
              {Astro.slots.has('extra') && (
                <div class="hero-extra mt-8">
                  <slot name="extra" />
                </div>
              )}
            </div>
            <div class="hero-media">
              <slot name="media" />
            </div>
          </div>
        )}

        {/* Background Variant */}
        {variant === 'background' && (
          <div class="text-center max-w-4xl mx-auto text-white">
            {Astro.slots.has('eyebrow') && (
              <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">
                <slot name="eyebrow" />
              </div>
            )}
            <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold mb-6 leading-tight">
              <slot name="title" />
            </h1>
            {Astro.slots.has('description') && (
              <p class="hero-description text-lg sm:text-xl lg:text-2xl text-white/90 mb-8 max-w-2xl mx-auto">
                <slot name="description" />
              </p>
            )}
            {Astro.slots.has('cta') && (
              <div class="hero-cta flex flex-wrap justify-center gap-4">
                <slot name="cta" />
              </div>
            )}
          </div>
        )}

        {/* Minimal Variant */}
        {variant === 'minimal' && (
          <div class="max-w-3xl">
            {Astro.slots.has('eyebrow') && (
              <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                <slot name="eyebrow" />
              </div>
            )}
            <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary mb-6 leading-tight">
              <slot name="title" />
            </h1>
            {Astro.slots.has('description') && (
              <p class="hero-description text-lg lg:text-xl text-text-secondary mb-8">
                <slot name="description" />
              </p>
            )}
            {Astro.slots.has('cta') && (
              <div class="hero-cta flex flex-wrap gap-4">
                <slot name="cta" />
              </div>
            )}
          </div>
        )}

        {/* Product Variant */}
        {variant === 'product' && (
          <div class="text-center">
            {Astro.slots.has('eyebrow') && (
              <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                <slot name="eyebrow" />
              </div>
            )}
            <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary mb-6 leading-tight max-w-4xl mx-auto">
              <slot name="title" />
            </h1>
            {Astro.slots.has('description') && (
              <p class="hero-description text-lg lg:text-xl text-text-secondary mb-8 max-w-2xl mx-auto">
                <slot name="description" />
              </p>
            )}
            {Astro.slots.has('cta') && (
              <div class="hero-cta flex flex-wrap justify-center gap-4 mb-12">
                <slot name="cta" />
              </div>
            )}
            {Astro.slots.has('media') && (
              <div class="hero-media relative perspective-1000">
                <div class="hero-product-showcase transform-gpu hover:scale-105 transition-transform duration-500">
                  <slot name="media" />
                </div>
                {/* Reflection effect */}
                <div class="absolute inset-x-0 -bottom-20 h-20 bg-gradient-to-t from-background to-transparent" aria-hidden="true" />
              </div>
            )}
          </div>
        )}

        {/* Gradient Variant (same as centered but with gradient bg handled above) */}
        {variant === 'gradient' && (
          <div class="text-center max-w-4xl mx-auto relative">
            {Astro.slots.has('eyebrow') && (
              <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                <slot name="eyebrow" />
              </div>
            )}
            <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-text-primary mb-6 leading-tight">
              <slot name="title" />
            </h1>
            {Astro.slots.has('description') && (
              <p class="hero-description text-lg sm:text-xl lg:text-2xl text-text-secondary mb-8 max-w-2xl mx-auto">
                <slot name="description" />
              </p>
            )}
            {Astro.slots.has('cta') && (
              <div class="hero-cta flex flex-wrap justify-center gap-4">
                <slot name="cta" />
              </div>
            )}
            {Astro.slots.has('media') && (
              <div class="hero-media mt-12 lg:mt-16">
                <slot name="media" />
              </div>
            )}
          </div>
        )}

        {/* Feature Grid Variant — centered headline with feature icons grid below the CTA */}
        {variant === 'feature-grid' && (
          <div class="text-center max-w-5xl mx-auto">
            {Astro.slots.has('eyebrow') && (
              <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                <slot name="eyebrow" />
              </div>
            )}
            <h1 class="hero-title text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-text-primary mb-6 leading-tight">
              <slot name="title" />
            </h1>
            {Astro.slots.has('description') && (
              <p class="hero-description text-lg sm:text-xl lg:text-2xl text-text-secondary mb-8 max-w-2xl mx-auto">
                <slot name="description" />
              </p>
            )}
            {Astro.slots.has('cta') && (
              <div class="hero-cta flex flex-wrap justify-center gap-4 mb-12 lg:mb-16">
                <slot name="cta" />
              </div>
            )}
            {/* Feature icons grid — expects 3-4 items via the "features" slot */}
            {Astro.slots.has('features') && (
              <div class="hero-features grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8 pt-8 border-t border-border-subtle">
                <slot name="features" />
              </div>
            )}
          </div>
        )}

        {/* Split Visual Variant — 50/50 content left, large visual right with benefits list */}
        {variant === 'split-visual' && (
          <div class:list={[
            'grid lg:grid-cols-2 gap-12 lg:gap-16 items-center',
            reverse && 'lg:[&>*:first-child]:order-2',
          ]}>
            <div class="hero-content">
              {Astro.slots.has('eyebrow') && (
                <div class="hero-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
                  <slot name="eyebrow" />
                </div>
              )}
              <h1 class="hero-title text-4xl sm:text-5xl lg:text-5xl font-bold text-text-primary mb-6 leading-tight">
                <slot name="title" />
              </h1>
              {Astro.slots.has('description') && (
                <p class="hero-description text-lg lg:text-xl text-text-secondary mb-6">
                  <slot name="description" />
                </p>
              )}
              {/* Benefits list — expects list items via the "benefits" slot */}
              {Astro.slots.has('benefits') && (
                <ul class="hero-benefits space-y-3 mb-8 text-text-secondary">
                  <slot name="benefits" />
                </ul>
              )}
              {Astro.slots.has('cta') && (
                <div class="hero-cta flex flex-wrap gap-4">
                  <slot name="cta" />
                </div>
              )}
            </div>
            <div class="hero-media relative">
              {Astro.slots.has('media') && (
                <div class="hero-split-visual-media rounded-2xl overflow-hidden shadow-2xl">
                  <slot name="media" />
                </div>
              )}
            </div>
          </div>
        )}

      </div>
    </div>
  </div>
</SectionWrapper>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }

  /* Hero media styling */
  .hero-media :global(img),
  .hero-media :global(video) {
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-2xl);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-product-showcase {
      transition: none;
    }

    .hero-product-showcase:hover {
      transform: none;
    }
  }
</style>
