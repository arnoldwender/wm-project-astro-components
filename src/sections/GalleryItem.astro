---
/**
 * GalleryItem Component - WenderMedia Astro Components
 *
 * Individual gallery/portfolio item with lightbox support.
 *
 * @example
 * <GalleryItem
 *   image="/portfolio/project1.jpg"
 *   title="Project Name"
 *   category="Web Design"
 *   href="/projects/project1"
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  image: string;
  title?: string;
  category?: string;
  description?: string;
  href?: string;
  lightbox?: boolean;
  aspectRatio?: 'square' | 'landscape' | 'portrait' | 'auto';
  variant?: 'default' | 'overlay' | 'card' | 'minimal';
  class?: string;
}

const {
  image,
  title,
  category,
  description,
  href,
  lightbox = false,
  aspectRatio = 'square',
  variant = 'default',
  class: className = '',
} = Astro.props;

const aspectClasses = {
  square: 'aspect-square',
  landscape: 'aspect-video',
  portrait: 'aspect-[3/4]',
  auto: '',
};

const Tag = href ? 'a' : lightbox ? 'button' : 'div';
---

<Tag
  href={href}
  type={lightbox && !href ? 'button' : undefined}
  class:list={[
    'gallery-item group block relative overflow-hidden',
    variant === 'card' && 'bg-surface border border-border-subtle rounded-xl',
    variant !== 'card' && 'rounded-xl',
    (href || lightbox) && 'cursor-pointer',
    className,
  ]}
  data-gallery-item
  data-lightbox-src={lightbox ? image : undefined}
  data-lightbox-title={lightbox ? title : undefined}
>
  {/* Image */}
  <div class:list={[
    'gallery-image overflow-hidden',
    variant === 'card' ? 'rounded-t-xl' : 'rounded-xl',
    aspectClasses[aspectRatio],
  ]}>
    <img
      src={image}
      alt={title || 'Gallery image'}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
    />

    {/* Overlay for default and overlay variants */}
    {(variant === 'default' || variant === 'overlay') && (
      <div class:list={[
        'absolute inset-0 transition-opacity duration-300',
        variant === 'overlay'
          ? 'bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-100'
          : 'bg-black/0 group-hover:bg-black/60',
      ]}>
        {/* Content on hover/overlay */}
        <div class:list={[
          'absolute inset-0 flex flex-col justify-end p-4 lg:p-6',
          variant === 'default' && 'opacity-0 group-hover:opacity-100 transition-opacity duration-300',
        ]}>
          {category && (
            <span class="text-xs font-medium text-white/80 uppercase tracking-wider mb-1">
              {category}
            </span>
          )}
          {title && (
            <h3 class="text-lg font-semibold text-white">{title}</h3>
          )}
          {description && variant === 'overlay' && (
            <p class="text-sm text-white/70 mt-1 line-clamp-2">{description}</p>
          )}
        </div>

        {/* Lightbox/Link icon */}
        {(href || lightbox) && variant === 'default' && (
          <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <span class="w-10 h-10 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-white">
              {lightbox ? (
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
              ) : (
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              )}
            </span>
          </div>
        )}
      </div>
    )}
  </div>

  {/* Card variant content */}
  {variant === 'card' && (title || category || description) && (
    <div class="p-4">
      {category && (
        <span class="text-xs font-medium text-primary uppercase tracking-wider">
          {category}
        </span>
      )}
      {title && (
        <h3 class="font-semibold text-text-primary mt-1 group-hover:text-primary transition-colors">
          {title}
        </h3>
      )}
      {description && (
        <p class="text-sm text-text-secondary mt-1 line-clamp-2">{description}</p>
      )}
    </div>
  )}

  {/* Minimal variant - title below */}
  {variant === 'minimal' && title && (
    <div class="mt-3">
      {category && (
        <span class="text-xs font-medium text-text-tertiary uppercase tracking-wider">
          {category}
        </span>
      )}
      <h3 class="font-medium text-text-primary group-hover:text-primary transition-colors">
        {title}
      </h3>
    </div>
  )}
</Tag>

<style>
  @media (prefers-reduced-motion: reduce) {
    .gallery-item img {
      transition: none;
    }

    .gallery-item:hover img {
      transform: none;
    }
  }
</style>
