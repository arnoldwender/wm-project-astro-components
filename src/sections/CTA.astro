---
/**
 * Premium CTA (Call-to-Action) Section Component - WenderMedia Astro Components
 *
 * High-converting CTA section with:
 * - Psychology-based design patterns
 * - Urgency/scarcity elements
 * - Social proof integration
 * - Multiple layout variants
 * - A/B testing support
 * - Accessibility compliant
 *
 * Features:
 * - Five layout variants: centered, split, banner, floating, gradient
 * - Urgency elements with pulsing indicator and countdown timer
 * - Social proof: user count, star rating, review count
 * - Trust logos and testimonial quote integration
 * - Sticky and scroll-triggered floating CTA behavior
 *
 * Conversion optimizations based on 2025 research:
 * - Personalized CTAs: 202% better conversion
 * - Urgency elements: up to 332% lift
 * - Specific CTAs: 161% improvement
 * - Button-based CTAs: 30% higher CTR
 *
 * @example
 * <CTA
 *   variant="centered"
 *   title="Start your free trial today"
 *   description="Join 10,000+ teams already using Acme Platform."
 *   ctaText="Get Started Free"
 *   ctaHref="/signup"
 *   secondaryText="Book a demo"
 *   secondaryHref="/demo"
 *   usersCount={10000}
 *   rating={4.8}
 *   reviewsCount={2500}
 * />
 *
 * @example
 * <CTA
 *   variant="split"
 *   title="Ready to transform your workflow?"
 *   subtitle="Limited Offer"
 *   ctaText="Claim your discount"
 *   ctaHref="/pricing"
 *   image="/images/dashboard-preview.jpg"
 *   imageAlt="Acme Corp dashboard"
 *   testimonialQuote="Acme Platform saved us 20 hours per week."
 *   testimonialAuthor="Jane Doe, CTO at WidgetCo"
 *   urgencyText="Only 5 spots left this month"
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  // Content
  title: string;
  subtitle?: string;
  description?: string;

  // Primary CTA
  ctaText: string;
  ctaHref: string;

  // Secondary CTA (optional)
  secondaryText?: string;
  secondaryHref?: string;

  // Layout variants
  variant?: 'centered' | 'split' | 'banner' | 'floating' | 'gradient';

  // Visual elements
  image?: string;
  imageAlt?: string;
  bgColor?: string;
  textColor?: 'light' | 'dark';

  // Trust elements
  trustText?: string;
  trustLogos?: Array<{ src: string; alt: string }>;
  testimonialQuote?: string;
  testimonialAuthor?: string;

  // Urgency elements
  urgencyText?: string;
  countdown?: {
    endDate: string;
    label: string;
  };

  // Social proof
  usersCount?: number;
  rating?: number;
  reviewsCount?: number;

  // Behavior
  sticky?: boolean;
  showOnScroll?: number;
  class?: string;
}

const {
  title,
  subtitle,
  description,
  ctaText,
  ctaHref,
  secondaryText,
  secondaryHref,
  variant = 'centered',
  image,
  imageAlt,
  bgColor = 'bg-gradient-to-r from-blue-600 to-purple-600',
  textColor = 'light',
  trustText,
  trustLogos = [],
  testimonialQuote,
  testimonialAuthor,
  urgencyText,
  countdown,
  usersCount,
  rating,
  reviewsCount,
  sticky = false,
  showOnScroll,
  class: className = '',
} = Astro.props;

const textClasses = textColor === 'light'
  ? 'text-white'
  : 'text-gray-900';

const subtitleClasses = textColor === 'light'
  ? 'text-white/80'
  : 'text-gray-600';

const buttonPrimaryClasses = textColor === 'light'
  ? 'bg-white text-gray-900 hover:bg-gray-100'
  : 'bg-gray-900 text-white hover:bg-gray-800';

const buttonSecondaryClasses = textColor === 'light'
  ? 'border-white text-white hover:bg-white hover:text-gray-900'
  : 'border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white';
---

<section
  class:list={[
    'cta-section',
    sticky && 'sticky-cta',
    className
  ]}
  data-cta-section
  data-sticky={sticky}
  data-show-on-scroll={showOnScroll}
>
  {/* Centered Layout */}
  {variant === 'centered' && (
    <div class:list={['py-16 md:py-24 lg:py-32', bgColor]}>
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          {/* Urgency Banner */}
          {urgencyText && (
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-red-500/20 rounded-full mb-6 animate-pulse">
              <span class="w-2 h-2 bg-red-500 rounded-full" />
              <span class={`text-sm font-medium ${textClasses}`}>{urgencyText}</span>
            </div>
          )}

          {/* Countdown Timer */}
          {countdown && (
            <div class="flex items-center justify-center gap-4 mb-8" data-countdown={countdown.endDate}>
              <div class="text-center">
                <div class={`text-3xl md:text-4xl font-bold ${textClasses}`} data-countdown-days>00</div>
                <div class={`text-xs uppercase ${subtitleClasses}`}>Days</div>
              </div>
              <span class={`text-2xl font-bold ${subtitleClasses}`}>:</span>
              <div class="text-center">
                <div class={`text-3xl md:text-4xl font-bold ${textClasses}`} data-countdown-hours>00</div>
                <div class={`text-xs uppercase ${subtitleClasses}`}>Hours</div>
              </div>
              <span class={`text-2xl font-bold ${subtitleClasses}`}>:</span>
              <div class="text-center">
                <div class={`text-3xl md:text-4xl font-bold ${textClasses}`} data-countdown-minutes>00</div>
                <div class={`text-xs uppercase ${subtitleClasses}`}>Min</div>
              </div>
              <span class={`text-2xl font-bold ${subtitleClasses}`}>:</span>
              <div class="text-center">
                <div class={`text-3xl md:text-4xl font-bold ${textClasses}`} data-countdown-seconds>00</div>
                <div class={`text-xs uppercase ${subtitleClasses}`}>Sec</div>
              </div>
            </div>
          )}

          {subtitle && (
            <p class={`text-sm uppercase tracking-wider mb-4 ${subtitleClasses}`}>
              {subtitle}
            </p>
          )}

          <h2 class={`text-3xl md:text-4xl lg:text-5xl font-bold mb-6 ${textClasses}`}>
            {title}
          </h2>

          {description && (
            <p class={`text-lg md:text-xl mb-8 max-w-2xl mx-auto ${subtitleClasses}`}>
              {description}
            </p>
          )}

          {/* CTA Buttons */}
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
            <a
              href={ctaHref}
              class={`inline-flex items-center gap-2 px-8 py-4 rounded-lg font-semibold text-lg transition-all transform hover:scale-105 shadow-lg ${buttonPrimaryClasses}`}
            >
              {ctaText}
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>

            {secondaryText && secondaryHref && (
              <a
                href={secondaryHref}
                class={`inline-flex items-center gap-2 px-8 py-4 border-2 rounded-lg font-semibold transition-all ${buttonSecondaryClasses}`}
              >
                {secondaryText}
              </a>
            )}
          </div>

          {/* Social Proof */}
          {(usersCount || rating) && (
            <div class="flex items-center justify-center gap-6 mb-8">
              {usersCount && (
                <div class={`text-sm ${subtitleClasses}`}>
                  <span class={`font-bold ${textClasses}`}>{usersCount.toLocaleString()}+</span> users
                </div>
              )}
              {rating && (
                <div class="flex items-center gap-1">
                  {[...Array(5)].map((_, i) => (
                    <svg
                      class:list={['w-4 h-4', i < Math.floor(rating) ? 'text-yellow-400' : `${subtitleClasses}`]}
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                  <span class={`ml-1 text-sm ${subtitleClasses}`}>
                    {rating.toFixed(1)} ({reviewsCount?.toLocaleString()} reviews)
                  </span>
                </div>
              )}
            </div>
          )}

          {/* Trust Elements */}
          {trustText && (
            <p class={`text-sm ${subtitleClasses}`}>{trustText}</p>
          )}

          {trustLogos.length > 0 && (
            <div class="flex items-center justify-center gap-8 mt-6">
              {trustLogos.map((logo) => (
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-6 opacity-60 hover:opacity-100 transition-opacity"
                  loading="lazy"
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  {/* Split Layout */}
  {variant === 'split' && (
    <div class={`py-16 md:py-24 ${bgColor}`}>
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            {subtitle && (
              <p class={`text-sm uppercase tracking-wider mb-4 ${subtitleClasses}`}>
                {subtitle}
              </p>
            )}

            <h2 class={`text-3xl md:text-4xl lg:text-5xl font-bold mb-6 ${textClasses}`}>
              {title}
            </h2>

            {description && (
              <p class={`text-lg mb-8 ${subtitleClasses}`}>
                {description}
              </p>
            )}

            {/* Testimonial */}
            {testimonialQuote && (
              <blockquote class="mb-8 pl-4 border-l-2 border-current">
                <p class={`italic mb-2 ${subtitleClasses}`}>"{testimonialQuote}"</p>
                {testimonialAuthor && (
                  <cite class={`text-sm not-italic ${textClasses}`}>— {testimonialAuthor}</cite>
                )}
              </blockquote>
            )}

            {/* CTA Buttons */}
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href={ctaHref}
                class={`inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg font-semibold transition-all transform hover:scale-105 shadow-lg ${buttonPrimaryClasses}`}
              >
                {ctaText}
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>

              {secondaryText && secondaryHref && (
                <a
                  href={secondaryHref}
                  class={`inline-flex items-center justify-center gap-2 px-8 py-4 border-2 rounded-lg font-semibold transition-all ${buttonSecondaryClasses}`}
                >
                  {secondaryText}
                </a>
              )}
            </div>
          </div>

          {image && (
            <div class="relative">
              <img
                src={image}
                alt={imageAlt || ''}
                class="rounded-2xl shadow-2xl"
                loading="lazy"
              />
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  {/* Banner Layout */}
  {variant === 'banner' && (
    <div class={`py-6 ${bgColor}`}>
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            {urgencyText && (
              <span class={`text-sm font-medium ${textClasses}`}>
                <span class="inline-flex w-2 h-2 bg-red-500 rounded-full mr-2 animate-pulse" />
                {urgencyText}
              </span>
            )}
            <h3 class={`text-lg font-semibold ${textClasses}`}>
              {title}
            </h3>
          </div>

          <a
            href={ctaHref}
            class={`inline-flex items-center gap-2 px-6 py-2 rounded-lg font-semibold transition-all ${buttonPrimaryClasses}`}
          >
            {ctaText}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  )}

  {/* Floating CTA */}
  {variant === 'floating' && (
    <div
      class="fixed bottom-6 right-6 z-50 hidden"
      data-floating-cta
    >
      <a
        href={ctaHref}
        class={`inline-flex items-center gap-2 px-6 py-3 rounded-full font-semibold shadow-2xl transition-all transform hover:scale-105 ${bgColor} ${textClasses}`}
      >
        {ctaText}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  )}

  {/* Gradient Card */}
  {variant === 'gradient' && (
    <div class="py-16 md:py-24">
      <div class="container mx-auto px-4">
        <div class={`relative rounded-3xl overflow-hidden ${bgColor} p-8 md:p-12 lg:p-16`}>
          {/* Background Pattern */}
          <div class="absolute inset-0 opacity-10">
            <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1" />
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>
          </div>

          <div class="relative text-center max-w-3xl mx-auto">
            {subtitle && (
              <p class={`text-sm uppercase tracking-wider mb-4 ${subtitleClasses}`}>
                {subtitle}
              </p>
            )}

            <h2 class={`text-3xl md:text-4xl lg:text-5xl font-bold mb-6 ${textClasses}`}>
              {title}
            </h2>

            {description && (
              <p class={`text-lg mb-8 ${subtitleClasses}`}>
                {description}
              </p>
            )}

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <a
                href={ctaHref}
                class={`inline-flex items-center gap-2 px-8 py-4 rounded-lg font-semibold text-lg transition-all transform hover:scale-105 shadow-lg ${buttonPrimaryClasses}`}
              >
                {ctaText}
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>

              {secondaryText && secondaryHref && (
                <a
                  href={secondaryHref}
                  class={`inline-flex items-center gap-2 px-8 py-4 border-2 rounded-lg font-semibold transition-all ${buttonSecondaryClasses}`}
                >
                  {secondaryText}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</section>

<script>
function initCTA() {
  // Countdown timer
  const countdowns = document.querySelectorAll('[data-countdown]');
  countdowns.forEach(countdown => {
    const endDate = new Date(countdown.getAttribute('data-countdown') || '').getTime();

    const daysEl = countdown.querySelector('[data-countdown-days]');
    const hoursEl = countdown.querySelector('[data-countdown-hours]');
    const minutesEl = countdown.querySelector('[data-countdown-minutes]');
    const secondsEl = countdown.querySelector('[data-countdown-seconds]');

    function update() {
      const now = Date.now();
      const diff = Math.max(0, endDate - now);

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      if (daysEl) daysEl.textContent = days.toString().padStart(2, '0');
      if (hoursEl) hoursEl.textContent = hours.toString().padStart(2, '0');
      if (minutesEl) minutesEl.textContent = minutes.toString().padStart(2, '0');
      if (secondsEl) secondsEl.textContent = seconds.toString().padStart(2, '0');
    }

    update();
    setInterval(update, 1000);
  });

  // Floating CTA scroll behavior
  const floatingCTAs = document.querySelectorAll('[data-floating-cta]');
  const ctaSections = document.querySelectorAll('[data-cta-section]');

  ctaSections.forEach(section => {
    const showOnScroll = parseInt(section.getAttribute('data-show-on-scroll') || '0');
    const floatingCTA = section.querySelector('[data-floating-cta]');

    if (showOnScroll && floatingCTA) {
      function checkScroll() {
        const scrollY = window.scrollY;
        if (scrollY > showOnScroll) {
          floatingCTA.classList.remove('hidden');
          floatingCTA.classList.add('animate-slide-up');
        } else {
          floatingCTA.classList.add('hidden');
          floatingCTA.classList.remove('animate-slide-up');
        }
      }

      window.addEventListener('scroll', checkScroll, { passive: true });
      checkScroll();
    }
  });

  // Sticky CTA behavior
  const stickyCTAs = document.querySelectorAll('[data-cta-section][data-sticky="true"]');
  stickyCTAs.forEach(cta => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          (cta as HTMLElement).classList.toggle('is-sticky', !entry.isIntersecting);
        });
      },
      { threshold: 0 }
    );

    const sentinel = document.createElement('div');
    cta.parentNode?.insertBefore(sentinel, cta);
    observer.observe(sentinel);
  });
}

// Initialize
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initCTA);
} else {
  initCTA();
}

// View Transitions support
document.addEventListener('astro:page-load', initCTA);
</script>

<style>
  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-slide-up {
    animation: slide-up 0.3s ease-out forwards;
  }

  .sticky-cta.is-sticky {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    box-shadow: 0 -4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .animate-slide-up {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .animate-pulse {
      animation: none;
    }
  }
</style>
