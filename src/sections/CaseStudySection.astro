<script>
  function initCaseStudySections() {
    // Carousel
    const carousels = document.querySelectorAll('[data-case-carousel]');
    carousels.forEach((carousel) => {
      const track = carousel.querySelector('.carousel-track') as HTMLElement;
      const prevBtn = carousel.querySelector('[data-carousel-prev]');
      const nextBtn = carousel.querySelector('[data-carousel-next]');

      let position = 0;
      const card = track?.querySelector('.case-card') as HTMLElement;
      const cardWidth = card?.offsetWidth || 300;
      const gap = 24;
      const containerWidth = (carousel.querySelector('.carousel-container') as HTMLElement)?.offsetWidth || 0;
      const visibleCards = Math.floor(containerWidth / (cardWidth + gap));
      const totalCards = track?.children.length || 0;
      const maxPosition = Math.max(0, (totalCards - visibleCards) * (cardWidth + gap));

      prevBtn?.addEventListener('click', () => {
        position = Math.max(0, position - (cardWidth + gap));
        if (track) track.style.transform = `translateX(-${position}px)`;
      });

      nextBtn?.addEventListener('click', () => {
        position = Math.min(maxPosition, position + (cardWidth + gap));
        if (track) track.style.transform = `translateX(-${position}px)`;
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCaseStudySections);
  } else {
    initCaseStudySections();
  }

  document.addEventListener('astro:page-load', initCaseStudySections);
</script>
