---
/**
 * TeamSection Component - WenderMedia Astro Components
 *
 * A section for showcasing team members, founders, or staff in six layout variants.
 * Pass TeamMember child components into the default slot; this section handles the
 * grid layout, column count, and optional section header. Use it on About pages,
 * team pages, or anywhere you need to present people.
 *
 * Features:
 * - Six variants: grid, cards (with shadows), horizontal (2-col wide cards), overlay
 *   (image with text overlay), minimal (compact), and featured (highlight one person)
 * - Configurable column count: 2, 3, 4, 5, or 6 columns with responsive breakpoints
 * - Optional SectionHeader with eyebrow, title, and description
 * - "featured" variant provides a separate named "featured" slot for the highlighted
 *   team member, rendered large and centered above the grid
 * - Background options: transparent, subtle, or muted
 *
 * Named slots:
 * - default    — TeamMember children shown in the grid
 * - "featured" — A single highlighted TeamMember (only used in the "featured" variant)
 *
 * Child components:
 * - Use TeamMember inside the default slot for all variants
 * - For the "featured" variant, also provide one TeamMember in slot="featured"
 *
 * @example
 * ---
 * import TeamSection from '../sections/TeamSection.astro';
 * import TeamMember from '../content/TeamMember.astro';
 * ---
 * <!-- Standard 4-column grid -->
 * <TeamSection
 *   variant="grid"
 *   columns={4}
 *   eyebrow="Our Team"
 *   title="Meet the People Behind Acme"
 *   description="A passionate team dedicated to building great products."
 * >
 *   <TeamMember name="Jane Doe" role="CEO" image="/team/jane.jpg" />
 *   <TeamMember name="John Smith" role="CTO" image="/team/john.jpg" />
 *   <TeamMember name="Maria Garcia" role="Head of Design" image="/team/maria.jpg" />
 *   <TeamMember name="Alex Chen" role="Lead Engineer" image="/team/alex.jpg" />
 * </TeamSection>
 *
 * @example
 * <!-- Card-based layout with 3 columns and subtle background -->
 * <TeamSection variant="cards" columns={3} title="Leadership" background="subtle">
 *   <TeamMember name="Jane Doe" role="CEO" image="/team/jane.jpg" />
 *   <TeamMember name="John Smith" role="CTO" image="/team/john.jpg" />
 *   <TeamMember name="Maria Garcia" role="COO" image="/team/maria.jpg" />
 * </TeamSection>
 *
 * @example
 * <!-- Featured variant: one highlighted person + supporting grid -->
 * <TeamSection variant="featured" columns={3} title="Our Founders">
 *   <TeamMember slot="featured" name="Jane Doe" role="CEO & Founder" image="/team/jane.jpg" />
 *   <TeamMember name="John Smith" role="CTO" image="/team/john.jpg" />
 *   <TeamMember name="Maria Garcia" role="COO" image="/team/maria.jpg" />
 *   <TeamMember name="Alex Chen" role="VP Engineering" image="/team/alex.jpg" />
 * </TeamSection>
 *
 * @example
 * <!-- Horizontal wide cards (always 2 columns) -->
 * <TeamSection variant="horizontal" title="Advisory Board">
 *   <TeamMember name="Dr. Sarah Lee" role="Advisor" image="/team/sarah.jpg" />
 *   <TeamMember name="Prof. Tom Baker" role="Advisor" image="/team/tom.jpg" />
 * </TeamSection>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

import SectionWrapper from './SectionWrapper.astro';
import SectionHeader from './SectionHeader.astro';

export interface Props {
  variant?: 'grid' | 'cards' | 'horizontal' | 'overlay' | 'minimal' | 'featured';
  columns?: 2 | 3 | 4 | 5 | 6;
  eyebrow?: string;
  title?: string;
  description?: string;
  background?: 'transparent' | 'subtle' | 'muted';
  class?: string;
}

const {
  variant = 'grid',
  columns = 4,
  eyebrow,
  title,
  description,
  background = 'transparent',
  class: className = '',
} = Astro.props;

// Column classes
const columnClasses = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
  5: 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5',
  6: 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6',
};
---

<SectionWrapper background={background} class={className}>
  {(eyebrow || title || description) && (
    <SectionHeader
      eyebrow={eyebrow}
      title={title || ''}
      description={description}
    />
  )}

  {/* Grid Variant */}
  {variant === 'grid' && (
    <div class:list={['team-grid grid gap-8 lg:gap-12', columnClasses[columns]]}>
      <slot />
    </div>
  )}

  {/* Cards Variant */}
  {variant === 'cards' && (
    <div class:list={['team-cards grid gap-6', columnClasses[columns]]}>
      <slot />
    </div>
  )}

  {/* Horizontal Variant */}
  {variant === 'horizontal' && (
    <div class="team-horizontal grid gap-6 md:grid-cols-2">
      <slot />
    </div>
  )}

  {/* Overlay Variant */}
  {variant === 'overlay' && (
    <div class:list={['team-overlay grid gap-6', columnClasses[columns]]}>
      <slot />
    </div>
  )}

  {/* Minimal Variant */}
  {variant === 'minimal' && (
    <div class:list={['team-minimal grid gap-8', columnClasses[columns > 4 ? columns : 4]]}>
      <slot />
    </div>
  )}

  {/* Featured Variant */}
  {variant === 'featured' && (
    <div class="team-featured">
      <div class="featured-member mb-12">
        <slot name="featured" />
      </div>
      <div class:list={['team-grid grid gap-8', columnClasses[columns]]}>
        <slot />
      </div>
    </div>
  )}
</SectionWrapper>

<style>
  /* Featured variant styling */
  .featured-member :global(> *) {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  .featured-member :global(img) {
    width: 12rem;
    height: 12rem;
  }

  .featured-member :global(h3) {
    font-size: 1.5rem;
  }

  .featured-member :global(p) {
    max-width: 32rem;
  }
</style>
