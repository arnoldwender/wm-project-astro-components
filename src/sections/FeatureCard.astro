---
/**
 * FeatureCard Component - WenderMedia Astro Components
 *
 * Individual feature card for use in FeaturesSection.
 *
 * @example
 * <FeatureCard
 *   icon="⚡"
 *   title="Lightning Fast"
 *   description="Optimized for speed and performance."
 *   href="/features/speed"
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  icon?: string;
  title: string;
  description?: string;
  href?: string;
  variant?: 'default' | 'compact' | 'horizontal' | 'centered';
  iconBackground?: boolean;
  class?: string;
}

const {
  icon,
  title,
  description,
  href,
  variant = 'default',
  iconBackground = true,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'feature-card group',
    variant === 'centered' && 'text-center',
    variant === 'horizontal' && 'flex items-start gap-4',
    href && 'cursor-pointer',
    className,
  ]}
>
  {icon && (
    <div class:list={[
      'feature-icon flex-shrink-0',
      variant === 'centered' && 'mx-auto',
      iconBackground && 'w-12 h-12 rounded-xl flex items-center justify-center bg-primary/10 text-primary mb-4',
      !iconBackground && 'text-3xl mb-3',
    ]}>
      {icon.startsWith('<') ? (
        <Fragment set:html={icon} />
      ) : (
        <span class={iconBackground ? 'text-xl' : ''}>{icon}</span>
      )}
    </div>
  )}

  <div class="feature-content">
    <h3 class:list={[
      'feature-title font-semibold text-text-primary mb-2',
      variant === 'compact' ? 'text-base' : 'text-lg',
      href && 'group-hover:text-primary transition-colors',
    ]}>
      {title}
      {href && (
        <svg class="inline-block w-4 h-4 ml-1 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      )}
    </h3>

    {description && (
      <p class:list={[
        'feature-description text-text-secondary',
        variant === 'compact' ? 'text-sm' : 'text-base',
      ]}>
        {description}
      </p>
    )}

    {Astro.slots.has('default') && (
      <div class="feature-extra mt-3">
        <slot />
      </div>
    )}
  </div>
</Tag>

<style>
  .feature-icon :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>
