---
/**
 * MasonryGrid Component - WenderMedia Astro Components
 *
 * Pinterest-style masonry layout for mixed-height content.
 *
 * Features:
 * - CSS columns-based masonry layout (no JavaScript required)
 * - Configurable column count (2-5) and gap sizes
 * - Responsive breakpoints collapse to 2 columns on tablet, 1 on mobile
 * - Prevents child element splitting with break-inside: avoid
 *
 * @example
 * <MasonryGrid columns={3} gap="md">
 *   <div>Short card content</div>
 *   <div>Taller card with more text for variety</div>
 *   <div>Another card item</div>
 *   <div>Final card in the grid</div>
 * </MasonryGrid>
 *
 * @example
 * <MasonryGrid columns={4} gap="lg" class="portfolio-grid">
 *   <img src="/images/project-1.jpg" alt="Project Alpha" />
 *   <img src="/images/project-2.jpg" alt="Project Beta" />
 * </MasonryGrid>
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  columns?: 2 | 3 | 4 | 5;
  gap?: 'none' | 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const {
  columns = 3,
  gap = 'md',
  class: className = '',
} = Astro.props;

const gapSizes = {
  none: '0',
  sm: '0.5rem',
  md: '1rem',
  lg: '1.5rem',
  xl: '2rem',
};
---

<div
  class:list={['masonry-grid', className]}
  style={`columns: ${columns}; column-gap: ${gapSizes[gap]};`}
>
  <slot />
</div>

<style>
  .masonry-grid {
    column-fill: balance;
  }

  .masonry-grid :global(> *) {
    break-inside: avoid;
    margin-bottom: var(--masonry-gap, 1rem);
  }

  @media (max-width: 768px) {
    .masonry-grid {
      columns: 2 !important;
    }
  }

  @media (max-width: 480px) {
    .masonry-grid {
      columns: 1 !important;
    }
  }
</style>
