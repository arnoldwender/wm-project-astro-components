---
/**
 * JobCard Component - WenderMedia Astro Components
 *
 * Individual job listing card.
 *
 * Features:
 * - Four display variants: default, card, compact, detailed
 * - Employment type labels with German localization
 * - Urgent and new badges for priority listings
 * - Salary range display and skill/requirement tags
 * - Links to full job description page
 *
 * @example
 * <JobCard
 *   title="Senior Frontend Developer"
 *   department="Engineering"
 *   location="Berlin, Germany"
 *   type="full-time"
 *   salary="65,000 - 85,000 EUR"
 *   href="/careers/senior-frontend"
 *   tags={['React', 'TypeScript', 'Astro']}
 *   variant="card"
 * />
 *
 * @example
 * <JobCard
 *   title="UX Designer"
 *   department="Design"
 *   location="Remote"
 *   type="contract"
 *   href="/careers/ux-designer"
 *   urgent={true}
 *   new={true}
 *   description="Join the Acme Corp design team to shape our next-gen product experience."
 *   variant="detailed"
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  title: string;
  department?: string;
  location?: string;
  type?: 'full-time' | 'part-time' | 'contract' | 'remote' | 'hybrid';
  salary?: string;
  description?: string;
  tags?: string[];
  href?: string;
  urgent?: boolean;
  new?: boolean;
  variant?: 'default' | 'card' | 'compact' | 'detailed';
  class?: string;
}

const {
  title,
  department,
  location,
  type,
  salary,
  description,
  tags = [],
  href,
  urgent = false,
  new: isNew = false,
  variant = 'default',
  class: className = '',
} = Astro.props;

const typeLabels: Record<string, string> = {
  'full-time': 'Vollzeit',
  'part-time': 'Teilzeit',
  'contract': 'Freiberuflich',
  'remote': 'Remote',
  'hybrid': 'Hybrid',
};

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'job-card group block',
    variant === 'card' && 'bg-surface border border-border-subtle rounded-xl p-6 hover:border-primary/50 hover:shadow-lg transition-all',
    variant === 'default' && 'py-6 border-b border-border-subtle last:border-b-0 hover:bg-background-subtle/50 -mx-4 px-4 transition-colors',
    variant === 'compact' && 'py-4 border-b border-border-subtle last:border-b-0',
    variant === 'detailed' && 'bg-surface border border-border-subtle rounded-xl overflow-hidden hover:shadow-lg transition-shadow',
    href && 'cursor-pointer',
    className,
  ]}
>
  {/* Detailed variant header */}
  {variant === 'detailed' && (urgent || isNew) && (
    <div class="bg-gradient-to-r from-primary/10 to-transparent px-6 py-2 border-b border-border-subtle">
      {urgent && (
        <span class="inline-flex items-center gap-1 text-xs font-semibold text-red-600">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          Dringend
        </span>
      )}
      {isNew && !urgent && (
        <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zm7-10a1 1 0 01.707.293l.707.707.707-.707A1 1 0 0115.828 3l-.707.707.707.707a1 1 0 01-1.414 1.414L13.707 5.12l-.707.707a1 1 0 01-1.414-1.414l.707-.707-.707-.707A1 1 0 0112 2z" clip-rule="evenodd" />
          </svg>
          Neu
        </span>
      )}
    </div>
  )}

  <div class:list={[variant === 'detailed' && 'p-6']}>
    {/* Main content */}
    <div class:list={[
      variant === 'compact' ? 'flex items-center justify-between gap-4' : 'flex flex-col md:flex-row md:items-start md:justify-between gap-4',
    ]}>
      {/* Left side */}
      <div class="flex-1 min-w-0">
        <div class="flex items-start gap-3">
          {/* Badges for non-detailed variants */}
          {variant !== 'detailed' && (urgent || isNew) && (
            <div class="flex gap-2 flex-shrink-0">
              {urgent && (
                <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-100 text-red-700">
                  Dringend
                </span>
              )}
              {isNew && !urgent && (
                <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-primary/10 text-primary">
                  Neu
                </span>
              )}
            </div>
          )}
        </div>

        {/* Title */}
        <h3 class:list={[
          'font-semibold text-text-primary group-hover:text-primary transition-colors',
          variant === 'compact' ? 'text-base' : 'text-lg',
        ]}>
          {title}
          {href && (
            <svg class="inline-block w-4 h-4 ml-1 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          )}
        </h3>

        {/* Meta info */}
        <div class:list={[
          'flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-text-secondary',
          variant === 'compact' ? 'mt-1' : 'mt-2',
        ]}>
          {department && (
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              {department}
            </span>
          )}
          {location && (
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {location}
            </span>
          )}
          {type && (
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {typeLabels[type] || type}
            </span>
          )}
        </div>

        {/* Description for detailed variant */}
        {variant === 'detailed' && description && (
          <p class="text-text-secondary mt-3 line-clamp-2">{description}</p>
        )}

        {/* Tags */}
        {tags.length > 0 && variant !== 'compact' && (
          <div class="flex flex-wrap gap-2 mt-3">
            {tags.map((tag) => (
              <span class="px-2 py-1 text-xs font-medium rounded-lg bg-background-subtle text-text-secondary">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>

      {/* Right side - Salary */}
      {salary && (
        <div class="flex-shrink-0 text-right">
          <p class="font-semibold text-text-primary">{salary}</p>
          {variant !== 'compact' && (
            <p class="text-xs text-text-tertiary">pro Jahr</p>
          )}
        </div>
      )}
    </div>

    {/* Apply button for detailed variant */}
    {variant === 'detailed' && href && (
      <div class="mt-4 pt-4 border-t border-border-subtle">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-white font-medium rounded-lg group-hover:bg-primary-600 transition-colors">
          Jetzt bewerben
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </div>
    )}
  </div>
</Tag>

<style>
  @media (prefers-reduced-motion: reduce) {
    .job-card {
      transition: none;
    }
  }
</style>
