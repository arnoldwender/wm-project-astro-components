---
/**
 * LocationCard Component - WenderMedia Astro Components
 *
 * Individual location, office, or store card.
 *
 * @example
 * <LocationCard
 *   name="Berlin Office"
 *   address="Friedrichstraße 123, 10117 Berlin"
 *   phone="+49 30 12345678"
 *   email="berlin@example.com"
 *   image="/offices/berlin.jpg"
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface OpeningHours {
  day: string;
  hours: string;
}

export interface Props {
  name: string;
  address: string;
  city?: string;
  country?: string;
  phone?: string;
  email?: string;
  image?: string;
  mapUrl?: string;
  openingHours?: OpeningHours[];
  tags?: string[];
  featured?: boolean;
  variant?: 'default' | 'card' | 'compact' | 'horizontal' | 'detailed';
  class?: string;
}

const {
  name,
  address,
  city,
  country,
  phone,
  email,
  image,
  mapUrl,
  openingHours = [],
  tags = [],
  featured = false,
  variant = 'default',
  class: className = '',
} = Astro.props;
---

<div
  class:list={[
    'location-card group',
    variant === 'card' && 'bg-surface border border-border-subtle rounded-xl overflow-hidden hover:shadow-lg transition-shadow',
    variant === 'default' && 'bg-surface border border-border-subtle rounded-xl p-6',
    variant === 'compact' && 'flex items-center gap-4 p-4 bg-surface border border-border-subtle rounded-lg',
    variant === 'horizontal' && 'flex flex-col md:flex-row gap-6 bg-surface border border-border-subtle rounded-xl overflow-hidden',
    variant === 'detailed' && 'bg-surface border border-border-subtle rounded-2xl overflow-hidden',
    featured && 'ring-2 ring-primary/20',
    className,
  ]}
>
  {/* Image */}
  {image && (variant === 'card' || variant === 'horizontal' || variant === 'detailed') && (
    <div class:list={[
      'location-image overflow-hidden',
      variant === 'card' && 'aspect-video',
      variant === 'horizontal' && 'md:w-2/5 aspect-video md:aspect-auto md:min-h-[200px]',
      variant === 'detailed' && 'aspect-[21/9]',
    ]}>
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  )}

  {/* Content */}
  <div class:list={[
    'location-content',
    variant === 'card' && 'p-5',
    variant === 'horizontal' && 'flex-1 p-6',
    variant === 'detailed' && 'p-6 lg:p-8',
    variant === 'compact' && 'flex-1 min-w-0',
  ]}>
    {/* Tags */}
    {tags.length > 0 && variant !== 'compact' && (
      <div class="flex flex-wrap gap-2 mb-2">
        {tags.map((tag) => (
          <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-primary/10 text-primary">
            {tag}
          </span>
        ))}
      </div>
    )}

    {/* Name & Location */}
    <h3 class:list={[
      'font-semibold text-text-primary',
      variant === 'compact' ? 'text-base' : 'text-lg',
      variant === 'detailed' && 'text-xl',
    ]}>
      {name}
    </h3>

    {(city || country) && (
      <p class="text-sm text-text-tertiary">
        {[city, country].filter(Boolean).join(', ')}
      </p>
    )}

    {/* Address */}
    <div class:list={['flex items-start gap-2 mt-3', variant === 'compact' && 'mt-1']}>
      <svg class="w-4 h-4 text-text-tertiary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <p class:list={['text-text-secondary', variant === 'compact' ? 'text-sm' : 'text-sm']}>
        {address}
      </p>
    </div>

    {/* Contact Info */}
    {(phone || email) && variant !== 'compact' && (
      <div class="mt-3 space-y-2">
        {phone && (
          <a href={`tel:${phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-sm text-text-secondary hover:text-primary transition-colors">
            <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {phone}
          </a>
        )}
        {email && (
          <a href={`mailto:${email}`} class="flex items-center gap-2 text-sm text-text-secondary hover:text-primary transition-colors">
            <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {email}
          </a>
        )}
      </div>
    )}

    {/* Opening Hours */}
    {openingHours.length > 0 && variant === 'detailed' && (
      <div class="mt-4 pt-4 border-t border-border-subtle">
        <h4 class="text-sm font-medium text-text-primary mb-2">Öffnungszeiten</h4>
        <div class="space-y-1">
          {openingHours.map((item) => (
            <div class="flex justify-between text-sm">
              <span class="text-text-secondary">{item.day}</span>
              <span class="text-text-primary">{item.hours}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Map Link */}
    {mapUrl && variant !== 'compact' && (
      <a
        href={mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-primary-600 transition-colors',
          variant === 'detailed' ? 'mt-6' : 'mt-4',
        ]}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
        </svg>
        Route planen
      </a>
    )}
  </div>

  {/* Compact variant action */}
  {variant === 'compact' && mapUrl && (
    <a
      href={mapUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex-shrink-0 w-10 h-10 rounded-full bg-background-subtle flex items-center justify-center text-text-tertiary hover:bg-primary hover:text-white transition-colors"
      aria-label="Route planen"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      </svg>
    </a>
  )}
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .location-card {
      transition: none;
    }
  }
</style>
