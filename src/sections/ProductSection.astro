</style>

<script>
  function initProductSections() {
    // Quantity controls
    const quantityControls = document.querySelectorAll('.quantity-controls');
    quantityControls.forEach((control) => {
      const input = control.querySelector('.quantity-input') as HTMLInputElement;
      const decBtn = control.querySelector('[data-quantity-dec]');
      const incBtn = control.querySelector('[data-quantity-inc]');

      decBtn?.addEventListener('click', () => {
        const value = parseInt(input.value) || 1;
        if (value > 1) input.value = String(value - 1);
      });

      incBtn?.addEventListener('click', () => {
        const value = parseInt(input.value) || 1;
        input.value = String(value + 1);
      });
    });

    // Thumbnail gallery
    const thumbnails = document.querySelectorAll('.thumbnail[data-image]');
    thumbnails.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const imageUrl = thumb.getAttribute('data-image');
        const mainImage = thumb.closest('.featured-gallery, .detail-gallery')?.querySelector('.main-image img, .main-image-container img') as HTMLImageElement;

        if (mainImage && imageUrl) {
          mainImage.src = imageUrl;

          // Update active state
          thumb.closest('.thumbnail-grid, .thumbnail-strip')?.querySelectorAll('.thumbnail').forEach((t) => {
            t.classList.remove('active');
          });
          thumb.classList.add('active');
        }
      });
    });

    // Variant buttons
    const variantBtns = document.querySelectorAll('.variant-btn');
    variantBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.closest('.variant-options')?.querySelectorAll('.variant-btn').forEach((b) => {
          b.classList.remove('active');
        });
        btn.classList.add('active');
      });
    });

    // Carousel
    const carousels = document.querySelectorAll('[data-product-carousel]');
    carousels.forEach((carousel) => {
      const track = carousel.querySelector('.carousel-track') as HTMLElement;
      const prevBtn = carousel.querySelector('[data-carousel-prev]');
      const nextBtn = carousel.querySelector('[data-carousel-next]');

      let position = 0;
      const cardWidth = track?.querySelector('.product-card')?.clientWidth || 0;
      const gap = 24; // 1.5rem
      const visibleCards = Math.floor(track?.parentElement?.clientWidth || 0 / (cardWidth + gap)) || 4;
      const totalCards = track?.children.length || 0;
      const maxPosition = (totalCards - visibleCards) * (cardWidth + gap);

      prevBtn?.addEventListener('click', () => {
        position = Math.max(0, position - (cardWidth + gap));
        if (track) track.style.transform = `translateX(-${position}px)`;
      });

      nextBtn?.addEventListener('click', () => {
        position = Math.min(maxPosition, position + (cardWidth + gap));
        if (track) track.style.transform = `translateX(-${position}px)`;
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductSections);
  } else {
    initProductSections();
  }

  document.addEventListener('astro:page-load', initProductSections);
</script>
