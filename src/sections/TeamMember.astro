---
/**
 * TeamMember Component - WenderMedia Astro Components
 *
 * Individual team member card.
 *
 * @example
 * <TeamMember
 *   name="Jane Doe"
 *   role="CEO & Founder"
 *   image="/images/team/jane.jpg"
 *   bio="Passionate about building great products."
 *   socials={[
 *     { platform: 'linkedin', url: 'https://linkedin.com/in/jane' },
 *     { platform: 'twitter', url: 'https://twitter.com/jane' },
 *   ]}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Social {
  platform: 'linkedin' | 'twitter' | 'github' | 'instagram' | 'email' | 'website';
  url: string;
}

export interface Props {
  name: string;
  role: string;
  image?: string;
  bio?: string;
  socials?: Social[];
  variant?: 'default' | 'card' | 'horizontal' | 'minimal' | 'overlay';
  class?: string;
}

const {
  name,
  role,
  image,
  bio,
  socials = [],
  variant = 'default',
  class: className = '',
} = Astro.props;

// Social icons
const socialIcons: Record<Social['platform'], string> = {
  linkedin: '<svg fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  twitter: '<svg fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  github: '<svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  instagram: '<svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
  email: '<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
  website: '<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>',
};

// Initials fallback
const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
---

{variant === 'overlay' ? (
  <div class:list={['team-member-overlay group relative overflow-hidden rounded-2xl', className]}>
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-full aspect-[3/4] object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full aspect-[3/4] bg-gradient-to-br from-primary/20 to-primary/40 flex items-center justify-center">
        <span class="text-4xl font-bold text-primary">{initials}</span>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity" />
    <div class="absolute inset-x-0 bottom-0 p-6 text-white">
      <h3 class="font-semibold text-lg">{name}</h3>
      <p class="text-sm text-white/80">{role}</p>
      {bio && (
        <p class="text-sm text-white/60 mt-2 line-clamp-2 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
          {bio}
        </p>
      )}
      {socials.length > 0 && (
        <div class="flex gap-3 mt-4 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 delay-75">
          {socials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center hover:bg-white/30 transition-colors"
              aria-label={`${name} on ${social.platform}`}
            >
              <span class="w-4 h-4" set:html={socialIcons[social.platform]} />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
) : variant === 'horizontal' ? (
  <div class:list={['team-member-horizontal flex gap-6 items-center', className]}>
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-24 h-24 rounded-full object-cover flex-shrink-0"
        loading="lazy"
      />
    ) : (
      <div class="w-24 h-24 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
        <span class="text-2xl font-bold text-primary">{initials}</span>
      </div>
    )}
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-text-primary">{name}</h3>
      <p class="text-sm text-primary font-medium">{role}</p>
      {bio && (
        <p class="text-sm text-text-secondary mt-2 line-clamp-2">{bio}</p>
      )}
      {socials.length > 0 && (
        <div class="flex gap-2 mt-3">
          {socials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-8 h-8 rounded-lg bg-background-subtle flex items-center justify-center text-text-tertiary hover:text-primary hover:bg-primary/10 transition-colors"
              aria-label={`${name} on ${social.platform}`}
            >
              <span class="w-4 h-4" set:html={socialIcons[social.platform]} />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
) : variant === 'minimal' ? (
  <div class:list={['team-member-minimal text-center', className]}>
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-16 h-16 rounded-full object-cover mx-auto mb-3"
        loading="lazy"
      />
    ) : (
      <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
        <span class="text-lg font-bold text-primary">{initials}</span>
      </div>
    )}
    <h3 class="font-medium text-text-primary text-sm">{name}</h3>
    <p class="text-xs text-text-tertiary">{role}</p>
  </div>
) : variant === 'card' ? (
  <div class:list={['team-member-card bg-surface border border-border-subtle rounded-2xl p-6 text-center', className]}>
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-28 h-28 rounded-full object-cover mx-auto mb-4 ring-4 ring-background"
        loading="lazy"
      />
    ) : (
      <div class="w-28 h-28 rounded-full bg-gradient-to-br from-primary/20 to-primary/40 flex items-center justify-center mx-auto mb-4 ring-4 ring-background">
        <span class="text-3xl font-bold text-primary">{initials}</span>
      </div>
    )}
    <h3 class="font-semibold text-lg text-text-primary">{name}</h3>
    <p class="text-sm text-primary font-medium mb-2">{role}</p>
    {bio && (
      <p class="text-sm text-text-secondary line-clamp-3">{bio}</p>
    )}
    {socials.length > 0 && (
      <div class="flex justify-center gap-2 mt-4 pt-4 border-t border-border-subtle">
        {socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-background-subtle flex items-center justify-center text-text-tertiary hover:text-primary hover:bg-primary/10 transition-colors"
            aria-label={`${name} on ${social.platform}`}
          >
            <span class="w-4 h-4" set:html={socialIcons[social.platform]} />
          </a>
        ))}
      </div>
    )}
  </div>
) : (
  <div class:list={['team-member-default text-center', className]}>
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-40 h-40 rounded-full object-cover mx-auto mb-4"
        loading="lazy"
      />
    ) : (
      <div class="w-40 h-40 rounded-full bg-gradient-to-br from-primary/20 to-primary/40 flex items-center justify-center mx-auto mb-4">
        <span class="text-4xl font-bold text-primary">{initials}</span>
      </div>
    )}
    <h3 class="font-semibold text-lg text-text-primary">{name}</h3>
    <p class="text-sm text-primary font-medium mb-2">{role}</p>
    {bio && (
      <p class="text-sm text-text-secondary max-w-xs mx-auto">{bio}</p>
    )}
    {socials.length > 0 && (
      <div class="flex justify-center gap-3 mt-4">
        {socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-background-subtle flex items-center justify-center text-text-tertiary hover:text-primary hover:bg-primary/10 transition-colors"
            aria-label={`${name} on ${social.platform}`}
          >
            <span class="w-5 h-5" set:html={socialIcons[social.platform]} />
          </a>
        ))}
      </div>
    )}
  </div>
)}

<style>
  .team-member-overlay {
    container-type: inline-size;
  }

  @media (prefers-reduced-motion: reduce) {
    .team-member-overlay img {
      transition: none;
    }

    .team-member-overlay .group-hover\:opacity-100,
    .team-member-overlay .group-hover\:translate-y-0 {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
