---
/**
 * SocialProofSection Component
 *
 * Display social proof elements like ratings, reviews count, and trust signals.
 *
 * Variants:
 * - stats: Key metrics and numbers
 * - ratings: Platform ratings (Google, Trustpilot, etc.)
 * - badges: Trust badges and certifications
 * - reviews: Aggregated review scores
 * - combined: Mix of stats, ratings, and badges
 * - minimal: Simple inline trust indicators
 *
 * @example
 * <SocialProofSection variant="ratings">
 *   <SocialProofItem platform="google" rating={4.8} count={500} />
 * </SocialProofSection>
 */

import SectionWrapper from './SectionWrapper.astro';

export interface RatingItem {
  platform: string;
  rating: number;
  count?: number;
  logo?: string;
  href?: string;
}

export interface StatItem {
  value: string;
  label: string;
  icon?: string;
}

export interface BadgeItem {
  name: string;
  image: string;
  href?: string;
}

export interface Props {
  variant?: 'stats' | 'ratings' | 'badges' | 'reviews' | 'combined' | 'minimal';
  title?: string;
  ratings?: RatingItem[];
  stats?: StatItem[];
  badges?: BadgeItem[];
  columns?: 2 | 3 | 4 | 5 | 6;
  background?: 'transparent' | 'subtle' | 'muted' | 'dark';
  class?: string;
}

const {
  variant = 'ratings',
  title,
  ratings = [],
  stats = [],
  badges = [],
  columns = 4,
  background = 'transparent',
  class: className = '',
} = Astro.props;

// Platform logos
const platformLogos: Record<string, string> = {
  google: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>',
  trustpilot: '<svg viewBox="0 0 24 24" fill="#00B67A"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>',
  yelp: '<svg viewBox="0 0 24 24" fill="#FF1A1A"><path d="M21.111 18.226c-.141.969-2.119 3.483-2.998 3.782-.259.091-.509.091-.681-.009-.129-.057-.171-.091-.937-.794-1.029-.94-1.373-1.282-1.513-1.503a1.044 1.044 0 01-.129-.507c.01-.198.069-.388.189-.559.172-.266.422-.524.947-.946l1.513-1.21c.267-.216.527-.332.716-.332.198 0 .396.095.544.284.353.45 2.207 2.826 2.349 3.794zm-3.499-7.369c-.061.569-.51 1.109-.975 1.175-.171.022-.337.034-.498.034-.422 0-.824-.073-1.203-.209-1.075-.383-1.843-.987-2.299-1.808-.085-.156-.164-.329-.234-.524-.075-.206-.136-.43-.181-.676-.043-.238-.077-.496-.1-.772-.02-.254-.034-.523-.045-.806-.05-1.385-.048-2.886.035-4.461.018-.385.095-.726.225-1.015.134-.296.323-.545.554-.738.237-.195.528-.34.863-.425.34-.085.746-.128 1.192-.128.429 0 .833.039 1.168.118.343.08.633.221.866.412.231.191.407.435.522.729.115.289.178.632.186 1.017.016.811-.002 1.61-.055 2.389-.054.791-.13 1.567-.227 2.319-.098.762-.218 1.491-.357 2.182-.139.688-.291 1.329-.446 1.918-.037.139-.044.273-.022.398z"/></svg>',
  capterra: '<svg viewBox="0 0 24 24" fill="#FF9D28"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>',
  g2: '<svg viewBox="0 0 24 24" fill="#FF492C"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>',
};

// Star rating component
const renderStars = (rating: number) => {
  const fullStars = Math.floor(rating);
  const hasHalf = rating % 1 >= 0.5;
  const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

  return `
    ${Array(fullStars).fill('<svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>').join('')}
    ${hasHalf ? '<svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><defs><linearGradient id="half"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="#e5e7eb"/></linearGradient></defs><path fill="url(#half)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>' : ''}
    ${Array(emptyStars).fill('<svg class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>').join('')}
  `;
};

const columnClasses = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
  5: 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5',
  6: 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6',
};
---

<SectionWrapper background={background} class={className} padding="small">
  {title && (
    <p class:list={[
      'text-center text-sm font-medium mb-6',
      background === 'dark' ? 'text-white/60' : 'text-text-tertiary',
    ]}>
      {title}
    </p>
  )}

  {/* Stats Variant */}
  {variant === 'stats' && stats.length > 0 && (
    <div class:list={['grid gap-8', columnClasses[columns]]}>
      {stats.map((stat) => (
        <div class="text-center">
          {stat.icon && (
            <span class="inline-block mb-2 text-primary" set:html={stat.icon} />
          )}
          <p class:list={[
            'text-3xl lg:text-4xl font-bold',
            background === 'dark' ? 'text-white' : 'text-text-primary',
          ]}>
            {stat.value}
          </p>
          <p class:list={[
            'text-sm',
            background === 'dark' ? 'text-white/70' : 'text-text-secondary',
          ]}>
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  )}

  {/* Ratings Variant */}
  {variant === 'ratings' && ratings.length > 0 && (
    <div class:list={['grid gap-6', columnClasses[Math.min(ratings.length, columns) as 2 | 3 | 4 | 5 | 6]]}>
      {ratings.map((item) => {
        const Tag = item.href ? 'a' : 'div';
        return (
          <Tag
            href={item.href}
            target={item.href ? '_blank' : undefined}
            rel={item.href ? 'noopener noreferrer' : undefined}
            class:list={[
              'flex flex-col items-center p-4 rounded-xl',
              item.href && 'hover:bg-background-subtle transition-colors cursor-pointer',
            ]}
          >
            {/* Platform logo */}
            <div class="w-8 h-8 mb-2">
              {item.logo ? (
                <img src={item.logo} alt={item.platform} class="w-full h-full object-contain" />
              ) : (
                <span set:html={platformLogos[item.platform.toLowerCase()] || ''} />
              )}
            </div>

            {/* Stars */}
            <div class="flex items-center gap-0.5 mb-1" set:html={renderStars(item.rating)} />

            {/* Rating and count */}
            <p class:list={[
              'text-sm',
              background === 'dark' ? 'text-white' : 'text-text-primary',
            ]}>
              <span class="font-semibold">{item.rating.toFixed(1)}</span>
              {item.count && (
                <span class:list={[background === 'dark' ? 'text-white/60' : 'text-text-tertiary']}>
                  {' '}({item.count.toLocaleString()} Bewertungen)
                </span>
              )}
            </p>
          </Tag>
        );
      })}
    </div>
  )}

  {/* Badges Variant */}
  {variant === 'badges' && badges.length > 0 && (
    <div class="flex flex-wrap justify-center items-center gap-6 lg:gap-10">
      {badges.map((badge) => {
        const Tag = badge.href ? 'a' : 'div';
        return (
          <Tag
            href={badge.href}
            target={badge.href ? '_blank' : undefined}
            rel={badge.href ? 'noopener noreferrer' : undefined}
            class:list={[
              'flex-shrink-0',
              badge.href && 'hover:opacity-80 transition-opacity',
            ]}
          >
            <img
              src={badge.image}
              alt={badge.name}
              class="h-12 lg:h-16 w-auto"
              loading="lazy"
            />
          </Tag>
        );
      })}
    </div>
  )}

  {/* Reviews Variant */}
  {variant === 'reviews' && ratings.length > 0 && (
    <div class="max-w-2xl mx-auto text-center">
      {/* Aggregate rating */}
      {ratings[0] && (
        <>
          <div class="flex justify-center gap-1 mb-2" set:html={renderStars(ratings[0].rating)} />
          <p class:list={[
            'text-4xl font-bold mb-1',
            background === 'dark' ? 'text-white' : 'text-text-primary',
          ]}>
            {ratings[0].rating.toFixed(1)}
          </p>
          <p class:list={[
            'text-sm mb-6',
            background === 'dark' ? 'text-white/60' : 'text-text-tertiary',
          ]}>
            Basierend auf {ratings.reduce((acc, r) => acc + (r.count || 0), 0).toLocaleString()} Bewertungen
          </p>
        </>
      )}

      {/* Platform breakdown */}
      <div class="flex flex-wrap justify-center gap-4">
        {ratings.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'flex items-center gap-2 px-4 py-2 rounded-full',
              background === 'dark' ? 'bg-white/10 hover:bg-white/20' : 'bg-background-subtle hover:bg-background-muted',
              'transition-colors',
            ]}
          >
            <span class="w-5 h-5" set:html={platformLogos[item.platform.toLowerCase()] || ''} />
            <span class:list={['text-sm font-medium', background === 'dark' ? 'text-white' : 'text-text-primary']}>
              {item.rating.toFixed(1)}
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* Combined Variant */}
  {variant === 'combined' && (
    <div class="space-y-8">
      {/* Stats row */}
      {stats.length > 0 && (
        <div class="flex flex-wrap justify-center gap-8 lg:gap-16">
          {stats.map((stat) => (
            <div class="text-center">
              <p class:list={[
                'text-2xl lg:text-3xl font-bold',
                background === 'dark' ? 'text-white' : 'text-text-primary',
              ]}>
                {stat.value}
              </p>
              <p class:list={[
                'text-xs',
                background === 'dark' ? 'text-white/60' : 'text-text-tertiary',
              ]}>
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      )}

      {/* Ratings & Badges row */}
      <div class="flex flex-wrap justify-center items-center gap-6">
        {ratings.map((item) => (
          <div class="flex items-center gap-2">
            <span class="w-6 h-6" set:html={platformLogos[item.platform.toLowerCase()] || ''} />
            <span class:list={['font-semibold', background === 'dark' ? 'text-white' : 'text-text-primary']}>
              {item.rating.toFixed(1)}
            </span>
          </div>
        ))}
        {badges.map((badge) => (
          <img src={badge.image} alt={badge.name} class="h-8 w-auto" loading="lazy" />
        ))}
      </div>
    </div>
  )}

  {/* Minimal Variant */}
  {variant === 'minimal' && (
    <div class="flex flex-wrap justify-center items-center gap-6 text-sm">
      {ratings.map((item) => (
        <div class="flex items-center gap-2">
          <span class="w-5 h-5" set:html={platformLogos[item.platform.toLowerCase()] || ''} />
          <span class:list={[background === 'dark' ? 'text-white' : 'text-text-secondary']}>
            <span class="font-semibold">{item.rating.toFixed(1)}</span>
            {item.count && <span class="opacity-70"> ({item.count})</span>}
          </span>
        </div>
      ))}
      {stats.map((stat) => (
        <div class:list={['flex items-center gap-2', background === 'dark' ? 'text-white' : 'text-text-secondary']}>
          <span class="font-semibold">{stat.value}</span>
          <span class="opacity-70">{stat.label}</span>
        </div>
      ))}
    </div>
  )}

  {/* Slot for custom content */}
  <slot />
</SectionWrapper>
