---
/**
 * CTASection Component - WenderMedia Astro Components
 *
 * A conversion-focused call-to-action section designed to drive user action. Place it
 * between content sections, at the bottom of a page, or as a sticky banner. Six layout
 * variants let you match the CTA to its context -- from a subtle inline banner to a
 * bold full-width background image.
 *
 * Features:
 * - Six variants: centered, split, banner, card, gradient, image
 * - Four background styles: primary brand color, dark, gradient, or transparent
 * - Background image support with automatic 60% dark overlay (image variant)
 * - Slot-based content: eyebrow, title, description, cta, and extra
 * - "banner" variant is compact (py-6) for sticky or inline use
 * - "card" variant renders a rounded, elevated card inside a transparent wrapper
 * - "split" variant places text on the left and CTA buttons/forms on the right
 *
 * Named slots:
 * - "eyebrow"     — Small label above the title (not available in "banner" variant)
 * - "title"       — The main heading text (required)
 * - "description" — Supporting copy below the title
 * - "cta"         — Buttons, links, or a form
 * - "extra"       — Additional content below the CTA (only in centered/gradient variants)
 *
 * @example
 * ---
 * import CTASection from '../sections/CTASection.astro';
 * import Button from '../atoms/Button.astro';
 * ---
 * <!-- Centered CTA with primary background -->
 * <CTASection variant="centered" background="primary">
 *   <Fragment slot="title">Ready to Get Started?</Fragment>
 *   <Fragment slot="description">Join 10,000+ teams already using Acme Platform.</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/signup">Start Free Trial</Button>
 *     <Button href="/demo" variant="outline">Book a Demo</Button>
 *   </Fragment>
 * </CTASection>
 *
 * @example
 * <!-- Compact banner CTA (great for sticky bars or between sections) -->
 * <CTASection variant="banner" background="dark">
 *   <Fragment slot="title">Limited Offer: 30% Off All Plans</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/pricing" size="sm">Claim Discount</Button>
 *   </Fragment>
 * </CTASection>
 *
 * @example
 * <!-- Split CTA with form or buttons on the right -->
 * <CTASection variant="split">
 *   <Fragment slot="eyebrow">Newsletter</Fragment>
 *   <Fragment slot="title">Stay in the Loop</Fragment>
 *   <Fragment slot="description">Get weekly tips on design and development.</Fragment>
 *   <Fragment slot="cta">
 *     <form class="flex gap-2">
 *       <input type="email" placeholder="you@example.com" class="input" />
 *       <Button type="submit">Subscribe</Button>
 *     </form>
 *   </Fragment>
 * </CTASection>
 *
 * @example
 * <!-- Card CTA floating on a transparent background -->
 * <CTASection variant="card" background="gradient">
 *   <Fragment slot="title">Upgrade Your Workflow</Fragment>
 *   <Fragment slot="description">Go Pro and unlock all features today.</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/upgrade">Upgrade Now</Button>
 *   </Fragment>
 * </CTASection>
 *
 * @example
 * <!-- Background image CTA -->
 * <CTASection variant="image" backgroundImage="/images/cta-bg.jpg">
 *   <Fragment slot="title">Let's Build Something Great</Fragment>
 *   <Fragment slot="description">Our team is ready to help you succeed.</Fragment>
 *   <Fragment slot="cta">
 *     <Button href="/contact">Contact Us</Button>
 *   </Fragment>
 * </CTASection>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

import SectionWrapper from './SectionWrapper.astro';

export interface Props {
  variant?: 'centered' | 'split' | 'banner' | 'card' | 'gradient' | 'image';
  background?: 'primary' | 'dark' | 'gradient' | 'transparent';
  backgroundImage?: string;
  class?: string;
}

const {
  variant = 'centered',
  background = 'primary',
  backgroundImage,
  class: className = '',
} = Astro.props;

// Background classes
const bgClasses = {
  primary: 'bg-primary text-primary-text',
  dark: 'bg-surface-inverse text-text-inverse',
  gradient: 'bg-gradient-to-r from-primary via-secondary to-primary text-white',
  transparent: 'bg-transparent',
};
---

{variant === 'card' ? (
  <SectionWrapper background="transparent" class={className}>
    <div class:list={[
      'cta-card rounded-2xl p-8 lg:p-12',
      bgClasses[background],
    ]}>
      <div class="text-center max-w-3xl mx-auto">
        {Astro.slots.has('eyebrow') && (
          <div class="cta-eyebrow text-sm font-semibold uppercase tracking-wider opacity-80 mb-4">
            <slot name="eyebrow" />
          </div>
        )}
        <h2 class="cta-title text-3xl lg:text-4xl font-bold mb-4">
          <slot name="title" />
        </h2>
        {Astro.slots.has('description') && (
          <p class="cta-description text-lg opacity-90 mb-8">
            <slot name="description" />
          </p>
        )}
        <div class="cta-actions flex flex-wrap justify-center gap-4">
          <slot name="cta" />
        </div>
      </div>
    </div>
  </SectionWrapper>
) : variant === 'banner' ? (
  <div
    class:list={[
      'cta-banner py-6 lg:py-8',
      bgClasses[background],
      className,
    ]}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-center md:text-left">
          <h2 class="text-xl lg:text-2xl font-bold">
            <slot name="title" />
          </h2>
          {Astro.slots.has('description') && (
            <p class="text-sm opacity-80 mt-1">
              <slot name="description" />
            </p>
          )}
        </div>
        <div class="cta-actions flex flex-wrap gap-3">
          <slot name="cta" />
        </div>
      </div>
    </div>
  </div>
) : variant === 'split' ? (
  <SectionWrapper
    background={background === 'transparent' ? 'subtle' : background}
    class={className}
  >
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <div class="cta-content">
        {Astro.slots.has('eyebrow') && (
          <div class="cta-eyebrow text-sm font-semibold uppercase tracking-wider text-primary mb-4">
            <slot name="eyebrow" />
          </div>
        )}
        <h2 class="cta-title text-3xl lg:text-4xl font-bold text-text-primary mb-4">
          <slot name="title" />
        </h2>
        {Astro.slots.has('description') && (
          <p class="cta-description text-lg text-text-secondary">
            <slot name="description" />
          </p>
        )}
      </div>
      <div class="cta-actions">
        <slot name="cta" />
      </div>
    </div>
  </SectionWrapper>
) : variant === 'image' ? (
  <div
    class:list={[
      'cta-image relative py-20 lg:py-32 bg-cover bg-center',
      className,
    ]}
    style={backgroundImage ? `background-image: url('${backgroundImage}')` : undefined}
  >
    <div class="absolute inset-0 bg-black/60" />
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center text-white max-w-3xl mx-auto">
        {Astro.slots.has('eyebrow') && (
          <div class="cta-eyebrow text-sm font-semibold uppercase tracking-wider opacity-80 mb-4">
            <slot name="eyebrow" />
          </div>
        )}
        <h2 class="cta-title text-3xl lg:text-5xl font-bold mb-4">
          <slot name="title" />
        </h2>
        {Astro.slots.has('description') && (
          <p class="cta-description text-lg lg:text-xl opacity-90 mb-8">
            <slot name="description" />
          </p>
        )}
        <div class="cta-actions flex flex-wrap justify-center gap-4">
          <slot name="cta" />
        </div>
      </div>
    </div>
  </div>
) : (
  /* Centered / Gradient variants */
  <div
    class:list={[
      'cta-section py-16 lg:py-24',
      variant === 'gradient' ? bgClasses.gradient : bgClasses[background],
      className,
    ]}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        {Astro.slots.has('eyebrow') && (
          <div class="cta-eyebrow text-sm font-semibold uppercase tracking-wider opacity-80 mb-4">
            <slot name="eyebrow" />
          </div>
        )}
        <h2 class="cta-title text-3xl lg:text-4xl xl:text-5xl font-bold mb-4">
          <slot name="title" />
        </h2>
        {Astro.slots.has('description') && (
          <p class="cta-description text-lg lg:text-xl opacity-90 mb-8">
            <slot name="description" />
          </p>
        )}
        <div class="cta-actions flex flex-wrap justify-center gap-4">
          <slot name="cta" />
        </div>
        {Astro.slots.has('extra') && (
          <div class="cta-extra mt-8 opacity-80">
            <slot name="extra" />
          </div>
        )}
      </div>
    </div>
  </div>
)}
