---
/**
 * TestimonialsSection Component - WenderMedia Astro Components
 *
 * A social-proof section that displays customer testimonials in six layout variants.
 * Pass TestimonialCard children into the default slot (or the "featured" named slot
 * for the featured variant). Use it on landing pages, product pages, or case study
 * sections to build trust and credibility.
 *
 * Features:
 * - Six variants: grid, carousel (sliding), featured (large + grid), masonry
 *   (Pinterest-style), quote (single large), and wall (social media style)
 * - Configurable column count (2, 3, or 4) for grid, masonry, featured, and wall variants
 * - Carousel includes previous/next navigation buttons with accessible aria-labels
 * - Masonry layout uses CSS columns for a staggered, Pinterest-like appearance
 * - Optional SectionHeader with eyebrow, title, and description
 * - Background options: transparent, subtle (default), muted, or dark
 * - Works with Astro view transitions (carousel re-initializes on astro:page-load)
 *
 * Named slots:
 * - default    — TestimonialCard children displayed in the chosen layout
 * - "featured" — A single highlighted testimonial (only in the "featured" variant),
 *                rendered large and centered above the remaining grid
 *
 * Child components:
 * - Use TestimonialCard inside the default slot for all variants
 * - For the carousel, each TestimonialCard should have data-testimonial-card attribute
 * - For the "featured" variant, place one TestimonialCard in slot="featured"
 *
 * @example
 * ---
 * import TestimonialsSection from '../sections/TestimonialsSection.astro';
 * import TestimonialCard from '../content/TestimonialCard.astro';
 * ---
 * <!-- Standard 3-column grid -->
 * <TestimonialsSection
 *   variant="grid"
 *   columns={3}
 *   eyebrow="Testimonials"
 *   title="What Our Customers Say"
 *   description="Trusted by teams worldwide."
 * >
 *   <TestimonialCard name="Jane Doe" role="CEO, Acme Corp" quote="This tool saved us hours every week." rating={5} />
 *   <TestimonialCard name="John Smith" role="CTO, Globex" quote="The best investment we made this year." rating={5} />
 *   <TestimonialCard name="Maria Garcia" role="Designer, Initech" quote="Intuitive and beautiful. Highly recommended." rating={4} />
 * </TestimonialsSection>
 *
 * @example
 * <!-- Sliding carousel -->
 * <TestimonialsSection variant="carousel" title="Customer Stories" background="muted">
 *   <TestimonialCard data-testimonial-card name="Jane Doe" role="CEO" quote="Incredible experience." />
 *   <TestimonialCard data-testimonial-card name="John Smith" role="CTO" quote="A game changer." />
 *   <TestimonialCard data-testimonial-card name="Maria Garcia" role="Designer" quote="Love the simplicity." />
 *   <TestimonialCard data-testimonial-card name="Alex Chen" role="Engineer" quote="Solid and reliable." />
 * </TestimonialsSection>
 *
 * @example
 * <!-- Featured testimonial (one large + supporting grid) -->
 * <TestimonialsSection variant="featured" columns={2} title="What People Think">
 *   <TestimonialCard slot="featured" name="Jane Doe" role="CEO, Acme Corp" quote="This platform transformed our entire workflow." />
 *   <TestimonialCard name="John Smith" role="CTO" quote="Fast and reliable." />
 *   <TestimonialCard name="Maria Garcia" role="Designer" quote="Beautiful design system." />
 * </TestimonialsSection>
 *
 * @example
 * <!-- Masonry layout for varied-length testimonials -->
 * <TestimonialsSection variant="masonry" columns={3} title="Wall of Love" background="subtle">
 *   <TestimonialCard name="Jane Doe" quote="Short and sweet!" />
 *   <TestimonialCard name="John Smith" quote="We have been using this for six months now and the results speak for themselves. Our team productivity went up 40%." />
 *   <TestimonialCard name="Maria Garcia" quote="Highly recommended." />
 * </TestimonialsSection>
 *
 * @example
 * <!-- Single large quote -->
 * <TestimonialsSection variant="quote" background="dark">
 *   <TestimonialCard name="Jane Doe" role="CEO, Acme Corp" quote="The single best decision we made for our business this year." />
 * </TestimonialsSection>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

import SectionWrapper from './SectionWrapper.astro';
import SectionHeader from './SectionHeader.astro';

export interface Props {
  variant?: 'grid' | 'carousel' | 'featured' | 'masonry' | 'quote' | 'wall';
  columns?: 2 | 3 | 4;
  eyebrow?: string;
  title?: string;
  description?: string;
  background?: 'transparent' | 'subtle' | 'muted' | 'dark';
  class?: string;
}

const {
  variant = 'grid',
  columns = 3,
  eyebrow,
  title,
  description,
  background = 'subtle',
  class: className = '',
} = Astro.props;

// Column classes
const columnClasses = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};

// Masonry column classes
const masonryClasses = {
  2: 'columns-1 md:columns-2',
  3: 'columns-1 md:columns-2 lg:columns-3',
  4: 'columns-1 sm:columns-2 lg:columns-3 xl:columns-4',
};
---

<SectionWrapper background={background} class={className}>
  {(eyebrow || title || description) && (
    <SectionHeader
      eyebrow={eyebrow}
      title={title || ''}
      description={description}
    />
  )}

  {/* Grid Variant */}
  {variant === 'grid' && (
    <div class:list={['testimonials-grid grid gap-6 lg:gap-8', columnClasses[columns]]}>
      <slot />
    </div>
  )}

  {/* Carousel Variant */}
  {variant === 'carousel' && (
    <div class="testimonials-carousel relative" data-testimonials-carousel>
      <div class="overflow-hidden">
        <div class="testimonials-track flex transition-transform duration-500" data-carousel-track>
          <slot />
        </div>
      </div>

      {/* Navigation */}
      <div class="flex justify-center gap-2 mt-8">
        <button
          type="button"
          class="p-2 rounded-full bg-surface border border-border-subtle hover:bg-background-subtle transition-colors"
          data-carousel-prev
          aria-label="Previous"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          type="button"
          class="p-2 rounded-full bg-surface border border-border-subtle hover:bg-background-subtle transition-colors"
          data-carousel-next
          aria-label="Next"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  )}

  {/* Featured Variant */}
  {variant === 'featured' && (
    <div class="testimonials-featured">
      <div class="max-w-4xl mx-auto">
        <slot name="featured" />
      </div>
      {Astro.slots.has('default') && (
        <div class:list={['mt-12 grid gap-6', columnClasses[columns]]}>
          <slot />
        </div>
      )}
    </div>
  )}

  {/* Masonry Variant */}
  {variant === 'masonry' && (
    <div class:list={['testimonials-masonry gap-6', masonryClasses[columns]]}>
      <slot />
    </div>
  )}

  {/* Quote Variant - Single large quote */}
  {variant === 'quote' && (
    <div class="testimonials-quote max-w-4xl mx-auto text-center">
      <slot />
    </div>
  )}

  {/* Wall Variant - Social media style */}
  {variant === 'wall' && (
    <div class:list={['testimonials-wall grid gap-4', columnClasses[columns]]}>
      <slot />
    </div>
  )}
</SectionWrapper>

<style>
  /* Masonry items */
  .testimonials-masonry :global(> *) {
    break-inside: avoid;
    margin-bottom: 1.5rem;
  }

  /* Carousel items */
  .testimonials-carousel :global([data-testimonial-card]) {
    flex: 0 0 100%;
    padding: 0 1rem;
  }

  @media (min-width: 768px) {
    .testimonials-carousel :global([data-testimonial-card]) {
      flex: 0 0 50%;
    }
  }

  @media (min-width: 1024px) {
    .testimonials-carousel :global([data-testimonial-card]) {
      flex: 0 0 33.333%;
    }
  }
</style>

<script>
  function initCarousel() {
    const carousels = document.querySelectorAll('[data-testimonials-carousel]');

    carousels.forEach((carousel) => {
      const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
      const prevBtn = carousel.querySelector('[data-carousel-prev]');
      const nextBtn = carousel.querySelector('[data-carousel-next]');
      const items = track?.querySelectorAll('[data-testimonial-card]') || [];

      if (!track || items.length === 0) return;

      let currentIndex = 0;
      const itemsPerView = window.innerWidth >= 1024 ? 3 : window.innerWidth >= 768 ? 2 : 1;
      const maxIndex = Math.max(0, items.length - itemsPerView);

      function updateCarousel() {
        const itemWidth = 100 / itemsPerView;
        track.style.transform = `translateX(-${currentIndex * itemWidth}%)`;
      }

      prevBtn?.addEventListener('click', () => {
        currentIndex = Math.max(0, currentIndex - 1);
        updateCarousel();
      });

      nextBtn?.addEventListener('click', () => {
        currentIndex = Math.min(maxIndex, currentIndex + 1);
        updateCarousel();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }

  document.addEventListener('astro:page-load', initCarousel);
</script>
