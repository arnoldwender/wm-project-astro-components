---
/**
 * PricingSection Component - WenderMedia Astro Components
 *
 * A flexible pricing display section that wraps PricingCard children in different
 * layouts. Use it on landing pages, product pages, or SaaS marketing sites to
 * present tiered plans side by side. Pass PricingCard components as children via
 * the default slot.
 *
 * Features:
 * - Four layout variants: cards, comparison table, monthly/yearly toggle, and minimal list
 * - Configurable grid columns (2, 3, or 4) for the cards and toggle variants
 * - Optional SectionHeader with eyebrow, title, and description
 * - Built-in billing-period toggle (monthly/yearly) that dispatches a "pricing:toggle"
 *   custom event so child PricingCard components can react and swap prices
 * - Accessible toggle: uses aria-pressed and keyboard-operable button
 * - Background options: transparent, subtle, or muted
 *
 * Child components:
 * - Use PricingCard inside the default <slot /> for the "cards" and "toggle" variants
 * - Use a custom <table> or comparison markup for the "comparison" variant
 * - Use simple list items or PricingCard (minimal style) for the "minimal" variant
 *
 * Variant-specific behavior:
 * - "cards" / "toggle": Renders a responsive CSS grid. "toggle" adds the billing switch.
 * - "comparison": Renders an overflow-x-auto wrapper for wide comparison tables.
 * - "minimal": Renders a centered, stacked list (max-w-2xl) for simple pricing.
 *
 * @example
 * ---
 * import PricingSection from '../sections/PricingSection.astro';
 * import PricingCard from '../ecommerce/PricingCard.astro';
 * ---
 * <!-- Standard 3-column pricing cards -->
 * <PricingSection
 *   variant="cards"
 *   columns={3}
 *   eyebrow="Pricing"
 *   title="Choose Your Plan"
 *   description="No hidden fees. Cancel anytime."
 * >
 *   <PricingCard name="Starter" price={9} period="mo" features={['5 Projects', '10 GB Storage']} />
 *   <PricingCard name="Pro" price={29} period="mo" featured features={['Unlimited Projects', '100 GB Storage']} />
 *   <PricingCard name="Enterprise" price={99} period="mo" features={['Everything in Pro', 'Priority Support']} />
 * </PricingSection>
 *
 * @example
 * <!-- Monthly/yearly toggle variant -->
 * <PricingSection
 *   variant="toggle"
 *   showToggle={true}
 *   columns={2}
 *   title="Simple, Transparent Pricing"
 * >
 *   <PricingCard name="Basic" price={15} period="mo" />
 *   <PricingCard name="Premium" price={45} period="mo" featured />
 * </PricingSection>
 *
 * @example
 * <!-- Minimal pricing list -->
 * <PricingSection variant="minimal" title="Our Rates" background="subtle">
 *   <PricingCard name="Consultation" price={150} period="hr" />
 *   <PricingCard name="Workshop" price={500} period="day" />
 * </PricingSection>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

import SectionWrapper from './SectionWrapper.astro';
import SectionHeader from './SectionHeader.astro';

export interface Props {
  variant?: 'cards' | 'comparison' | 'toggle' | 'minimal';
  columns?: 2 | 3 | 4;
  eyebrow?: string;
  title?: string;
  description?: string;
  showToggle?: boolean;
  background?: 'transparent' | 'subtle' | 'muted';
  class?: string;
}

const {
  variant = 'cards',
  columns = 3,
  eyebrow,
  title,
  description,
  showToggle = false,
  background = 'transparent',
  class: className = '',
} = Astro.props;

// Column classes
const columnClasses = {
  2: 'md:grid-cols-2 max-w-4xl',
  3: 'lg:grid-cols-3 max-w-5xl',
  4: 'lg:grid-cols-4 max-w-6xl',
};
---

<SectionWrapper background={background} class={className}>
  {(eyebrow || title || description) && (
    <SectionHeader
      eyebrow={eyebrow}
      title={title || ''}
      description={description}
    />
  )}

  {/* Billing Toggle */}
  {showToggle && (
    <div class="pricing-toggle flex items-center justify-center gap-4 mb-12" data-pricing-toggle>
      <span class="text-sm font-medium text-text-secondary" data-toggle-label="monthly">Monatlich</span>
      <button
        type="button"
        class="relative w-14 h-7 bg-background-muted rounded-full transition-colors"
        data-toggle-switch
        aria-pressed="false"
        aria-label="Toggle billing period"
      >
        <span class="absolute top-1 left-1 w-5 h-5 bg-primary rounded-full transition-transform" data-toggle-knob />
      </button>
      <span class="text-sm font-medium text-text-tertiary" data-toggle-label="yearly">
        Jährlich <span class="text-primary">(-20%)</span>
      </span>
    </div>
  )}

  {/* Cards Variant */}
  {(variant === 'cards' || variant === 'toggle') && (
    <div class:list={['pricing-cards grid gap-6 lg:gap-8 mx-auto items-start', columnClasses[columns]]}>
      <slot />
    </div>
  )}

  {/* Comparison Variant */}
  {variant === 'comparison' && (
    <div class="pricing-comparison overflow-x-auto">
      <slot />
    </div>
  )}

  {/* Minimal Variant */}
  {variant === 'minimal' && (
    <div class="pricing-minimal max-w-2xl mx-auto space-y-4">
      <slot />
    </div>
  )}
</SectionWrapper>

<style>
  /* Toggle switch */
  [data-toggle-switch][aria-pressed="true"] {
    background-color: var(--color-primary);
  }

  [data-toggle-switch][aria-pressed="true"] [data-toggle-knob] {
    transform: translateX(1.75rem);
    background-color: white;
  }

  [data-toggle-switch][aria-pressed="true"] + [data-toggle-label="yearly"] {
    color: var(--color-text-secondary);
  }

  [data-toggle-switch][aria-pressed="false"] + [data-toggle-label="monthly"] {
    color: var(--color-text-secondary);
  }
</style>

<script>
  function initPricingToggle() {
    const toggles = document.querySelectorAll('[data-pricing-toggle]');

    toggles.forEach((container) => {
      const switchBtn = container.querySelector('[data-toggle-switch]');

      switchBtn?.addEventListener('click', () => {
        const isYearly = switchBtn.getAttribute('aria-pressed') === 'true';
        switchBtn.setAttribute('aria-pressed', (!isYearly).toString());

        // Dispatch event for pricing cards to update
        container.dispatchEvent(new CustomEvent('pricing:toggle', {
          bubbles: true,
          detail: { billing: isYearly ? 'monthly' : 'yearly' }
        }));
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricingToggle);
  } else {
    initPricingToggle();
  }

  document.addEventListener('astro:page-load', initPricingToggle);
</script>
