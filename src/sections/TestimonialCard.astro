---
/**
 * TestimonialCard Component - WenderMedia Astro Components
 *
 * Individual testimonial card.
 *
 * Features:
 * - Four display variants (card, minimal, social, large)
 * - Five-star rating display with filled/unfilled states
 * - Source platform icon (Twitter, LinkedIn, Google, Trustpilot)
 * - Initials fallback when no avatar image is provided
 * - Large variant for featured hero-style testimonials
 *
 * @example
 * <TestimonialCard
 *   quote="Acme Corp transformed our workflow. We shipped 3x faster after onboarding."
 *   name="Jane Doe"
 *   role="VP of Engineering"
 *   company="Widget Inc"
 *   avatar="/images/avatars/jane.jpg"
 *   rating={5}
 *   source="linkedin"
 * />
 *
 * @example
 * <TestimonialCard
 *   variant="large"
 *   quote="The best investment we made this year. Outstanding support and results."
 *   name="John Smith"
 *   role="Founder"
 *   company="Acme Corp"
 *   rating={5}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  quote: string;
  name: string;
  role?: string;
  company?: string;
  avatar?: string;
  rating?: 1 | 2 | 3 | 4 | 5;
  variant?: 'card' | 'minimal' | 'social' | 'large';
  source?: 'twitter' | 'linkedin' | 'google' | 'trustpilot';
  class?: string;
}

const {
  quote,
  name,
  role,
  company,
  avatar,
  rating,
  variant = 'card',
  source,
  class: className = '',
} = Astro.props;

// Generate initials
const initials = name
  .split(' ')
  .map(n => n[0])
  .join('')
  .toUpperCase()
  .slice(0, 2);

// Source icons
const sourceIcons = {
  twitter: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  linkedin: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  google: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>',
  trustpilot: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>',
};
---

<div
  class:list={[
    'testimonial-card',
    variant === 'card' && 'bg-surface border border-border-subtle rounded-xl p-6',
    variant === 'minimal' && 'p-4',
    variant === 'social' && 'bg-surface border border-border-subtle rounded-xl p-6',
    variant === 'large' && 'text-center py-8',
    className,
  ]}
  data-testimonial-card
>
  {/* Rating Stars */}
  {rating && (
    <div class="testimonial-rating flex gap-1 mb-4">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          class:list={[
            'w-5 h-5',
            i < rating ? 'text-yellow-400' : 'text-gray-300',
          ]}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  )}

  {/* Quote */}
  <blockquote class:list={[
    'testimonial-quote text-text-primary mb-6',
    variant === 'large' ? 'text-2xl lg:text-3xl font-medium italic' : 'text-base',
  ]}>
    {variant !== 'minimal' && <span class="text-primary text-4xl leading-none">"</span>}
    {quote}
    {variant !== 'minimal' && <span class="text-primary text-4xl leading-none">"</span>}
  </blockquote>

  {/* Author */}
  <div class:list={[
    'testimonial-author flex items-center gap-4',
    variant === 'large' && 'justify-center',
  ]}>
    {avatar ? (
      <img
        src={avatar}
        alt={name}
        class="w-12 h-12 rounded-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center font-semibold">
        {initials}
      </div>
    )}

    <div>
      <p class="font-semibold text-text-primary">{name}</p>
      {(role || company) && (
        <p class="text-sm text-text-tertiary">
          {role}{role && company && ', '}{company}
        </p>
      )}
    </div>

    {/* Source Icon */}
    {source && (
      <div class="ml-auto text-text-tertiary" set:html={sourceIcons[source]} />
    )}
  </div>
</div>

<style>
  .testimonial-quote {
    line-height: 1.7;
  }
</style>
