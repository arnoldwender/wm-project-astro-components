---
/**
 * TopBar Component - WenderMedia Astro Components
 *
 * Fixed utility navigation bar designed to sit above the main site header.
 * Displays contact information, social media links, and an optional language
 * switcher slot. Can be dismissed by the user via a close button.
 *
 * Features:
 * - Contact info: phone number and email with proper tel: and mailto: links
 * - Social media icon links with accessible labels
 * - Language switcher slot for custom implementations
 * - Two visual variants: light and dark
 * - Optional sticky positioning
 * - Dismissible with X button (persisted to sessionStorage)
 * - Fully keyboard accessible
 * - Dark mode support
 * - Responsive: stacks gracefully on mobile
 *
 * @example
 * <TopBar
 *   phone="+49 345 1234567"
 *   email="info@example.de"
 *   socialLinks={[
 *     { platform: 'facebook', url: 'https://facebook.com/example', label: 'Facebook' },
 *     { platform: 'instagram', url: 'https://instagram.com/example', label: 'Instagram' },
 *   ]}
 * />
 *
 * @example
 * <TopBar phone="+49 345 1234567" variant="dark" sticky>
 *   <Fragment slot="language-switcher">
 *     <a href="/de">DE</a> | <a href="/en">EN</a>
 *   </Fragment>
 * </TopBar>
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface SocialLink {
  /** Platform identifier for icon selection */
  platform: string;
  /** URL to the social profile */
  url: string;
  /** Accessible label for screen readers */
  label: string;
}

export interface Props {
  /** Phone number (displayed and used for tel: link) */
  phone?: string;
  /** Email address (displayed and used for mailto: link) */
  email?: string;
  /** Array of social media links */
  socialLinks?: SocialLink[];
  /** Show the language switcher slot area */
  showLanguageSwitcher?: boolean;
  /** Visual variant */
  variant?: 'light' | 'dark';
  /** Enable sticky positioning at page top */
  sticky?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  phone,
  email,
  socialLinks = [],
  showLanguageSwitcher = false,
  variant = 'light',
  sticky = false,
  class: className = '',
} = Astro.props;

/* Simple SVG icons for common social platforms */
const socialIcons: Record<string, string> = {
  facebook: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>',
  instagram: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
  twitter: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  linkedin: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  youtube: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>',
  xing: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.188 0c-.517 0-.741.325-.927.66 0 0-7.455 13.224-7.702 13.657.015.024 4.919 9.023 4.919 9.023.17.308.436.66.967.66h3.454c.211 0 .375-.078.463-.22.089-.151.089-.346-.009-.536l-4.879-8.916c-.004-.006-.004-.016 0-.022L22.139.756c.095-.191.097-.387.006-.535C22.056.078 21.894 0 21.686 0h-3.498zM3.648 4.74c-.211 0-.385.074-.473.216-.09.149-.078.339.02.531l2.34 4.05c.004.01.004.016 0 .021L3.169 13.9c-.09.185-.089.381 0 .529.087.142.252.22.463.22h3.455c.518 0 .766-.348.945-.667l2.405-4.414c-.015-.02-2.36-4.083-2.36-4.083-.165-.305-.435-.745-.964-.745H3.648z"/></svg>',
};
---

<div
  class:list={[
    'top-bar',
    `top-bar--${variant}`,
    sticky && 'top-bar--sticky',
    className,
  ]}
  data-top-bar
  role="banner"
>
  <div class="top-bar__inner">
    <!-- Contact info -->
    <div class="top-bar__contact">
      {phone && (
        <a href={`tel:${phone.replace(/\s/g, '')}`} class="top-bar__link" aria-label={`Anrufen: ${phone}`}>
          <svg class="top-bar__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          <span>{phone}</span>
        </a>
      )}
      {email && (
        <a href={`mailto:${email}`} class="top-bar__link" aria-label={`E-Mail: ${email}`}>
          <svg class="top-bar__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span>{email}</span>
        </a>
      )}
    </div>

    <!-- Right side: social + language + dismiss -->
    <div class="top-bar__actions">
      {/* Social links */}
      {socialLinks.length > 0 && (
        <nav class="top-bar__social" aria-label="Social media links">
          {socialLinks.map((link) => (
            <a
              href={link.url}
              class="top-bar__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
            >
              <span set:html={socialIcons[link.platform] || link.platform} />
            </a>
          ))}
        </nav>
      )}

      {/* Language switcher slot */}
      {showLanguageSwitcher && Astro.slots.has('language-switcher') && (
        <div class="top-bar__language" role="navigation" aria-label="Language selection">
          <slot name="language-switcher" />
        </div>
      )}

      {/* Dismiss button */}
      <button
        class="top-bar__dismiss"
        type="button"
        aria-label="Close top bar"
        data-top-bar-dismiss
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  /* Container */
  .top-bar {
    width: 100%;
    font-family: var(--font-family-body, system-ui, -apple-system, sans-serif);
    font-size: var(--font-size-xs, 0.75rem);
    z-index: 50;
    transition: transform var(--transition-fast, 150ms ease);
  }

  .top-bar--sticky {
    position: sticky;
    top: 0;
  }

  /* Hidden state via JS */
  .top-bar[data-dismissed] {
    display: none;
  }

  /* Inner layout */
  .top-bar__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-xs, 0.25rem) var(--space-lg, 1.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md, 1rem);
  }

  /* Contact section */
  .top-bar__contact {
    display: flex;
    align-items: center;
    gap: var(--space-md, 1rem);
  }

  .top-bar__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs, 0.25rem);
    text-decoration: none;
    font-weight: var(--font-weight-medium, 500);
    transition: opacity var(--transition-fast, 150ms ease);
  }

  .top-bar__link:hover {
    opacity: 0.8;
  }

  .top-bar__link:focus-visible {
    outline: 2px solid var(--color-primary, #3b82f6);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 0.25rem);
  }

  .top-bar__icon {
    flex-shrink: 0;
  }

  /* Actions section */
  .top-bar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md, 1rem);
  }

  /* Social links */
  .top-bar__social {
    display: flex;
    align-items: center;
    gap: var(--space-sm, 0.5rem);
  }

  .top-bar__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-sm, 0.25rem);
    transition: opacity var(--transition-fast, 150ms ease),
                background var(--transition-fast, 150ms ease);
  }

  .top-bar__social-link:hover {
    opacity: 0.8;
  }

  .top-bar__social-link:focus-visible {
    outline: 2px solid var(--color-primary, #3b82f6);
    outline-offset: 2px;
  }

  /* Language switcher slot area */
  .top-bar__language {
    display: flex;
    align-items: center;
    gap: var(--space-xs, 0.25rem);
    padding-left: var(--space-sm, 0.5rem);
    border-left: 1px solid currentColor;
    opacity: 0.5;
  }

  .top-bar__language :global(a) {
    text-decoration: none;
    font-weight: var(--font-weight-medium, 500);
    color: inherit;
  }

  .top-bar__language :global(a:hover) {
    opacity: 0.8;
  }

  /* Dismiss button */
  .top-bar__dismiss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    background: none;
    border: none;
    border-radius: var(--radius-sm, 0.25rem);
    cursor: pointer;
    color: inherit;
    opacity: 0.6;
    transition: opacity var(--transition-fast, 150ms ease),
                background var(--transition-fast, 150ms ease);
  }

  .top-bar__dismiss:hover {
    opacity: 1;
  }

  .top-bar__dismiss:focus-visible {
    outline: 2px solid var(--color-primary, #3b82f6);
    outline-offset: 2px;
    opacity: 1;
  }

  /* ---- Variant: light ---- */
  .top-bar--light {
    background: var(--color-bg-alt, #f7fafc);
    color: var(--color-text, #1a202c);
    border-bottom: 1px solid var(--color-border, #e2e8f0);
  }

  .top-bar--light .top-bar__link {
    color: var(--color-text, #1a202c);
  }

  .top-bar--light .top-bar__social-link {
    color: var(--color-text-light, #718096);
  }

  .top-bar--light .top-bar__social-link:hover {
    background: var(--color-border, #e2e8f0);
  }

  /* ---- Variant: dark ---- */
  .top-bar--dark {
    background: var(--color-text, #1a202c);
    color: var(--color-bg, #ffffff);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .top-bar--dark .top-bar__link {
    color: var(--color-bg, #ffffff);
  }

  .top-bar--dark .top-bar__social-link {
    color: rgba(255, 255, 255, 0.7);
  }

  .top-bar--dark .top-bar__social-link:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* ---- Dark mode overrides for light variant ---- */
  :global(.dark) .top-bar--light {
    background: var(--color-bg-alt, #2d3748);
    color: var(--color-text, #e2e8f0);
    border-color: var(--color-border, #4a5568);
  }

  :global(.dark) .top-bar--light .top-bar__link {
    color: var(--color-text, #e2e8f0);
  }

  :global(.dark) .top-bar--light .top-bar__social-link {
    color: var(--color-text-light, #a0aec0);
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .top-bar__inner {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-xs, 0.25rem);
    }

    .top-bar__contact {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-sm, 0.5rem);
    }

    /* Hide email on very small screens to save space */
    .top-bar__contact > :nth-child(2) {
      display: none;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .top-bar,
    .top-bar__link,
    .top-bar__social-link,
    .top-bar__dismiss {
      transition: none;
    }
  }
</style>

<script>
  /**
   * TopBar dismiss functionality.
   * Uses sessionStorage so the bar reappears on next session.
   */
  function initTopBars() {
    document.querySelectorAll<HTMLElement>('[data-top-bar]').forEach((bar) => {
      /* Restore dismissed state */
      if (sessionStorage.getItem('top-bar-dismissed') === 'true') {
        bar.setAttribute('data-dismissed', '');
        return;
      }

      const dismissBtn = bar.querySelector('[data-top-bar-dismiss]');
      if (!dismissBtn) return;

      dismissBtn.addEventListener('click', () => {
        bar.setAttribute('data-dismissed', '');
        sessionStorage.setItem('top-bar-dismissed', 'true');
        bar.dispatchEvent(new CustomEvent('topbar:dismiss', { bubbles: true }));
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTopBars);
  } else {
    initTopBars();
  }

  document.addEventListener('astro:page-load', initTopBars);
</script>
