---
/**
 * AuthSection Component - WenderMedia Astro Components
 *
 * Authentication pages (login, signup, forgot password, etc.)
 *
 * Variants:
 * - login: Standard login form
 * - signup: Registration form
 * - forgot: Password recovery
 * - reset: Password reset
 * - verify: Email/code verification
 * - mfa: Multi-factor authentication
 *
 * @example
 * <AuthSection
 *   variant="login"
 *   title="Welcome back"
 *   showSocials={true}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface SocialProvider {
  name: string;
  icon: string;
  href: string;
}

export interface Props {
  variant?: 'login' | 'signup' | 'forgot' | 'reset' | 'verify' | 'mfa';
  layout?: 'centered' | 'split' | 'card';
  title?: string;
  subtitle?: string;
  logo?: string;
  backgroundImage?: string;
  showSocials?: boolean;
  socialProviders?: SocialProvider[];
  showRemember?: boolean;
  showForgotPassword?: boolean;
  showTerms?: boolean;
  termsUrl?: string;
  privacyUrl?: string;
  loginUrl?: string;
  signupUrl?: string;
  redirectUrl?: string;
  class?: string;
}

const {
  variant = 'login',
  layout = 'centered',
  title,
  subtitle,
  logo,
  backgroundImage,
  showSocials = true,
  socialProviders = [
    { name: 'Google', icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>', href: '/auth/google' },
    { name: 'GitHub', icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>', href: '/auth/github' },
  ],
  showRemember = true,
  showForgotPassword = true,
  showTerms = true,
  termsUrl = '/terms',
  privacyUrl = '/privacy',
  loginUrl = '/login',
  signupUrl = '/signup',
  redirectUrl = '/',
  class: className = '',
} = Astro.props;

const defaultTitles: Record<string, string> = {
  login: 'Welcome back',
  signup: 'Create your account',
  forgot: 'Forgot password?',
  reset: 'Reset your password',
  verify: 'Verify your email',
  mfa: 'Two-factor authentication',
};

const defaultSubtitles: Record<string, string> = {
  login: 'Sign in to continue to your account',
  signup: 'Get started with a free account',
  forgot: "Enter your email and we'll send you a reset link",
  reset: 'Enter your new password below',
  verify: 'Enter the code we sent to your email',
  mfa: 'Enter the code from your authenticator app',
};

const displayTitle = title || defaultTitles[variant];
const displaySubtitle = subtitle || defaultSubtitles[variant];
---

<section
  class:list={[
    'auth-section',
    `auth-section--${layout}`,
    className,
  ]}
  style={backgroundImage && layout === 'split' ? `--bg-image: url(${backgroundImage})` : undefined}
>
  {/* Split layout background */}
  {layout === 'split' && (
    <div class="auth-background">
      {backgroundImage ? (
        <img src={backgroundImage} alt="" aria-hidden="true" class="bg-image" />
      ) : (
        <div class="bg-pattern" />
      )}
      <div class="bg-overlay" />
      <div class="bg-content">
        <slot name="background-content" />
      </div>
    </div>
  )}

  <div class="auth-container">
    <div class:list={['auth-card', layout === 'card' && 'auth-card--elevated']}>
      {/* Header */}
      <div class="auth-header">
        {logo && <img src={logo} alt="Logo" class="auth-logo" />}
        <h1 class="auth-title">{displayTitle}</h1>
        {displaySubtitle && <p class="auth-subtitle">{displaySubtitle}</p>}
      </div>

      {/* Social login */}
      {showSocials && (variant === 'login' || variant === 'signup') && socialProviders.length > 0 && (
        <div class="social-login">
          {socialProviders.map((provider) => (
            <a href={provider.href} class="social-btn">
              <span class="social-icon" set:html={provider.icon} />
              <span>Continue with {provider.name}</span>
            </a>
          ))}
        </div>
      )}

      {/* Divider */}
      {showSocials && (variant === 'login' || variant === 'signup') && (
        <div class="divider">
          <span>or continue with email</span>
        </div>
      )}

      {/* Login form */}
      {variant === 'login' && (
        <form class="auth-form" method="POST" action="/api/auth/login">
          <input type="hidden" name="redirect" value={redirectUrl} />

          <div class="form-group">
            <label for="email" class="form-label">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <div class="form-label-row">
              <label for="password" class="form-label">Password</label>
              {showForgotPassword && (
                <a href="/forgot-password" class="form-link">Forgot password?</a>
              )}
            </div>
            <div class="password-input">
              <input
                type="password"
                id="password"
                name="password"
                class="form-input"
                placeholder="••••••••"
                required
                autocomplete="current-password"
              />
              <button type="button" class="password-toggle" aria-label="Show password" data-password-toggle>
                <svg class="icon-show" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <svg class="icon-hide hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                </svg>
              </button>
            </div>
          </div>

          {showRemember && (
            <div class="form-checkbox">
              <input type="checkbox" id="remember" name="remember" />
              <label for="remember">Remember me for 30 days</label>
            </div>
          )}

          <button type="submit" class="btn btn--primary btn--full">
            Sign in
          </button>
        </form>
      )}

      {/* Signup form */}
      {variant === 'signup' && (
        <form class="auth-form" method="POST" action="/api/auth/signup">
          <input type="hidden" name="redirect" value={redirectUrl} />

          <div class="form-row">
            <div class="form-group">
              <label for="firstName" class="form-label">First name</label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                class="form-input"
                placeholder="John"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="form-group">
              <label for="lastName" class="form-label">Last name</label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                class="form-input"
                placeholder="Doe"
                required
                autocomplete="family-name"
              />
            </div>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <div class="password-input">
              <input
                type="password"
                id="password"
                name="password"
                class="form-input"
                placeholder="Create a password"
                required
                autocomplete="new-password"
                minlength="8"
              />
              <button type="button" class="password-toggle" aria-label="Show password" data-password-toggle>
                <svg class="icon-show" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <svg class="icon-hide hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                </svg>
              </button>
            </div>
            <p class="form-hint">Must be at least 8 characters</p>
          </div>

          {showTerms && (
            <div class="form-checkbox">
              <input type="checkbox" id="terms" name="terms" required />
              <label for="terms">
                I agree to the <a href={termsUrl}>Terms of Service</a> and <a href={privacyUrl}>Privacy Policy</a>
              </label>
            </div>
          )}

          <button type="submit" class="btn btn--primary btn--full">
            Create account
          </button>
        </form>
      )}

      {/* Forgot password form */}
      {variant === 'forgot' && (
        <form class="auth-form" method="POST" action="/api/auth/forgot-password">
          <div class="form-group">
            <label for="email" class="form-label">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>

          <button type="submit" class="btn btn--primary btn--full">
            Send reset link
          </button>

          <a href={loginUrl} class="back-link">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to login
          </a>
        </form>
      )}

      {/* Reset password form */}
      {variant === 'reset' && (
        <form class="auth-form" method="POST" action="/api/auth/reset-password">
          <div class="form-group">
            <label for="password" class="form-label">New password</label>
            <input
              type="password"
              id="password"
              name="password"
              class="form-input"
              placeholder="Enter new password"
              required
              autocomplete="new-password"
              minlength="8"
            />
          </div>

          <div class="form-group">
            <label for="confirmPassword" class="form-label">Confirm password</label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              class="form-input"
              placeholder="Confirm new password"
              required
              autocomplete="new-password"
            />
          </div>

          <button type="submit" class="btn btn--primary btn--full">
            Reset password
          </button>
        </form>
      )}

      {/* Verify form */}
      {variant === 'verify' && (
        <form class="auth-form" method="POST" action="/api/auth/verify">
          <div class="form-group">
            <label for="code" class="form-label">Verification code</label>
            <div class="code-inputs" data-code-inputs>
              <input type="text" maxlength="1" class="code-input" data-code-index="0" inputmode="numeric" pattern="[0-9]" required />
              <input type="text" maxlength="1" class="code-input" data-code-index="1" inputmode="numeric" pattern="[0-9]" required />
              <input type="text" maxlength="1" class="code-input" data-code-index="2" inputmode="numeric" pattern="[0-9]" required />
              <input type="text" maxlength="1" class="code-input" data-code-index="3" inputmode="numeric" pattern="[0-9]" required />
              <input type="text" maxlength="1" class="code-input" data-code-index="4" inputmode="numeric" pattern="[0-9]" required />
              <input type="text" maxlength="1" class="code-input" data-code-index="5" inputmode="numeric" pattern="[0-9]" required />
            </div>
            <input type="hidden" name="code" id="fullCode" />
          </div>

          <button type="submit" class="btn btn--primary btn--full">
            Verify
          </button>

          <p class="resend-text">
            Didn't receive a code? <button type="button" class="resend-btn">Resend</button>
          </p>
        </form>
      )}

      {/* MFA form */}
      {variant === 'mfa' && (
        <form class="auth-form" method="POST" action="/api/auth/mfa">
          <div class="mfa-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="48" height="48">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>

          <div class="form-group">
            <label for="mfaCode" class="form-label">Authentication code</label>
            <input
              type="text"
              id="mfaCode"
              name="code"
              class="form-input form-input--centered"
              placeholder="000000"
              maxlength="6"
              inputmode="numeric"
              pattern="[0-9]{6}"
              autocomplete="one-time-code"
              required
            />
          </div>

          <button type="submit" class="btn btn--primary btn--full">
            Verify
          </button>

          <a href="#" class="form-link form-link--center">
            Use backup code instead
          </a>
        </form>
      )}

      {/* Footer links */}
      <div class="auth-footer">
        {variant === 'login' && (
          <p>
            Don't have an account? <a href={signupUrl}>Sign up</a>
          </p>
        )}
        {variant === 'signup' && (
          <p>
            Already have an account? <a href={loginUrl}>Sign in</a>
          </p>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .auth-section {
    min-height: 100vh;
    display: flex;
    background: var(--color-background);
  }

  .auth-section--centered {
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .auth-section--card {
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--color-background-subtle);
  }

  .auth-section--split {
    flex-direction: row;
  }

  /* Split background */
  .auth-background {
    display: none;
    position: relative;
    flex: 1;
    background: var(--color-primary);
  }

  @media (min-width: 1024px) {
    .auth-section--split .auth-background {
      display: flex;
    }
  }

  .bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bg-pattern {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
  }

  .bg-content {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    color: white;
  }

  /* Container */
  .auth-container {
    width: 100%;
    max-width: 28rem;
    padding: 2rem;
  }

  .auth-section--split .auth-container {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    max-width: none;
  }

  .auth-card {
    width: 100%;
    max-width: 28rem;
  }

  .auth-card--elevated {
    background: var(--color-surface);
    border-radius: var(--radius-2xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-xl);
  }

  /* Header */
  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth-logo {
    height: 2.5rem;
    width: auto;
    margin-bottom: 1.5rem;
  }

  .auth-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-text-primary);
  }

  .auth-subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Social login */
  .social-login {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .social-btn:hover {
    background: var(--color-background-subtle);
    border-color: var(--color-border);
  }

  .social-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .social-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border-subtle);
  }

  .divider span {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  /* Form */
  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .form-link {
    font-size: 0.75rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .form-link:hover {
    text-decoration: underline;
  }

  .form-link--center {
    display: block;
    text-align: center;
    font-size: 0.875rem;
  }

  .form-input {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-alpha);
  }

  .form-input--centered {
    text-align: center;
    font-size: 1.5rem;
    letter-spacing: 0.5rem;
    font-family: ui-monospace, monospace;
  }

  .form-hint {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .password-input {
    position: relative;
  }

  .password-input .form-input {
    width: 100%;
    padding-right: 3rem;
  }

  .password-toggle {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    padding: 0.25rem;
    background: none;
    border: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
  }

  .password-toggle:hover {
    color: var(--color-text-secondary);
  }

  .password-toggle .hidden {
    display: none;
  }

  .form-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .form-checkbox input {
    width: 1rem;
    height: 1rem;
    margin-top: 0.125rem;
    accent-color: var(--color-primary);
  }

  .form-checkbox label {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .form-checkbox a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .form-checkbox a:hover {
    text-decoration: underline;
  }

  /* Code inputs */
  .code-inputs {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .code-input {
    width: 3rem;
    height: 3.5rem;
    text-align: center;
    font-size: 1.5rem;
    font-weight: 600;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    outline: none;
    transition: border-color 0.2s;
  }

  .code-input:focus {
    border-color: var(--color-primary);
  }

  /* MFA icon */
  .mfa-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: background 0.2s;
    border: none;
    text-decoration: none;
  }

  .btn--primary {
    background: var(--color-primary);
    color: white;
  }

  .btn--primary:hover {
    background: var(--color-primary-dark);
  }

  .btn--full {
    width: 100%;
  }

  /* Back link */
  .back-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-text-primary);
  }

  /* Resend */
  .resend-text {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .resend-btn {
    background: none;
    border: none;
    color: var(--color-primary);
    font-weight: 500;
    cursor: pointer;
    padding: 0;
  }

  .resend-btn:hover {
    text-decoration: underline;
  }

  /* Footer */
  .auth-footer {
    text-align: center;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  .auth-footer p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .auth-footer a {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: none;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .code-input {
      width: 2.5rem;
      height: 3rem;
      font-size: 1.25rem;
    }
  }
</style>

<script>
  function initAuthForms() {
    // Password toggle
    const passwordToggles = document.querySelectorAll('[data-password-toggle]');
    passwordToggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const input = toggle.parentElement?.querySelector('input');
        const showIcon = toggle.querySelector('.icon-show');
        const hideIcon = toggle.querySelector('.icon-hide');

        if (input) {
          const isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          showIcon?.classList.toggle('hidden', !isPassword);
          hideIcon?.classList.toggle('hidden', isPassword);
        }
      });
    });

    // Code inputs
    const codeContainers = document.querySelectorAll('[data-code-inputs]');
    codeContainers.forEach((container) => {
      const inputs = container.querySelectorAll('.code-input');
      const fullCodeInput = container.parentElement?.querySelector('#fullCode') as HTMLInputElement;

      inputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
          const target = e.target as HTMLInputElement;
          const value = target.value;

          if (value && index < inputs.length - 1) {
            (inputs[index + 1] as HTMLInputElement).focus();
          }

          // Update hidden input
          if (fullCodeInput) {
            const code = Array.from(inputs).map((i) => (i as HTMLInputElement).value).join('');
            fullCodeInput.value = code;
          }
        });

        input.addEventListener('keydown', (e) => {
          const target = e.target as HTMLInputElement;

          if (e.key === 'Backspace' && !target.value && index > 0) {
            (inputs[index - 1] as HTMLInputElement).focus();
          }
        });

        // Handle paste
        input.addEventListener('paste', (e) => {
          e.preventDefault();
          const pastedData = e.clipboardData?.getData('text').slice(0, inputs.length) || '';

          pastedData.split('').forEach((char, i) => {
            if (inputs[i]) {
              (inputs[i] as HTMLInputElement).value = char;
            }
          });

          const lastFilledIndex = Math.min(pastedData.length, inputs.length) - 1;
          if (lastFilledIndex >= 0) {
            (inputs[lastFilledIndex] as HTMLInputElement).focus();
          }

          // Update hidden input
          if (fullCodeInput) {
            fullCodeInput.value = pastedData;
          }
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAuthForms);
  } else {
    initAuthForms();
  }

  document.addEventListener('astro:page-load', initAuthForms);
</script>
