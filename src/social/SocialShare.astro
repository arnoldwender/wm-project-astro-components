    icon: '<path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>',
  },
  copy: {
    name: 'Link kopieren',
    color: '#6b7280',
    shareUrl: '', // Handled by JavaScript
    icon: '<path d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75"/>',
  },
};

// Size configurations
const sizeClasses = {
  sm: { button: 'p-2 text-sm', icon: 'w-4 h-4' },
  md: { button: 'p-3 text-base', icon: 'w-5 h-5' },
  lg: { button: 'p-4 text-lg', icon: 'w-6 h-6' },
};
---

<div
  class:list={[
    'social-share',
    `social-share--${variant}`,
    `social-share--${size}`,
    `social-share--${direction}`,
    className,
  ]}
  data-url={url}
  data-title={title}
  data-copied-label={copiedLabel}
>
  {showConsent && (
    <p class="consent-notice">{consentText}</p>
  )}

  <div class="share-buttons">
    {platforms.map((platform) => {
      const config = platformConfig[platform];
      if (!config) return null;

      return (
        <button
          type="button"
          class="share-button"
          data-platform={platform}
          data-share-url={config.shareUrl}
          style={`--platform-color: ${config.color};`}
          aria-label={`${shareLabel} auf ${config.name}`}
          title={config.name}
        >
          <svg
            class={`share-icon ${sizeClasses[size].icon}`}
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <Fragment set:html={config.icon} />
          </svg>
          {variant === 'buttons' && (
            <span class="share-label">{config.name}</span>
          )}
        </button>
      );
    })}
  </div>
</div>

<style>
  .social-share {
    --share-gap: 0.5rem;
    --share-radius: 0.375rem;
  }

  .consent-notice {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    color: #6b7280;
    line-height: 1.4;
  }

  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--share-gap);
  }

  .social-share--vertical .share-buttons {
    flex-direction: column;
  }

  .share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: var(--share-radius);
    color: #374151;
    font-size: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .share-button:hover {
    background: var(--platform-color);
    border-color: var(--platform-color);
    color: white;
  }

  .share-button:focus-visible {
    outline: 2px solid var(--platform-color);
    outline-offset: 2px;
  }

  .share-button.copied {
    background: #10b981;
    border-color: #10b981;
    color: white;
  }

  /* Icons variant */
  .social-share--icons .share-button {
    padding: 0.75rem;
  }

  .social-share--icons .share-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  /* Minimal variant */
  .social-share--minimal .share-button {
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: #6b7280;
  }

  .social-share--minimal .share-button:hover {
    color: var(--platform-color);
    background: transparent;
  }

  .social-share--minimal .share-label {
    display: none;
  }

  /* Size variants */
  .social-share--sm .share-button {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
  }

  .social-share--sm.social-share--icons .share-button,
  .social-share--sm.social-share--minimal .share-button {
    padding: 0.5rem;
  }

  .social-share--lg .share-button {
    padding: 0.875rem 1.25rem;
    font-size: 1rem;
  }

  .social-share--lg.social-share--icons .share-button,
  .social-share--lg.social-share--minimal .share-button {
    padding: 1rem;
  }

  .share-icon {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .social-share--buttons .share-label {
      display: none;
    }

    .social-share--buttons .share-button {
      padding: 0.75rem;
    }
  }
</style>

<script>
  function initSocialShare() {
    const containers = document.querySelectorAll('.social-share');

    containers.forEach((container) => {
      const url = container.getAttribute('data-url') || window.location.href;
      const title = container.getAttribute('data-title') || document.title;
      const copiedLabel = container.getAttribute('data-copied-label') || 'Copied!';
      const buttons = container.querySelectorAll('.share-button');

      buttons.forEach((button) => {
        button.addEventListener('click', async (e) => {
          e.preventDefault();

          const platform = button.getAttribute('data-platform');
          const shareUrl = button.getAttribute('data-share-url');

          if (platform === 'copy') {
            // Copy to clipboard
            try {
              await navigator.clipboard.writeText(url);

              // Show feedback
              const originalLabel = button.querySelector('.share-label')?.textContent;
              const labelEl = button.querySelector('.share-label');

              button.classList.add('copied');
              if (labelEl) labelEl.textContent = copiedLabel;

              setTimeout(() => {
                button.classList.remove('copied');
                if (labelEl && originalLabel) labelEl.textContent = originalLabel;
              }, 2000);
            } catch (err) {
              // Fallback for older browsers
              const input = document.createElement('input');
              input.value = url;
              document.body.appendChild(input);
              input.select();
              document.execCommand('copy');
              document.body.removeChild(input);

              button.classList.add('copied');
              setTimeout(() => button.classList.remove('copied'), 2000);
            }
          } else if (shareUrl) {
            // Open share dialog
            const width = 600;
            const height = 400;
            const left = (window.innerWidth - width) / 2;
            const top = (window.innerHeight - height) / 2;

            // Email doesn't need popup
            if (platform === 'email') {
              window.location.href = shareUrl;
            } else {
              window.open(
                shareUrl,
                'share',
                `width=${width},height=${height},left=${left},top=${top},toolbar=no,menubar=no`
              );
            }
          }
        });
      });
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSocialShare);
  } else {
    initSocialShare();
  }

  // Re-initialize after Astro page transitions
  document.addEventListener('astro:page-load', initSocialShare);
</script>
