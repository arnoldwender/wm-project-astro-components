---
/**
 * DSGVO-Compliant Social Share Buttons - WenderMedia Astro Components
 *
 * Two-click solution: First click shows consent info, second click shares.
 * No external scripts or tracking until user actively shares.
 *
 * This follows the "Shariff" approach for privacy-friendly sharing.
 *
 * Usage:
 * <SocialShare
 *   url={Astro.url.href}
 *   title="Page Title"
 *   description="Page description"
 *   platforms={['facebook', 'twitter', 'linkedin', 'email']}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

type Platform =
  | 'facebook'
  | 'twitter'
  | 'linkedin'
  | 'xing'
  | 'whatsapp'
  | 'telegram'
  | 'email'
  | 'pinterest'
  | 'reddit'
  | 'copy';

export interface Props {
  // Required
  url: string;
  title: string;

  // Optional
  description?: string;
  image?: string;
  hashtags?: string[];
  via?: string; // Twitter username

  // Platforms to show
  platforms?: Platform[];

  // Styling
  class?: string;
  variant?: 'buttons' | 'icons' | 'minimal';
  size?: 'sm' | 'md' | 'lg';
  direction?: 'horizontal' | 'vertical';

  // Labels
  shareLabel?: string;
  copiedLabel?: string;

  // DSGVO
  showConsent?: boolean;
  consentText?: string;
}

const {
  url,
  title,
  description = '',
  image = '',
  hashtags = [],
  via = '',
  platforms = ['facebook', 'twitter', 'linkedin', 'email', 'copy'],
  class: className = '',
  variant = 'buttons',
  size = 'md',
  direction = 'horizontal',
  shareLabel = 'Teilen',
  copiedLabel = 'Kopiert!',
  showConsent = true,
  consentText = 'Beim Teilen werden Daten an den jeweiligen Dienst übertragen.',
} = Astro.props;

// Encode URL parameters
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);
const encodedHashtags = hashtags.join(',');

// Platform configurations
const platformConfig: Record<Platform, { name: string; color: string; shareUrl: string; icon: string }> = {
  facebook: {
    name: 'Facebook',
    color: '#1877f2',
