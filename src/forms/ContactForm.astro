---
/**
 * ContactForm Component - WenderMedia Astro Components
 *
 * GDPR-compliant contact form with validation
 * Features: honeypot spam protection, real-time validation, accessible
 */

export interface Props {
  action?: string;
  nameLabel?: string;
  emailLabel?: string;
  messageLabel?: string;
  consentText?: string;
  privacyUrl?: string;
  submitLabel?: string;
  successMessage?: string;
  errorMessage?: string;
  class?: string;
}

const {
  action = '/api/contact',
  nameLabel = 'Name',
  emailLabel = 'Email',
  messageLabel = 'Message',
  consentText = 'I consent to the processing of my personal data for responding to my inquiry.',
  privacyUrl = '/privacy-policy',
  submitLabel = 'Send Message',
  successMessage = 'Thank you! Your message has been sent successfully.',
  errorMessage = 'Failed to send message. Please try again.',
  class: className = '',
} = Astro.props;
---

<form class:list={["contact-form space-y-6", className]} data-contact-form data-action={action} data-success={successMessage} data-error={errorMessage}>
  <div>
    <label for="contact-name" class="block text-sm font-medium mb-2">
      {nameLabel} *
    </label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
      aria-describedby="name-error"
    />
    <div id="name-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
  </div>

  <div>
    <label for="contact-email" class="block text-sm font-medium mb-2">
      {emailLabel} *
    </label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
      aria-describedby="email-error"
    />
    <div id="email-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
  </div>

  <div>
    <label for="contact-message" class="block text-sm font-medium mb-2">
      {messageLabel} *
    </label>
    <textarea
      id="contact-message"
      name="message"
      rows="4"
      required
      class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
      aria-describedby="message-error"
    ></textarea>
    <div id="message-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
  </div>

  <div>
    <label class="flex items-start space-x-2">
      <input
        type="checkbox"
        id="contact-consent"
        name="consent"
        required
        class="mt-1 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
      />
      <span class="text-sm">
        {consentText}
        <a href={privacyUrl} class="text-blue-600 hover:text-blue-800 underline">Privacy Policy</a>
      </span>
    </label>
    <div id="consent-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
  </div>

  <!-- Honeypot for spam protection -->
  <input type="text" name="honeypot" style="display: none;" tabindex="-1" autocomplete="off" />

  <div>
    <button
      type="submit"
      class="w-full bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      {submitLabel}
    </button>
  </div>

  <div class="form-status hidden" role="status" aria-live="polite"></div>
</form>

<script>
  function initContactForm() {
    const forms = document.querySelectorAll('[data-contact-form]');

    forms.forEach(form => {
      const action = form.getAttribute('data-action') || '/api/contact';
      const successMsg = form.getAttribute('data-success') || 'Message sent successfully!';
      const errorMsg = form.getAttribute('data-error') || 'Failed to send message.';

      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const formStatus = form.querySelector('.form-status') as HTMLDivElement;

      function validateField(field: HTMLInputElement | HTMLTextAreaElement, errorId: string): boolean {
        const errorElement = document.getElementById(errorId);
        if (!errorElement) return true;

        if (!field.value.trim()) {
          showError(field, errorElement, 'This field is required');
          return false;
        }

        if (field.type === 'email' && !isValidEmail(field.value)) {
          showError(field, errorElement, 'Please enter a valid email address');
          return false;
        }

        hideError(field, errorElement);
        return true;
      }

      function isValidEmail(email: string): boolean {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      }

      function showError(field: HTMLElement, errorElement: HTMLElement, message: string) {
        field.setAttribute('aria-invalid', 'true');
        errorElement.textContent = message;
        errorElement.classList.remove('hidden');
        field.classList.add('border-red-500');
      }

      function hideError(field: HTMLElement, errorElement: HTMLElement) {
        field.setAttribute('aria-invalid', 'false');
        errorElement.textContent = '';
        errorElement.classList.add('hidden');
        field.classList.remove('border-red-500');
      }

      // Real-time validation
      ['contact-name', 'contact-email', 'contact-message'].forEach(fieldId => {
        const field = form.querySelector(`#${fieldId}`) as HTMLInputElement | HTMLTextAreaElement;
        if (field) {
          field.addEventListener('blur', () => {
            validateField(field, fieldId.replace('contact-', '') + '-error');
          });
        }
      });

      // Form submission
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const nameField = form.querySelector('#contact-name') as HTMLInputElement;
        const emailField = form.querySelector('#contact-email') as HTMLInputElement;
        const messageField = form.querySelector('#contact-message') as HTMLTextAreaElement;
        const consentField = form.querySelector('#contact-consent') as HTMLInputElement;

        const isNameValid = validateField(nameField, 'name-error');
        const isEmailValid = validateField(emailField, 'email-error');
        const isMessageValid = validateField(messageField, 'message-error');

        const consentError = document.getElementById('consent-error');
        let isConsentValid = true;
        if (!consentField.checked) {
          if (consentError) {
            consentError.textContent = 'You must consent to data processing';
            consentError.classList.remove('hidden');
          }
          isConsentValid = false;
        } else if (consentError) {
          consentError.classList.add('hidden');
        }

        if (!isNameValid || !isEmailValid || !isMessageValid || !isConsentValid) {
          const firstInvalid = form.querySelector('[aria-invalid="true"]') as HTMLElement;
          firstInvalid?.focus();
          return;
        }

        submitButton.disabled = true;
        const originalText = submitButton.textContent;
        submitButton.textContent = 'Sending...';

        try {
          const formData = new FormData(form as HTMLFormElement);
          const response = await fetch(action, {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            formStatus.className = 'form-status p-4 bg-green-50 border border-green-200 rounded-md text-green-800';
            formStatus.textContent = successMsg;
            (form as HTMLFormElement).reset();
          } else {
            throw new Error(errorMsg);
          }
        } catch (error) {
          formStatus.className = 'form-status p-4 bg-red-50 border border-red-200 rounded-md text-red-800';
          formStatus.textContent = error instanceof Error ? error.message : errorMsg;
        } finally {
          formStatus.classList.remove('hidden');
          submitButton.disabled = false;
          submitButton.textContent = originalText;
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }

  document.addEventListener('astro:page-load', initContactForm);
</script>
