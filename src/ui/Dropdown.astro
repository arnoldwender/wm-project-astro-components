---
/**
 * Dropdown/Select Component
 *
 * Accessible dropdown menu and select component following WAI-ARIA patterns.
 *
 * Features:
 * - Full keyboard navigation (arrow keys, Home, End, type-ahead)
 * - Multiple selection support
 * - Grouped options
 * - Search/filter
 * - Custom option rendering
 * - Form integration with hidden input
 * - Reduced motion support
 *
 * @example
 * <Dropdown
 *   name="country"
 *   label="Select Country"
 *   options={[
 *     { value: 'us', label: 'United States', icon: '🇺🇸' },
 *     { value: 'uk', label: 'United Kingdom', icon: '🇬🇧' },
 *     { value: 'de', label: 'Germany', icon: '🇩🇪' },
 *   ]}
 *   placeholder="Choose a country"
 * />
 */

export interface DropdownOption {
  value: string;
  label: string;
  icon?: string;
  description?: string;
  disabled?: boolean;
  group?: string;
}

export interface Props {
  name: string;
  label?: string;
  options: DropdownOption[];
  value?: string | string[];
  placeholder?: string;
  multiple?: boolean;
  searchable?: boolean;
  searchPlaceholder?: string;
  disabled?: boolean;
  required?: boolean;
  error?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'ghost' | 'outline';
  maxHeight?: string;
  class?: string;
}

const {
  name,
  label,
  options,
  value,
  placeholder = 'Select an option',
  multiple = false,
  searchable = false,
  searchPlaceholder = 'Search...',
  disabled = false,
  required = false,
  error,
  size = 'md',
  variant = 'default',
  maxHeight = '300px',
  class: className = '',
} = Astro.props;

const id = `dropdown-${name}`;
const labelId = `${id}-label`;
const listboxId = `${id}-listbox`;

const sizeClasses = {
  sm: 'h-8 text-sm px-2.5',
  md: 'h-10 text-base px-3',
  lg: 'h-12 text-lg px-4',
};

const variantClasses = {
  default: 'bg-background border border-border-default hover:border-border-strong',
  ghost: 'bg-transparent hover:bg-background-subtle',
  outline: 'bg-transparent border-2 border-border-default hover:border-primary',
};

// Group options
const groupedOptions = options.reduce((groups, option) => {
  const group = option.group || '';
  if (!groups[group]) groups[group] = [];
  groups[group].push(option);
  return groups;
}, {} as Record<string, DropdownOption[]>);

const hasGroups = Object.keys(groupedOptions).some(g => g !== '');
---

<div
  class:list={['dropdown-root relative', className]}
  data-dropdown
  data-name={name}
  data-multiple={multiple}
  data-searchable={searchable}
  data-disabled={disabled}
>
  {/* Hidden input for form submission */}
  <input
    type="hidden"
    name={name}
    value={Array.isArray(value) ? value.join(',') : value || ''}
    data-dropdown-input
  />

  {/* Label */}
  {label && (
    <label
      id={labelId}
      class="block text-sm font-medium text-text-primary mb-1.5"
    >
      {label}
      {required && <span class="text-error ml-0.5">*</span>}
    </label>
  )}

  {/* Trigger Button */}
  <button
    type="button"
    id={id}
    class:list={[
      'dropdown-trigger flex items-center justify-between w-full rounded-md transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring',
      sizeClasses[size],
      variantClasses[variant],
      disabled && 'opacity-50 cursor-not-allowed',
      error && 'border-error',
    ]}
    role="combobox"
    aria-expanded="false"
    aria-haspopup="listbox"
    aria-labelledby={label ? labelId : undefined}
    aria-controls={listboxId}
    aria-disabled={disabled}
    data-dropdown-trigger
  >
    <span class="dropdown-value truncate text-left" data-dropdown-value>
      <span class="text-text-muted">{placeholder}</span>
    </span>
    <svg
      class="dropdown-chevron w-4 h-4 ml-2 text-text-tertiary transition-transform duration-200"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      data-dropdown-chevron
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  {/* Error message */}
  {error && (
    <p class="mt-1 text-sm text-error" role="alert">
      {error}
    </p>
  )}

  {/* Dropdown Panel */}
  <div
    class="dropdown-panel absolute z-dropdown w-full mt-1 bg-surface rounded-lg shadow-dropdown border border-border-default opacity-0 invisible transform -translate-y-2 transition-all duration-200"
    data-dropdown-panel
  >
    {/* Search Input */}
    {searchable && (
      <div class="p-2 border-b border-border-subtle">
        <input
          type="text"
          class="w-full px-3 py-2 text-sm bg-background-subtle rounded-md border border-border-subtle focus:outline-none focus:border-primary"
          placeholder={searchPlaceholder}
          data-dropdown-search
          aria-label="Search options"
        />
      </div>
    )}

    {/* Options List */}
    <ul
      id={listboxId}
      role="listbox"
      aria-labelledby={label ? labelId : id}
      aria-multiselectable={multiple}
      class="py-1 overflow-y-auto"
      style={`max-height: ${maxHeight}`}
      data-dropdown-listbox
    >
      {hasGroups ? (
        Object.entries(groupedOptions).map(([group, groupOptions]) => (
          <li role="presentation">
            {group && (
              <div class="px-3 py-2 text-xs font-semibold text-text-tertiary uppercase tracking-wider">
                {group}
              </div>
            )}
            <ul role="group" aria-label={group || undefined}>
              {groupOptions.map((option, index) => (
                <li
                  role="option"
                  aria-selected="false"
                  aria-disabled={option.disabled}
                  class:list={[
                    'dropdown-option flex items-center gap-3 px-3 py-2 cursor-pointer transition-colors',
                    'hover:bg-background-subtle focus:bg-background-subtle focus:outline-none',
                    option.disabled && 'opacity-50 cursor-not-allowed pointer-events-none',
                  ]}
                  data-dropdown-option
                  data-value={option.value}
                  data-label={option.label}
                  tabindex="-1"
                >
                  {multiple && (
                    <span class="dropdown-checkbox w-4 h-4 rounded border border-border-strong flex items-center justify-center transition-colors" data-dropdown-checkbox>
                      <svg class="w-3 h-3 text-white opacity-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </span>
                  )}
                  {option.icon && <span class="flex-shrink-0">{option.icon}</span>}
                  <div class="flex-1 min-w-0">
                    <div class="truncate">{option.label}</div>
                    {option.description && (
                      <div class="text-xs text-text-tertiary truncate">{option.description}</div>
                    )}
                  </div>
                  {!multiple && (
                    <svg class="dropdown-check w-4 h-4 text-primary opacity-0" fill="currentColor" viewBox="0 0 20 20" data-dropdown-check>
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  )}
                </li>
              ))}
            </ul>
          </li>
        ))
      ) : (
        options.map((option) => (
          <li
            role="option"
            aria-selected="false"
            aria-disabled={option.disabled}
            class:list={[
              'dropdown-option flex items-center gap-3 px-3 py-2 cursor-pointer transition-colors',
              'hover:bg-background-subtle focus:bg-background-subtle focus:outline-none',
              option.disabled && 'opacity-50 cursor-not-allowed pointer-events-none',
            ]}
            data-dropdown-option
            data-value={option.value}
            data-label={option.label}
            tabindex="-1"
          >
            {multiple && (
              <span class="dropdown-checkbox w-4 h-4 rounded border border-border-strong flex items-center justify-center transition-colors" data-dropdown-checkbox>
                <svg class="w-3 h-3 text-white opacity-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
            )}
            {option.icon && <span class="flex-shrink-0">{option.icon}</span>}
            <div class="flex-1 min-w-0">
              <div class="truncate">{option.label}</div>
              {option.description && (
                <div class="text-xs text-text-tertiary truncate">{option.description}</div>
              )}
            </div>
            {!multiple && (
              <svg class="dropdown-check w-4 h-4 text-primary opacity-0" fill="currentColor" viewBox="0 0 20 20" data-dropdown-check>
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            )}
          </li>
        ))
      )}

      {/* Empty state */}
      <li class="dropdown-empty hidden px-3 py-6 text-center text-sm text-text-muted" data-dropdown-empty>
        No options found
      </li>
    </ul>
  </div>
</div>

<style>
  .dropdown-panel.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-chevron.open {
    transform: rotate(180deg);
  }

  .dropdown-option[aria-selected="true"] {
    background-color: var(--color-background-subtle);
  }

  .dropdown-option[aria-selected="true"] .dropdown-check {
    opacity: 1;
  }

  .dropdown-option[aria-selected="true"] .dropdown-checkbox {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .dropdown-option[aria-selected="true"] .dropdown-checkbox svg {
    opacity: 1;
  }

  .dropdown-option:focus {
    background-color: var(--color-background-subtle);
  }

  @media (prefers-reduced-motion: reduce) {
    .dropdown-panel,
    .dropdown-chevron {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  function initDropdown(dropdown: HTMLElement) {
    const trigger = dropdown.querySelector('[data-dropdown-trigger]') as HTMLButtonElement;
    const panel = dropdown.querySelector('[data-dropdown-panel]') as HTMLElement;
    const chevron = dropdown.querySelector('[data-dropdown-chevron]') as HTMLElement;
    const listbox = dropdown.querySelector('[data-dropdown-listbox]') as HTMLElement;
    const input = dropdown.querySelector('[data-dropdown-input]') as HTMLInputElement;
    const valueDisplay = dropdown.querySelector('[data-dropdown-value]') as HTMLElement;
    const searchInput = dropdown.querySelector('[data-dropdown-search]') as HTMLInputElement;
    const emptyState = dropdown.querySelector('[data-dropdown-empty]') as HTMLElement;
    const options = Array.from(dropdown.querySelectorAll('[data-dropdown-option]')) as HTMLElement[];

    const isMultiple = dropdown.dataset.multiple === 'true';
    const isSearchable = dropdown.dataset.searchable === 'true';
    const isDisabled = dropdown.dataset.disabled === 'true';

    let isOpen = false;
    let focusedIndex = -1;
    let selectedValues: string[] = [];
    let typeaheadBuffer = '';
    let typeaheadTimeout: number;

    // Initialize with existing value
    if (input.value) {
      selectedValues = input.value.split(',').filter(Boolean);
      updateDisplay();
      updateOptionStates();
    }

    function open() {
      if (isDisabled) return;
      isOpen = true;
      trigger.setAttribute('aria-expanded', 'true');
      panel.classList.add('open');
      chevron.classList.add('open');

      if (isSearchable && searchInput) {
        searchInput.value = '';
        filterOptions('');
        searchInput.focus();
      } else {
        focusOption(selectedValues.length > 0 ? options.findIndex(o => o.dataset.value === selectedValues[0]) : 0);
      }

      document.addEventListener('click', handleOutsideClick);
      dropdown.dispatchEvent(new CustomEvent('dropdown:open', { bubbles: true }));
    }

    function close() {
      isOpen = false;
      trigger.setAttribute('aria-expanded', 'false');
      panel.classList.remove('open');
      chevron.classList.remove('open');
      focusedIndex = -1;
      trigger.focus();
      document.removeEventListener('click', handleOutsideClick);
      dropdown.dispatchEvent(new CustomEvent('dropdown:close', { bubbles: true }));
    }

    function toggle() {
      isOpen ? close() : open();
    }

    function handleOutsideClick(e: MouseEvent) {
      if (!dropdown.contains(e.target as Node)) {
        close();
      }
    }

    function focusOption(index: number) {
      const visibleOptions = options.filter(o => !o.classList.contains('hidden'));
      if (index < 0) index = visibleOptions.length - 1;
      if (index >= visibleOptions.length) index = 0;

      visibleOptions.forEach((opt, i) => {
        if (i === index) {
          opt.focus();
          opt.scrollIntoView({ block: 'nearest' });
          focusedIndex = options.indexOf(opt);
        }
      });
    }

    function selectOption(option: HTMLElement) {
      const value = option.dataset.value!;
      const label = option.dataset.label!;

      if (isMultiple) {
        const index = selectedValues.indexOf(value);
        if (index > -1) {
          selectedValues.splice(index, 1);
        } else {
          selectedValues.push(value);
        }
      } else {
        selectedValues = [value];
        close();
      }

      updateInput();
      updateDisplay();
      updateOptionStates();

      dropdown.dispatchEvent(new CustomEvent('dropdown:change', {
        bubbles: true,
        detail: { value: isMultiple ? selectedValues : selectedValues[0] }
      }));
    }

    function updateInput() {
      input.value = selectedValues.join(',');
      input.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function updateDisplay() {
      if (selectedValues.length === 0) {
        valueDisplay.innerHTML = `<span class="text-text-muted">${trigger.dataset.placeholder || 'Select an option'}</span>`;
      } else if (isMultiple) {
        valueDisplay.textContent = `${selectedValues.length} selected`;
      } else {
        const selected = options.find(o => o.dataset.value === selectedValues[0]);
        valueDisplay.textContent = selected?.dataset.label || selectedValues[0];
      }
    }

    function updateOptionStates() {
      options.forEach(option => {
        const isSelected = selectedValues.includes(option.dataset.value!);
        option.setAttribute('aria-selected', isSelected.toString());
      });
    }

    function filterOptions(query: string) {
      const lowerQuery = query.toLowerCase();
      let hasVisible = false;

      options.forEach(option => {
        const label = option.dataset.label!.toLowerCase();
        const matches = label.includes(lowerQuery);
        option.classList.toggle('hidden', !matches);
        if (matches) hasVisible = true;
      });

      emptyState?.classList.toggle('hidden', hasVisible);
    }

    function handleTypeahead(char: string) {
      typeaheadBuffer += char.toLowerCase();
      clearTimeout(typeaheadTimeout);
      typeaheadTimeout = window.setTimeout(() => {
        typeaheadBuffer = '';
      }, 500);

      const match = options.find(o =>
        o.dataset.label!.toLowerCase().startsWith(typeaheadBuffer) &&
        !o.classList.contains('hidden')
      );

      if (match) {
        focusOption(options.indexOf(match));
      }
    }

    // Event handlers
    trigger.addEventListener('click', toggle);

    trigger.addEventListener('keydown', (e) => {
      if (['Enter', ' ', 'ArrowDown', 'ArrowUp'].includes(e.key)) {
        e.preventDefault();
        if (!isOpen) {
          open();
          if (e.key === 'ArrowUp') {
            focusOption(options.length - 1);
          }
        }
      }
    });

    listbox.addEventListener('keydown', (e) => {
      const visibleOptions = options.filter(o => !o.classList.contains('hidden'));
      const currentIndex = visibleOptions.findIndex(o => o === document.activeElement);

      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          focusOption(currentIndex + 1);
          break;
        case 'ArrowUp':
          e.preventDefault();
          focusOption(currentIndex - 1);
          break;
        case 'Home':
          e.preventDefault();
          focusOption(0);
          break;
        case 'End':
          e.preventDefault();
          focusOption(visibleOptions.length - 1);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          if (document.activeElement?.hasAttribute('data-dropdown-option')) {
            selectOption(document.activeElement as HTMLElement);
          }
          break;
        case 'Escape':
          e.preventDefault();
          close();
          break;
        default:
          if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !isSearchable) {
            handleTypeahead(e.key);
          }
      }
    });

    options.forEach(option => {
      option.addEventListener('click', () => {
        if (option.getAttribute('aria-disabled') !== 'true') {
          selectOption(option);
        }
      });
    });

    searchInput?.addEventListener('input', (e) => {
      filterOptions((e.target as HTMLInputElement).value);
    });

    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        focusOption(0);
      } else if (e.key === 'Escape') {
        e.preventDefault();
        close();
      }
    });
  }

  function initAllDropdowns() {
    document.querySelectorAll('[data-dropdown]').forEach(dropdown => {
      initDropdown(dropdown as HTMLElement);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllDropdowns);
  } else {
    initAllDropdowns();
  }

  document.addEventListener('astro:page-load', initAllDropdowns);
</script>
