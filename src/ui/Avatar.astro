---
/**
 * Avatar Component
 *
 * User avatar with image, initials, or icon fallback.
 *
 * Features:
 * - Image with lazy loading
 * - Initials fallback
 * - Icon fallback
 * - Multiple sizes
 * - Status indicator
 * - Group/stack support
 * - Border ring for emphasis
 *
 * @example
 * <Avatar src="/user.jpg" alt="John Doe" size="lg" />
 * <Avatar name="John Doe" />
 * <Avatar status="online" />
 */

export interface Props {
  src?: string;
  alt?: string;
  name?: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  status?: 'online' | 'offline' | 'busy' | 'away';
  ring?: boolean;
  ringColor?: 'primary' | 'success' | 'warning' | 'error' | 'white';
  square?: boolean;
  class?: string;
}

const {
  src,
  alt = '',
  name,
  size = 'md',
  status,
  ring = false,
  ringColor = 'white',
  square = false,
  class: className = '',
} = Astro.props;

// Get initials from name
const getInitials = (name: string) => {
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0].charAt(0).toUpperCase();
  return (parts[0].charAt(0) + parts[parts.length - 1].charAt(0)).toUpperCase();
};

const initials = name ? getInitials(name) : '';

// Size classes
const sizeClasses = {
  xs: 'w-6 h-6 text-xs',
  sm: 'w-8 h-8 text-sm',
  md: 'w-10 h-10 text-base',
  lg: 'w-12 h-12 text-lg',
  xl: 'w-16 h-16 text-xl',
  '2xl': 'w-20 h-20 text-2xl',
};

const statusSizeClasses = {
  xs: 'w-1.5 h-1.5',
  sm: 'w-2 h-2',
  md: 'w-2.5 h-2.5',
  lg: 'w-3 h-3',
  xl: 'w-3.5 h-3.5',
  '2xl': 'w-4 h-4',
};

const statusColorClasses = {
  online: 'bg-success',
  offline: 'bg-text-tertiary',
  busy: 'bg-error',
  away: 'bg-warning',
};

const ringColorClasses = {
  primary: 'ring-primary',
  success: 'ring-success',
  warning: 'ring-warning',
  error: 'ring-error',
  white: 'ring-white',
};

// Generate consistent background color from name
const getBackgroundColor = (name: string) => {
  const colors = [
    'bg-primary',
    'bg-secondary',
    'bg-success',
    'bg-warning',
    'bg-error',
    'bg-info',
  ];
  let hash = 0;
  for (let i = 0; i < name.length; i++) {
    hash = name.charCodeAt(i) + ((hash << 5) - hash);
  }
  return colors[Math.abs(hash) % colors.length];
};

const backgroundColor = name ? getBackgroundColor(name) : 'bg-background-muted';
---

<div
  class:list={[
    'avatar relative inline-flex items-center justify-center flex-shrink-0',
    'font-medium text-white select-none',
    sizeClasses[size],
    square ? 'rounded-lg' : 'rounded-full',
    ring && `ring-2 ring-offset-2 ring-offset-surface ${ringColorClasses[ringColor]}`,
    !src && backgroundColor,
    className,
  ]}
  data-avatar
>
  {src ? (
    <img
      src={src}
      alt={alt || name || 'Avatar'}
      class:list={[
        'w-full h-full object-cover',
        square ? 'rounded-lg' : 'rounded-full',
      ]}
      loading="lazy"
      decoding="async"
      data-avatar-image
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <span
      class:list={[
        'avatar-fallback hidden items-center justify-center w-full h-full',
        backgroundColor,
        square ? 'rounded-lg' : 'rounded-full',
      ]}
      aria-hidden="true"
    >
      {initials || (
        <svg class="w-1/2 h-1/2 text-white/70" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
        </svg>
      )}
    </span>
  ) : initials ? (
    <span class="avatar-initials" aria-hidden="true">
      {initials}
    </span>
  ) : (
    <svg class="w-1/2 h-1/2 text-white/70" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
    </svg>
  )}

  <!-- Status indicator -->
  {status && (
    <span
      class:list={[
        'avatar-status absolute bottom-0 right-0 block rounded-full ring-2 ring-surface',
        statusSizeClasses[size],
        statusColorClasses[status],
      ]}
      aria-label={`Status: ${status}`}
    />
  )}

  <!-- Slot for custom content/badges -->
  <slot />
</div>

<style>
  .avatar img {
    transition: opacity var(--duration-200) var(--ease-out);
  }

  .avatar:hover img {
    opacity: 0.9;
  }
</style>
