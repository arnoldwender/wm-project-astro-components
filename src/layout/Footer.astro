---

<footer class:list={["border-t border-gray-800", className]}>
  <div class="container mx-auto px-4 py-12 md:py-16">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand & Description -->
      <div class="space-y-4">
        <a href="/" aria-label={`${siteName} - Home`}>
          {logo ? (
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-12 md:h-14 w-auto mb-4"
              width={logo.width || 200}
              height={logo.height || 56}
            />
          ) : (
            <span class="text-xl font-bold">{siteName}</span>
          )}
        </a>
        {description && (
          <p class="text-sm leading-relaxed opacity-70 max-w-xs">
            {description}
          </p>
        )}
      </div>

      <!-- Quick Links -->
      {links.length > 0 && (
        <div>
          <h4 class="font-semibold mb-4 text-sm uppercase tracking-wider">
            Links
          </h4>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="opacity-70 hover:opacity-100 transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Contact Info -->
      {(contactEmail || contactPhone || address) && (
        <div>
          <h4 class="font-semibold mb-4 text-sm uppercase tracking-wider">
            Contact
          </h4>
          <ul class="space-y-3 text-sm">
            {contactEmail && (
              <li>
                <a
                  href={`mailto:${contactEmail}`}
                  class="opacity-70 hover:opacity-100 transition-colors"
                >
                  {contactEmail}
                </a>
              </li>
            )}
            {contactPhone && (
              <li>
                <a
                  href={`tel:${contactPhone}`}
                  class="opacity-70 hover:opacity-100 transition-colors"
                >
                  {contactPhone}
                </a>
              </li>
            )}
            {address && (
              <li class="opacity-70">
                {address}
              </li>
            )}
          </ul>
        </div>
      )}
    </div>

    <!-- Social Links -->
    {socialLinks.length > 0 && (
      <div class="flex flex-wrap items-center justify-center gap-6 mb-8 pt-8 border-t border-gray-800">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="opacity-70 hover:opacity-100 transition-colors"
            aria-label={social.name}
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d={iconPaths[social.icon]} />
            </svg>
          </a>
        ))}
      </div>
    )}

    <!-- Copyright -->
    <div class="text-center opacity-70 text-xs">
      <p>{copyrightText}</p>
    </div>
  </div>
</footer>
