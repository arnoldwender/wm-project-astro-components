---
/**
 * Footer Component - WenderMedia Astro Components
 *
 * Responsive multi-column site footer with brand section, quick links,
 * contact details, social media icons, and copyright line. Use as the
 * closing landmark on every page.
 *
 * Features:
 * - Three-column grid: brand/description, quick links, contact info
 * - Built-in SVG icons for 7 social platforms (Instagram, Facebook, Twitter, LinkedIn, Behance, GitHub, YouTube)
 * - Logo image or text-based branding via the logo prop
 * - Auto-generated copyright year when no custom text is provided
 * - Semantic HTML with accessible aria-labels on social links
 * - Fully responsive: collapses to single column on small screens
 *
 * @example
 * ---
 * import Footer from '@components/layout/Footer.astro';
 * ---
 * <Footer
 *   siteName="Acme Corp"
 *   description="Building innovative solutions since 2010."
 *   links={[
 *     { label: 'Impressum', href: '/impressum' },
 *     { label: 'Datenschutz', href: '/datenschutz' },
 *     { label: 'Blog', href: '/blog' },
 *   ]}
 *   socialLinks={[
 *     { name: 'Instagram', href: 'https://instagram.com/acme', icon: 'instagram' },
 *     { name: 'LinkedIn', href: 'https://linkedin.com/company/acme', icon: 'linkedin' },
 *   ]}
 *   contactEmail="info@example.com"
 *   contactPhone="+49 345 12345"
 *   address="123 Main St, 06108 Halle (Saale)"
 * />
 *
 * @example
 * <!-- Minimal footer with logo and custom copyright -->
 * <Footer
 *   logo={{ src: '/images/logo-white.svg', alt: 'Acme Corp' }}
 *   copyright="2020-2026 Acme Corp. All rights reserved."
 * />
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface FooterLink {
  label: string;
  href: string;
}

export interface SocialLink {
  name: string;
  href: string;
  icon: 'instagram' | 'facebook' | 'twitter' | 'linkedin' | 'behance' | 'github' | 'youtube';
}

export interface Props {
  logo?: {
    src: string;
    alt: string;
    width?: number;
    height?: number;
  };
  siteName?: string;
  description?: string;
  links?: FooterLink[];
  socialLinks?: SocialLink[];
  contactEmail?: string;
  contactPhone?: string;
  address?: string;
  copyright?: string;
  class?: string;
}

const {
  logo,
  siteName = 'Site Name',
  description,
  links = [],
  socialLinks = [],
  contactEmail,
  contactPhone,
  address,
  copyright,
  class: className = '',
} = Astro.props;

const currentYear = new Date().getFullYear();
const copyrightText = copyright || `© ${currentYear} ${siteName}. All rights reserved.`;

