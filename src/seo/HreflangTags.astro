---
/**
 * HreflangTags Component - WenderMedia Astro Components
 *
 * Generate hreflang tags for multilingual SEO.
 * Helps search engines serve the correct language version.
 *
 * Features:
 * - Generates one <link rel="alternate"> per locale
 * - Automatically adds an x-default tag pointing to the default locale
 * - Works with subdomain, subdirectory, or separate-domain strategies
 *
 * @example
 * <!-- Bilingual site (German default, English alternate) -->
 * <HreflangTags
 *   currentLocale="de"
 *   locales={[
 *     { lang: 'de', url: 'https://example.com/de/seite' },
 *     { lang: 'en', url: 'https://example.com/en/page' },
 *   ]}
 *   defaultLocale="de"
 * />
 *
 * @example
 * <!-- Three locales with separate domains -->
 * <HreflangTags
 *   currentLocale="en"
 *   locales={[
 *     { lang: 'en', url: 'https://example.com/about' },
 *     { lang: 'de', url: 'https://example.de/ueber-uns' },
 *     { lang: 'es', url: 'https://example.es/sobre-nosotros' },
 *   ]}
 * />
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface LocaleLink {
  lang: string;
  url: string;
}

export interface Props {
  currentLocale: string;
  locales: LocaleLink[];
  defaultLocale?: string;
}

const {
  currentLocale,
  locales,
  defaultLocale = locales[0]?.lang,
} = Astro.props;

// Get x-default URL
const xDefaultUrl = locales.find(l => l.lang === defaultLocale)?.url || locales[0]?.url;
---

<!-- Hreflang tags for each locale -->
{locales.map(({ lang, url }) => (
  <link rel="alternate" hreflang={lang} href={url} />
))}

<!-- x-default for language/region selector pages -->
{xDefaultUrl && (
  <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
)}
