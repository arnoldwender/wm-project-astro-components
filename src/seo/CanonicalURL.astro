---
/**
 * CanonicalURL Component - WenderMedia Astro Components
 *
 * Set the canonical URL to prevent duplicate content issues.
 * Automatically handles trailing slashes and query parameters.
 *
 * Features:
 * - Automatic URL normalization (strips query params and trailing slashes)
 * - Falls back to the current page URL when no explicit url is provided
 * - Configurable: keep query params or trailing slashes when needed
 *
 * @example
 * <!-- Auto-detect canonical from the current page URL -->
 * <CanonicalURL />
 *
 * @example
 * <!-- Explicit canonical for a specific page -->
 * <CanonicalURL url="https://example.com/services/web-design" />
 *
 * @example
 * <!-- Keep query parameters (e.g. for paginated pages) -->
 * <CanonicalURL
 *   url="https://example.com/blog?page=2"
 *   removeQueryParams={false}
 * />
 *
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  url?: string;
  removeQueryParams?: boolean;
  removeTrailingSlash?: boolean;
}

const {
  url,
  removeQueryParams = true,
  removeTrailingSlash = true,
} = Astro.props;

function normalizeUrl(inputUrl: string): string {
  let normalized = inputUrl;

  // Remove query parameters if specified
  if (removeQueryParams) {
    const urlObj = new URL(normalized);
    urlObj.search = '';
    normalized = urlObj.href;
  }

  // Remove trailing slash if specified (except for root)
  if (removeTrailingSlash && normalized.endsWith('/') && normalized !== Astro.site?.href) {
    normalized = normalized.slice(0, -1);
  }

  return normalized;
}

const canonicalUrl = url
  ? normalizeUrl(url)
  : normalizeUrl(Astro.url.href);
---

<link rel="canonical" href={canonicalUrl} />
