---
/**
 * ShareBar Component - WenderMedia Astro Components
 *
 * Social sharing buttons with tracking support.
 * Accessible and GDPR-friendly (no third-party scripts).
 *
 * Features:
 * - GDPR-friendly sharing via native URLs (no third-party scripts)
 * - Supports Twitter, LinkedIn, Facebook, WhatsApp, Telegram, email, copy, and print
 * - Horizontal and vertical layout with optional labels
 * - Copy-to-clipboard with visual feedback
 * - Multiple size and style variants (default, outline, ghost)
 *
 * @example
 * <ShareBar
 *   url="https://example.com/article"
 *   title="Article Title"
 *   platforms={['twitter', 'linkedin', 'facebook', 'email', 'copy']}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export type Platform =
  | 'twitter'
  | 'linkedin'
  | 'facebook'
  | 'whatsapp'
  | 'telegram'
  | 'email'
  | 'copy'
  | 'print';

export interface Props {
  url?: string;
  title?: string;
  description?: string;
  platforms?: Platform[];
  direction?: 'horizontal' | 'vertical';
  showLabels?: boolean;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'outline' | 'ghost';
  class?: string;
}

const {
  url,
  title = '',
  description = '',
  platforms = ['twitter', 'linkedin', 'facebook', 'email', 'copy'],
  direction = 'horizontal',
  showLabels = false,
  size = 'md',
  variant = 'default',
  class: className = '',
} = Astro.props;

const shareUrl = url || Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);

const platformConfig: Record<Platform, { name: string; href?: string; icon: string; color: string }> = {
  twitter: {
    name: 'Twitter',
    href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
    icon: '<path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>',
    color: '#1DA1F2',
  },
  linkedin: {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
    icon: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
    color: '#0A66C2',
  },
  facebook: {
    name: 'Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
    icon: '<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>',
    color: '#1877F2',
  },
  whatsapp: {
    name: 'WhatsApp',
    href: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
    icon: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>',
    color: '#25D366',
  },
  telegram: {
    name: 'Telegram',
    href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
    icon: '<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>',
    color: '#0088CC',
  },
  email: {
    name: 'E-Mail',
    href: `mailto:?subject=${encodedTitle}&body=${encodedDescription}%0A%0A${encodedUrl}`,
    icon: '<path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>',
    color: '#6b7280',
  },
  copy: {
    name: 'Link kopieren',
    icon: '<path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>',
    color: '#6b7280',
  },
  print: {
    name: 'Drucken',
    icon: '<path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/>',
    color: '#6b7280',
  },
};

const sizeClasses = {
  sm: 'share-bar__btn--sm',
  md: 'share-bar__btn--md',
  lg: 'share-bar__btn--lg',
};
---

<div
  class:list={[
    'share-bar',
    `share-bar--${direction}`,
    className,
  ]}
  data-share-url={shareUrl}
>
  {platforms.map((platform) => {
    const config = platformConfig[platform];
    if (!config) return null;

    const isAction = platform === 'copy' || platform === 'print';

    return isAction ? (
      <button
        type="button"
        class:list={[
          'share-bar__btn',
          `share-bar__btn--${variant}`,
          sizeClasses[size],
        ]}
        data-share-action={platform}
        aria-label={config.name}
        style={`--btn-color: ${config.color}`}
      >
        <svg class="share-bar__icon" viewBox="0 0 24 24" fill="currentColor">
          <Fragment set:html={config.icon} />
        </svg>
        {showLabels && <span class="share-bar__label">{config.name}</span>}
      </button>
    ) : (
      <a
        href={config.href}
        class:list={[
          'share-bar__btn',
          `share-bar__btn--${variant}`,
          sizeClasses[size],
        ]}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Teilen auf ${config.name}`}
        style={`--btn-color: ${config.color}`}
      >
        <svg class="share-bar__icon" viewBox="0 0 24 24" fill="currentColor">
          <Fragment set:html={config.icon} />
        </svg>
        {showLabels && <span class="share-bar__label">{config.name}</span>}
      </a>
    );
  })}
</div>

<!-- Toast for copy feedback -->
<div id="share-toast" class="share-toast" aria-live="polite" hidden>
  Link kopiert!
</div>

<style>
  .share-bar {
    display: flex;
    gap: 0.5rem;
  }

  .share-bar--vertical {
    flex-direction: column;
  }

  .share-bar__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
    border-radius: 0.5rem;
    color: var(--btn-color, #6b7280);
    background: transparent;
  }

  .share-bar__btn--sm {
    width: 2rem;
    height: 2rem;
  }

  .share-bar__btn--md {
    width: 2.5rem;
    height: 2.5rem;
  }

  .share-bar__btn--lg {
    width: 3rem;
    height: 3rem;
  }

  .share-bar__btn--default {
    background: var(--btn-color, #6b7280);
    color: #fff;
  }

  .share-bar__btn--default:hover {
    opacity: 0.9;
    transform: scale(1.05);
  }

  .share-bar__btn--outline {
    border: 1px solid var(--btn-color, #6b7280);
  }

  .share-bar__btn--outline:hover {
    background: var(--btn-color, #6b7280);
    color: #fff;
  }

  .share-bar__btn--ghost:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .share-bar__icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .share-bar__btn--sm .share-bar__icon {
    width: 1rem;
    height: 1rem;
  }

  .share-bar__btn--lg .share-bar__icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .share-bar__label {
    font-size: 0.875rem;
    font-weight: 500;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Toast */
  .share-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.75rem 1.5rem;
    background: #111;
    color: #fff;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    z-index: 9999;
    animation: slideUp 0.3s ease;
  }

  .share-toast[hidden] {
    display: none;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }
</style>

<script>
  function initShareBar() {
    const copyButtons = document.querySelectorAll('[data-share-action="copy"]');
    const printButtons = document.querySelectorAll('[data-share-action="print"]');
    const toast = document.getElementById('share-toast');

    copyButtons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const shareBar = btn.closest('[data-share-url]');
        const url = shareBar?.getAttribute('data-share-url') || window.location.href;

        try {
          await navigator.clipboard.writeText(url);
          if (toast) {
            toast.hidden = false;
            setTimeout(() => {
              toast.hidden = true;
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });

    printButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        window.print();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareBar);
  } else {
    initShareBar();
  }

  document.addEventListener('astro:page-load', initShareBar);
</script>
