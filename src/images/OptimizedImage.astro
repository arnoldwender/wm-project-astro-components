---
/**
 * OptimizedImage Component - WenderMedia Astro Components
 *
 * Premium responsive image with modern format support.
 *
 * Features:
 * - Automatic WebP/AVIF format detection via <picture>
 * - Responsive srcset with customizable breakpoints
 * - Lazy loading with native browser support
 * - Priority loading for LCP images
 * - Blur-up placeholder option
 * - Progressive LQIP (Low Quality Image Placeholder) with blur-up crossfade
 * - Aspect ratio preservation
 * - Art direction support
 * - Reduced motion support for animations
 *
 * @example
 * <OptimizedImage
 *   src="/images/hero.jpg"
 *   alt="Hero image"
 *   width={1200}
 *   height={630}
 *   priority
 * />
 *
 * @example
 * <OptimizedImage
 *   src="/images/product.jpg"
 *   webpSrc="/images/product.webp"
 *   avifSrc="/images/product.avif"
 *   alt="Product"
 *   aspectRatio="4/3"
 * />
 *
 * @example Blur-up LQIP progressive loading
 * <OptimizedImage
 *   src="/images/hero.jpg"
 *   alt="Hero"
 *   blurUp
 *   blurDataUrl="data:image/jpeg;base64,/9j/4AAQ..."
 *   width={1200}
 *   height={630}
 * />
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
 */

export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  priority?: boolean;
  sizes?: string;
  breakpoints?: number[];
  // Modern format sources
  webpSrc?: string;
  avifSrc?: string;
  // Placeholder
  placeholder?: 'blur' | 'none';
  blurDataURL?: string;
  /** Enable progressive blur-up LQIP loading: show a tiny blurred image first, then crossfade */
  blurUp?: boolean;
  /** Base64-encoded tiny image (e.g. 20x20px) used as the LQIP source when blurUp=true */
  blurDataUrl?: string;
  // Layout
  aspectRatio?: string;
  objectFit?: 'contain' | 'cover' | 'fill' | 'none' | 'scale-down';
  objectPosition?: string;
  // Styling
  class?: string;
  imgClass?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  priority = false,
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw',
  breakpoints = [400, 600, 800, 1200, 1600],
  webpSrc,
  avifSrc,
  placeholder = 'none',
  blurDataURL,
  blurUp = false,
  blurDataUrl,
  aspectRatio,
  objectFit = 'cover',
  objectPosition = 'center',
  class: className = '',
  imgClass = '',
} = Astro.props;

// Helper to generate srcset for a given source
const generateSrcset = (baseSrc: string): string => {
  // If the src contains query params or is external, don't generate srcset
  if (baseSrc.includes('?') || baseSrc.startsWith('http')) {
    return baseSrc;
  }
  return breakpoints.map((size: number) => `${baseSrc} ${size}w`).join(', ');
};

// Auto-detect WebP/AVIF sources if not provided
const getModernSrc = (originalSrc: string, format: 'webp' | 'avif'): string | undefined => {
  if (format === 'webp' && webpSrc) return webpSrc;
  if (format === 'avif' && avifSrc) return avifSrc;

  // Auto-generate path by replacing extension
  const extMatch = originalSrc.match(/\.(jpe?g|png|gif)$/i);
  if (extMatch) {
    return originalSrc.replace(extMatch[0], `.${format}`);
  }
  return undefined;
};

const avifSource = getModernSrc(src, 'avif');
const webpSource = getModernSrc(src, 'webp');

// Generate srcsets
const fallbackSrcset = generateSrcset(src);
const avifSrcset = avifSource ? generateSrcset(avifSource) : undefined;
const webpSrcset = webpSource ? generateSrcset(webpSource) : undefined;

// Resolve LQIP source: blurUp mode uses blurDataUrl, legacy placeholder uses blurDataURL
const resolvedLqipSrc = blurUp ? blurDataUrl : blurDataURL;
const hasBlurPlaceholder = (placeholder === 'blur' && blurDataURL) || blurUp;

// Blur placeholder styling
const blurStyle = hasBlurPlaceholder && resolvedLqipSrc
  ? `background-image: url(${resolvedLqipSrc}); background-size: cover;`
  : '';

// Aspect ratio styling
const aspectStyle = aspectRatio ? `aspect-ratio: ${aspectRatio};` : '';
const containerStyle = [blurStyle, aspectStyle].filter(Boolean).join(' ');
---

<picture
  class:list={[
    'optimized-image',
    hasBlurPlaceholder && 'has-placeholder',
    blurUp && 'blur-up',
    className,
  ]}
  style={containerStyle || undefined}
  data-optimized-image
>
 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  {/* AVIF source - best compression, newest format */}
  {avifSrcset && (
    <source
      type="image/avif"
      srcset={avifSrcset}
      sizes={sizes}
    />
  )}

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  {/* WebP source - good compression, wide support */}
  {webpSrcset && (
    <source
      type="image/webp"
      srcset={webpSrcset}
      sizes={sizes}
    />
  )}

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  {/* Fallback image */}
  <img
    src={src}
    srcset={fallbackSrcset}
    sizes={sizes}
    alt={alt}
    width={width}
    height={height}
    loading={priority ? 'eager' : loading}
    decoding={priority ? 'sync' : 'async'}
    class:list={[
      'optimized-image-img',
      imgClass,
    ]}
    style={`object-fit: ${objectFit}; object-position: ${objectPosition};`}
    data-placeholder={blurUp ? 'blur-up' : placeholder}
    data-priority={priority ? 'high' : undefined}
    onload={hasBlurPlaceholder ? "this.parentElement.classList.add('loaded')" : undefined}
  />
</picture>

<style>
  .optimized-image {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .optimized-image-img {
    display: block;
    width: 100%;
    height: 100%;
  }

 * @copyright 2007-2026 Wender Media - Arnold Wender. MIT License.
 * @see https://github.com/arnoldwender/wm-project-astro-components
  /* Blur placeholder animation */
  .optimized-image.has-placeholder .optimized-image-img {
    opacity: 0;
    transition: opacity var(--duration-300, 300ms) var(--ease-out, ease-out);
  }

  .optimized-image.has-placeholder.loaded .optimized-image-img {
    opacity: 1;
  }

  .optimized-image.has-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: inherit;
    filter: blur(20px);
    transform: scale(1.1);
    transition: opacity var(--duration-300, 300ms) var(--ease-out, ease-out);
  }

  .optimized-image.has-placeholder.loaded::before {
    opacity: 0;
  }

  /* --- Blur-up LQIP mode ---
   * Shows the tiny base64 image with blur(20px), then crossfades to the
   * full-resolution image once it has loaded. */
  .optimized-image.blur-up .optimized-image-img {
    opacity: 0;
    filter: blur(0);
    transition:
      opacity var(--duration-500, 500ms) var(--ease-out, ease-out),
      filter var(--duration-500, 500ms) var(--ease-out, ease-out);
  }

  .optimized-image.blur-up::before {
    content: '';
    position: absolute;
    inset: 0;
    background: inherit;
    background-size: cover;
    filter: blur(20px);
    transform: scale(1.1); /* prevent blurred edges showing */
    transition: opacity var(--duration-500, 500ms) var(--ease-out, ease-out);
  }

  .optimized-image.blur-up.loaded .optimized-image-img {
    opacity: 1;
    filter: blur(0);
  }

  .optimized-image.blur-up.loaded::before {
    opacity: 0;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .optimized-image.has-placeholder .optimized-image-img,
    .optimized-image.has-placeholder::before,
    .optimized-image.blur-up .optimized-image-img,
    .optimized-image.blur-up::before {
      transition: none;
    }

    .optimized-image.has-placeholder .optimized-image-img,
    .optimized-image.blur-up .optimized-image-img {
      opacity: 1;
      filter: none;
    }

    .optimized-image.has-placeholder::before,
    .optimized-image.blur-up::before {
      display: none;
    }
  }
</style>
