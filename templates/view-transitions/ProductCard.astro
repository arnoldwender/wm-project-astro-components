---
/**
 * Product Card with View Transitions
 *
 * Creates smooth morph transitions when navigating
 * from product listing to product detail page.
 */

interface Props {
  slug: string;
  name: string;
  price: number;
  compareAtPrice?: number;
  image: string;
  imageAlt: string;
  category?: string;
  badge?: 'new' | 'sale' | 'bestseller';
}

const { slug, name, price, compareAtPrice, image, imageAlt, category, badge } = Astro.props;

// Unique transition names
const imageTransition = `product-image-${slug}`;
const nameTransition = `product-name-${slug}`;
const priceTransition = `product-price-${slug}`;

const discount = compareAtPrice ? Math.round((1 - price / compareAtPrice) * 100) : 0;

const badgeText = {
  new: 'Neu',
  sale: `-${discount}%`,
  bestseller: 'Bestseller',
};

const badgeClass = {
  new: 'badge-new',
  sale: 'badge-sale',
  bestseller: 'badge-bestseller',
};
---

<article class="product-card">
  <a href={`/products/${slug}`} class="card-link">
    <div class="card-image">
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
        transition:name={imageTransition}
      />
      {
        badge && (
          <span class={`badge ${badgeClass[badge]}`}>
            {badge === 'sale' && compareAtPrice ? `-${discount}%` : badgeText[badge]}
          </span>
        )
      }
    </div>

    <div class="card-content">
      {category && <span class="category">{category}</span>}
      <h3 transition:name={nameTransition}>{name}</h3>
      <div class="price-wrapper" transition:name={priceTransition}>
        <span class="price">€{price.toFixed(2).replace('.', ',')}</span>
        {
          compareAtPrice && (
            <span class="compare-price">€{compareAtPrice.toFixed(2).replace('.', ',')}</span>
          )
        }
      </div>
    </div>
  </a>
</article>

<style>
  .product-card {
    background: white;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.1);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgb(0 0 0 / 0.15);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f8fafc;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-card:hover .card-image img {
    transform: scale(1.05);
  }

  .badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .badge-new {
    background: #3b82f6;
    color: white;
  }

  .badge-sale {
    background: #ef4444;
    color: white;
  }

  .badge-bestseller {
    background: #f59e0b;
    color: white;
  }

  .card-content {
    padding: 1rem;
  }

  .category {
    display: block;
    font-size: 0.75rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .price-wrapper {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .price {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
  }

  .compare-price {
    font-size: 0.875rem;
    color: #94a3b8;
    text-decoration: line-through;
  }
</style>
