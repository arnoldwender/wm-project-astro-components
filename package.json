{
  "name": "@wendermedia/astro-components",
  "version": "4.0.1",
  "description": "Complete Astro 7 development resource - components, bundles, integrations, and utilities",
  "type": "module",
  "main": "./index.ts",
  "bin": {
    "create-wm-component": "./cli/bin.js",
    "wm-components": "./cli/bin.js"
  },
  "exports": {
    ".": "./index.ts",
    "./layout": "./src/layout/index.ts",
    "./layouts": "./src/layouts/index.ts",
    "./seo": "./src/seo/index.ts",
    "./accessibility": "./src/accessibility/index.ts",
    "./sections": "./src/sections/index.ts",
    "./gallery": "./src/gallery/index.ts",
    "./forms": "./src/forms/index.ts",
    "./products": "./src/products/index.ts",
    "./images": "./src/images/index.ts",
    "./maps": "./src/maps/index.ts",
    "./legal": "./src/legal/index.ts",
    "./social": "./src/social/index.ts",
    "./navigation": "./src/navigation/index.ts",
    "./content": "./src/content/index.ts",
    "./ecommerce": "./src/ecommerce/index.ts",
    "./media": "./src/media/index.ts",
    "./ui": "./src/ui/index.ts",
    "./design-system": "./src/design-system/index.ts",
    "./design-system/tokens/*": "./src/design-system/tokens/*",
    "./design-system/base/*": "./src/design-system/base/*",
    "./design-system/utilities/*": "./src/design-system/utilities/*",
    "./tokens": "./tokens/index.ts",
    "./integrations/react/*": "./integrations/react/*",
    "./integrations/vue/*": "./integrations/vue/*",
    "./integrations/svelte/*": "./integrations/svelte/*",
    "./integrations/solid/*": "./integrations/solid/*",
    "./integrations/wordpress": "./integrations/wordpress/index.ts",
    "./bundles/*": "./bundles/*",
    "./templates/*": "./templates/*",
    "./utilities/*": "./utilities/*",
    "./testing": "./testing/index.ts"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:a11y": "vitest --config vitest.a11y.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "tokens:build": "style-dictionary build --config tokens/config.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "files": [
    "src",
    "cli",
    "integrations",
    "bundles",
    "templates",
    "utilities",
    "tokens",
    "testing",
    "docs",
    "index.ts",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "astro-component",
    "astro",
    "astro7",
    "components",
    "ui",
    "css",
    "seo",
    "performance",
    "optimization",
    "accessibility",
    "a11y",
    "wcag",
    "gdpr",
    "dsgvo",
    "bfsg",
    "image",
    "images",
    "media",
    "video",
    "audio",
    "maps",
    "social-share",
    "react",
    "vue",
    "svelte",
    "solid",
    "content-collections",
    "view-transitions",
    "i18n",
    "design-system",
    "design-tokens",
    "css-variables",
    "theming",
    "dark-mode",
    "tailwind",
    "tailwind4",
    "wordpress",
    "headless-cms"
  ],
  "author": "Arnold Wender <info@wendermedia.com> (https://www.wendermedia.com)",
  "license": "LicenseRef-Wender-Media-Source-1.0",
  "homepage": "https://github.com/arnoldwender/wm-project-astro-components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arnoldwender/wm-project-astro-components.git"
  },
  "bugs": {
    "url": "https://github.com/arnoldwender/wm-project-astro-components/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/arnoldwender"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependencies": {
    "@justinribeiro/lite-youtube": "^1.9.0",
    "astro": "^6.0.0 || ^7.0.0",
    "gsap": "^3.11.0"
  },
  "peerDependenciesMeta": {
    "gsap": {
      "optional": true
    },
    "@justinribeiro/lite-youtube": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/solid-js": "^7.0.0",
    "@astrojs/svelte": "^9.0.0",
    "@astrojs/vue": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4"
  },
  "overrides": {
    "vite": "^8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/web-components": "^10.3.6",
    "@storybook/web-components-vite": "^10.3.6",
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "astro": "^7.0.0",
    "axe-core": "^4.11.4",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^2.1.1",
    "gsap": "^3.15.0",
    "happy-dom": "^20.9.0",
    "lit": "^3.3.2",
    "storybook": "^10.3.6",
    "style-dictionary": "^5.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
