{
  "name": "@wendermedia/astro-components",
  "version": "2.0.0",
  "description": "Complete Astro development resource - components, bundles, integrations, and utilities",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./layout": "./src/layout/index.ts",
    "./seo": "./src/seo/index.ts",
    "./accessibility": "./src/accessibility/index.ts",
    "./sections": "./src/sections/index.ts",
    "./gallery": "./src/gallery/index.ts",
    "./forms": "./src/forms/index.ts",
    "./products": "./src/products/index.ts",
    "./images": "./src/images/index.ts",
    "./maps": "./src/maps/index.ts",
    "./social": "./src/social/index.ts",
    "./design-system": "./src/design-system/index.ts",
    "./design-system/tokens/*": "./src/design-system/tokens/*",
    "./design-system/base/*": "./src/design-system/base/*",
    "./design-system/utilities/*": "./src/design-system/utilities/*",
    "./integrations/react/*": "./integrations/react/*",
    "./integrations/vue/*": "./integrations/vue/*",
    "./integrations/svelte/*": "./integrations/svelte/*",
    "./integrations/solid/*": "./integrations/solid/*",
    "./bundles/*": "./bundles/*",
    "./templates/*": "./templates/*",
    "./utilities/*": "./utilities/*"
  },
  "files": [
    "src",
    "integrations",
    "bundles",
    "templates",
    "utilities",
    "docs",
    "index.ts"
  ],
  "keywords": [
    "astro",
    "components",
    "ui",
    "seo",
    "accessibility",
    "wcag",
    "gdpr",
    "dsgvo",
    "maps",
    "social-share",
    "react",
    "vue",
    "svelte",
    "solid",
    "content-collections",
    "view-transitions",
    "i18n",
    "design-system",
    "design-tokens",
    "css-variables",
    "theming",
    "dark-mode"
  ],
  "author": "Arnold Wender <arnold.wender@gmail.com>",
  "license": "PROPRIETARY",
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "optionalDependencies": {
    "@astrojs/react": "^3.0.0",
    "@astrojs/vue": "^4.0.0",
    "@astrojs/svelte": "^5.0.0",
    "@astrojs/solid-js": "^4.0.0",
    "@astrojs/mdx": "^3.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@astrojs/tailwind": "^5.0.0",
    "@astrojs/partytown": "^2.0.0"
  },
  "devDependencies": {
    "astro": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
