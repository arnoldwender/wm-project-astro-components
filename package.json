{
  "name": "wm-project-astro-components",
  "version": "2.0.0",
  "description": "Complete Astro development resource - components, bundles, integrations, and utilities",
  "type": "module",
  "main": "./index.ts",
  "bin": {
    "create-wm-component": "./cli/bin.js",
    "wm-components": "./cli/bin.js"
  },
  "exports": {
    ".": "./index.ts",
    "./layout": "./src/layout/index.ts",
    "./seo": "./src/seo/index.ts",
    "./accessibility": "./src/accessibility/index.ts",
    "./sections": "./src/sections/index.ts",
    "./gallery": "./src/gallery/index.ts",
    "./forms": "./src/forms/index.ts",
    "./products": "./src/products/index.ts",
    "./images": "./src/images/index.ts",
    "./maps": "./src/maps/index.ts",
    "./social": "./src/social/index.ts",
    "./navigation": "./src/navigation/index.ts",
    "./content": "./src/content/index.ts",
    "./ecommerce": "./src/ecommerce/index.ts",
    "./media": "./src/media/index.ts",
    "./design-system": "./src/design-system/index.ts",
    "./design-system/tokens/*": "./src/design-system/tokens/*",
    "./design-system/base/*": "./src/design-system/base/*",
    "./design-system/utilities/*": "./src/design-system/utilities/*",
    "./tokens": "./tokens/index.ts",
    "./integrations/react/*": "./integrations/react/*",
    "./integrations/vue/*": "./integrations/vue/*",
    "./integrations/svelte/*": "./integrations/svelte/*",
    "./integrations/solid/*": "./integrations/solid/*",
    "./integrations/wordpress": "./integrations/wordpress/index.ts",
    "./bundles/*": "./bundles/*",
    "./templates/*": "./templates/*",
    "./utilities/*": "./utilities/*",
    "./testing": "./testing/index.ts"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:a11y": "vitest --config vitest.a11y.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "tokens:build": "style-dictionary build --config tokens/config.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "files": [
    "src",
    "cli",
    "integrations",
    "bundles",
    "templates",
    "utilities",
    "tokens",
    "testing",
    "docs",
    "index.ts"
  ],
  "keywords": [
    "astro",
    "components",
    "ui",
    "seo",
    "accessibility",
    "wcag",
    "gdpr",
    "dsgvo",
    "bfsg",
    "maps",
    "social-share",
    "react",
    "vue",
    "svelte",
    "solid",
    "content-collections",
    "view-transitions",
    "i18n",
    "design-system",
    "design-tokens",
    "css-variables",
    "theming",
    "dark-mode",
    "wordpress",
    "headless-cms"
  ],
  "author": "Arnold Wender <arnold.wender@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/arnoldwender/wm-project-astro-components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arnoldwender/wm-project-astro-components.git"
  },
  "bugs": {
    "url": "https://github.com/arnoldwender/wm-project-astro-components/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/arnoldwender"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "optionalDependencies": {
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/partytown": "^2.1.5",
    "@astrojs/react": "^3.6.3",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/solid-js": "^4.4.4",
    "@astrojs/svelte": "^7.2.5",
    "@astrojs/tailwind": "^5.1.5",
    "@astrojs/vue": "^4.5.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/blocks": "^8.0.0",
    "@storybook/web-components": "^8.0.0",
    "@storybook/web-components-vite": "^8.6.18",
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^2.1.9",
    "astro": "^5.18.1",
    "axe-core": "^4.11.1",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.6.0",
    "happy-dom": "^20.8.8",
    "storybook": "^8.6.18",
    "style-dictionary": "^5.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.1"
  }
}
