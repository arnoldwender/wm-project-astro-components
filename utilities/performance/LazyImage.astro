---
/**
 * Lazy Loading Image Component
 *
 * Optimized image loading with:
 * - Native lazy loading
 * - Blur placeholder
 * - Aspect ratio preservation
 * - Responsive srcset
 */

import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  // Image source (can be import or string URL)
  src: ImageMetadata | string;
  alt: string;

  // Dimensions (required for aspect ratio)
  width?: number;
  height?: number;

  // Loading strategy
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';

  // Responsive
  sizes?: string;
  widths?: number[];

  // Placeholder
  placeholder?: 'blur' | 'color' | 'none';
  placeholderColor?: string;

  // Styling
  class?: string;
  style?: string;

  // Object fit
  fit?: 'contain' | 'cover' | 'fill' | 'none' | 'scale-down';
  position?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  sizes = '100vw',
  widths = [400, 800, 1200, 1600],
  placeholder = 'blur',
  placeholderColor = '#e5e7eb',
  class: className = '',
  style = '',
  fit = 'cover',
  position = 'center',
} = Astro.props;

// Get image metadata
const isLocal = typeof src !== 'string';
let optimizedImage;
let srcset;
let blurDataUrl = '';

if (isLocal) {
  // Generate optimized image
  optimizedImage = await getImage({
    src: src as ImageMetadata,
    width: width || (src as ImageMetadata).width,
    height: height || (src as ImageMetadata).height,
    format: 'webp',
  });

  // Generate srcset for responsive images
  const srcsetImages = await Promise.all(
    widths.map(async (w) => {
      const img = await getImage({
        src: src as ImageMetadata,
        width: w,
        format: 'webp',
      });
      return `${img.src} ${w}w`;
    })
  );
  srcset = srcsetImages.join(', ');

  // Generate blur placeholder (tiny version)
  if (placeholder === 'blur') {
    const blurImage = await getImage({
      src: src as ImageMetadata,
      width: 20,
      format: 'webp',
      quality: 10,
    });
    blurDataUrl = blurImage.src;
  }
}

const imgWidth = width || (isLocal ? (src as ImageMetadata).width : undefined);
const imgHeight = height || (isLocal ? (src as ImageMetadata).height : undefined);
const aspectRatio = imgWidth && imgHeight ? imgWidth / imgHeight : undefined;

const finalSrc = isLocal ? optimizedImage?.src : src;
---

<div
  class:list={['lazy-image-container', className]}
  style={`
    ${aspectRatio ? `aspect-ratio: ${aspectRatio};` : ''}
    ${style}
  `}
>
  {/* Placeholder */}
  {
    placeholder === 'blur' && blurDataUrl && (
      <div
        class="lazy-image-placeholder"
        style={`background-image: url(${blurDataUrl});`}
        aria-hidden="true"
      />
    )
  }
  {
    placeholder === 'color' && (
      <div
        class="lazy-image-placeholder"
        style={`background-color: ${placeholderColor};`}
        aria-hidden="true"
      />
    )
  }

  {/* Actual image */}
  <img
    src={finalSrc}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    width={imgWidth}
    height={imgHeight}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class="lazy-image"
    style={`object-fit: ${fit}; object-position: ${position};`}
    onload="this.parentElement.classList.add('loaded')"
  />
</div>

<style>
  .lazy-image-container {
    position: relative;
    overflow: hidden;
    background-color: #f3f4f6;
  }

  .lazy-image-placeholder {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(20px);
    transform: scale(1.1);
    transition: opacity 0.3s ease-out;
  }

  .lazy-image {
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }

  .lazy-image-container.loaded .lazy-image {
    opacity: 1;
  }

  .lazy-image-container.loaded .lazy-image-placeholder {
    opacity: 0;
  }
</style>
